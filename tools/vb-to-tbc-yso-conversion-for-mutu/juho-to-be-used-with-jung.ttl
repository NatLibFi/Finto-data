  skos:prefLabel "tillgodoräknande av icke-formell kunskap"@sv ;
  juho-meta:hasSelite """Opetus- ja koulutussanasto, 2. laitos (OKM, 2021:10) : ”toimenpide, jossa sovitaan, että osaaminen, jota opiskelija tulee hankkimaan oppilaitoksen tai korkeakoulun (1) ulkopuolella muuten kuin opiskelemalla, tullaan dokumentoimaan, tunnistamaan (ks. osaamisen tunnistaminen) ja tunnustamaan (ks. osaamisen tunnustaminen) osaksi tavoitteena olevaa tutkintoa”. Opinnollistaminen eroaa osaamisen tunnustamisesta siten, että opinnollistamisesta sovitaan ennen osaamisen hankkimista (esimerkiksi työn aloittamista). Opetus- ja koulutussanasto, 2. laitos (OKM, 2021:10) {@fi}
""" ;
  juho-meta:hasThematicGroup juho:p115 ;
