juho:p10961  a                      juho-meta:Concept;
        rdfs:subClassOf             yso:p1127 , juho-meta:juho-kasitteet;
        skos:altLabel               "FRF"@sv;
        skos:prefLabel              "FRF-räddningsgrupp"@sv , "Finn Rescue Force"@en , "FRF-pelastusjoukkue"@fi;
        juho-meta:hasSelite         "Suomen kansainvälinen pelastuskomennuskunta on koottu suurimmista pelastuslaitoksista ja koulutettu erikseen. Se voi toimia: äkillisissä luonnononnettomuuksissa - maanjäristykset, maanvyöryt, lumivyöryt, metsäpalot, tulivuorten purkaukset, tulvat ja myrskyt teknologisissa ja ympäristöonnettomuuksissa - kemikaalit, vaaralliset aineet, liikenne- ja kuljetusonnettomuudet, patosortumat, laajat asuinaluepalot sekä öljyvahingot aseellisten selkkausten yhteydessä onnettomuus- ja siviilikriisinhallinta - luonnononnettomuudet, teknologiset ja ympäristöonnettomuudet sekä siviiliväestön avustustoiminta (pelastustoimi.net) ";
        juho-meta:hasThematicGroup  juho:p26 , juho:p35 .

