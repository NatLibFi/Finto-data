finaf:000023581 a rdac:C10005,
        skos:Concept ;
    dct:created "2006-05-02"^^xsd:date ;
    dct:modified "2020-11-05T20:23:47"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000474538487>,
        "Asteri ID: 000023581" ;
    rdaa:P50035 "Perustava kokous pidetty Turun Raatihuoneella 10.10.1867, jolloin perustettiin Sjöld-Aktiebolag i Åbo ja siihen liittyvä kauppa avattiin 1.12.1867. Kauppa purettiin ja avttiin jälleen 1868. Vuonna 1903 kaupanpidon aloitti Henrik Kestiä. H. Kestilän kangas- ja lankatavarain kauppaa jatkoi poika 1911 nimellä Suomalainen Pukimo ja toiminta alotettiin virallisesti 11.8.1911. Tästä elinkeinoilmoituksesta katsotaan suomalaisen vaatetusteollisuuden alkaneen. Sittemmin Kestilän Pukimo Oy aloitti toimintansa 1932. 1970-luvulla toteutettiin organisaatiomuutos, jolloin perustettiin Kestilä Production Oy ja Kestiä Marketing Oy. 1980-luvulla yhtiö jaettiin eri yhtiöiksi"@fi ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50407 "Kestilä (yhtiö)"@fi ;
    rdau:P61101 "Grönlund, Inga. Kestilä : turkulaista vaatetusteollisuuden historiaa ja tuotesuunnittelijoita / Inga Grönlund, 2005"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Kestilä (yhtiö)"@fi .

