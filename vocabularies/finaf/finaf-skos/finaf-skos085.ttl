    rdaa:P50334 finaf:000086465 ;
    rdaa:P50393 "Johan Fredrik Granlund osti kirjapainon 1856. Granlundin kuolinpesä myi painon G. W. Wilén ja kumpp.:lle 1876, joka liitti sen tarvikkeiston omaan painoonsa."@fi ;
    rdaa:P50407 "Frenckellin kirjapaino (Turku, 1856-1876)"@fi ;
    skos:altLabel "Frenckellska boktryckeriet (Turku, 1856-1876)"@fi ;
    skos:inScheme finaf: ;
