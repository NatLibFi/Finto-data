    rdaa:P50035 "Oppilaitoksen nimenmuotoja. Tuomarniemen metsänvartijakoulu (1903–1922), Tuomarniemen metsäkoulu (1922–1964), Tuomarniemen metsäopisto (1965–1987), Tuomarniemen metsäoppilaitos (1988–2004), Seinäjoen koulutuskeskus, maatalous- ja metsäoppilaitos (2005–2007), Koulutuskeskus Sedu, Ähtäri, Tuomarniementie (2008–)."@fi ;
    rdaa:P50236 "1988/2004"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 "oppilaitos"@fi ;
    rdaa:P50350 yso:p100490 ;
    rdaa:P50407 "Tuomarniemen metsäoppilaitos"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Tuomarniemen_mets%C3%A4oppilaitos'>Wikipedia</a>, katsottu 28.11.2019"@fi,
        "Riukulehto, Sulevi: Tuomarniemi : siellä ei koskaan sada..., 2004"@fi ;
    skos:altLabel "Seinäjoen ammattikorkeakoulu. Tuomarniemen metsäoppilaitos"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Tuomarniemen metsäoppilaitos"@fi .

