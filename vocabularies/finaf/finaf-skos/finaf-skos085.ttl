    rdaa:P50025 "Radio Ylen Ykkönen"@fi,
        "Yleisradio. Radio Ykkönen"@fi ;
    rdaa:P50035 "Kanavan nimi oli (Radio) Ylen Ykkönen 1990-2003 ja sen jälkeen YLE Radio 1 tai Yle Radio 1. Suomen ainoan radiokanavan (1926–1963), Yleisohjelman (1963–1985) ja 1-verkon (1985–1990) jatkajana Yle Radio 1 on kulttuurin, asiapuheen ja radiodraaman (kuunnelmat) sekä klassisen musiikin, jazzin ja kansanmusiikin kanava."@fi,
        "Yle Radio 1 on kulttuurin, asiapuheen ja radiodraaman (kuunnelmat) sekä klassisen musiikin, jazzin ja kansanmusiikin kanava. Yle Radio 1:n edeltäjinä olivat Suomen ainoa radiokanava (1926-1963), Yleisohjelma (1963–1985) ja 1-verkko (1985–1990). Nimenä oli vuoteen 2003 asti (Radio) Ylen Ykkönen ja vuoteen 2012 asti YLE Radio 1."@fi ;
    rdaa:P50037 "1990" ;
    rdaa:P50038 "2003" ;
    rdaa:P50237 mts:m818 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Ylen Ykkönen"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Yle_Radio_1'>Wikipedia</a>, katsottu 15.3.2018"@fi,
        "Radio-ohjelmat [Äänite] : ryhmäkirjaus"@fi ;
    skos:altLabel "Radio Ylen Ykkönen"@fi,
        "Yleisradio. Radio Ykkönen"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Ylen Ykkönen"@fi .

