finaf:000027132 a rdac:C10005,
        skos:Concept ;
    dct:created "2002-07-22"^^xsd:date ;
    dct:modified "2021-06-18T19:08:31"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000027132" ;
    rdaa:P50016 finaf:000027133 ;
    rdaa:P50393 "Hjalmar Ingman ryhtyi ensimmäisenä Suomessa valmistamaan teollisesti viiliä, maalaisjuustoa, smetanaa ja rahkaa. Kauppaa käytiin Helsingin kauppatorilla ja Kauppahallissa. V. 1962 perustettiin tehdas viilituotannolle. Tehdasta laajennettiin joka viides vuosi. 1960-luvulla teki maustettu jugurtti läpimurtonsa. 1978 alettiin jäätelön valmistus teollisesti. Vuonna 1988 Ingman ja Kotisaari fuusioituivat. Vuonna 1991 yritys osti Apetit Pakaste Oy:n Huhtamäeltä ja Ingman Foods Oy Ab:lle valmistui uusi tuotantolaitos ja pääkonttori Sipooseen. Yritys keskittyi maidon jalostukseen. Leipomotoiminta myytiin Fazerille, Apetit ja Frionor pakasteiden markkinointi Lännen Tehtaat Oy:lle. Mehujen ja juomien markkinointi siirrettiin Chymos Juomat OY:lle, jonka osakkaaksi Ingman ryhtyi. Vientiä Venäjälle ja Baltian maihin. Liettuassa on jäätelötehdas."@fi ;
    rdaa:P50407 "Ingman Foods"@fi ;
    rdau:P61101 "Komsi, Pauli. Omistamisen taito : perheyritykset kansakunnan rakentajina / Pauli Komsi, Jan Lindström, Seppo Zetterberg, 2002"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Ingman Foods"@fi .

