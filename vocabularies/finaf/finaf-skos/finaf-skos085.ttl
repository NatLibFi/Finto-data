finaf:000028073 a rdac:C10005,
        skos:Concept ;
    dct:created "2007-05-24"^^xsd:date ;
    dct:modified "2022-09-01T19:03:18"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000105752883>,
        "Asteri ID: 000028073" ;
    rdaa:P50022 yso:p13876,
        yso:p2625,
        yso:p37992 ;
    rdaa:P50035 "Helsingin venäläinen teatteri perustettiin 1868. Vuosina 1868-1875 teatteri toimi Arkadiateatterissa (avajaisesitys 29.10.1868). Jatkossa teatterin toiminta siirtyi Aleksanterin teatteriin, jonka rakennus valmistui lokakuussa 1879. Maistraatin todistus rakennuksen tarkastuksesta on päivätty 13.11.1879. Helsingin uusi venäläinen teatteritalo nimettiin keisarin mukaan Aleksanterin teatteriksi (Aleksandrovski teatr) helmikuussa 1880 ja teatterin avajaiset pidettiin 30.3.1880. Helsingin venäläisen teatterin lakkautuksen jälkeen Aleksanterin teatteri siirtyi Suomalaisen oopperan käyttöön 1919."@fi ;
    rdaa:P50037 "1868" ;
    rdaa:P50038 "1918" ;
    rdaa:P50237 mts:m898 ;
    rdaa:P50336 finaf:000028075 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Helsingin venäläinen teatteri"@fi ;
    rdau:P61101 "<a href='http://www.aleksanterinteatteri.fi/historia'>Aleksanterin teatterin verkkosivut</a>, katsottu 15.3.2019"@fi,
        "Byckling, Liisa. Arkadiasta Aleksanterin teatteriin : Helsingin Venäläinen teatteri 1868 - 1918, 2006 t.p. (Helsingin venäläinen teatteri)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Helsingin venäläinen teatteri"@fi .

