finaf:000020098 a rdac:C10005,
        skos:Concept ;
    dct:created "2004-01-20"^^xsd:date ;
    dct:modified "2021-06-18T19:06:54"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000020098" ;
    rdaa:P50016 finaf:000020099 ;
    rdaa:P50022 yso:p7691 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50236 "1903/1922"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 "oppilaitos"@fi ;
    rdaa:P50350 yso:p100490 ;
    rdaa:P50393 "Metsänvartijakoulu perustettu 1903. - Seitsemän ensimmäistä vuosikymmentä metsänvartijakoulun, metsäkoulun ja metsäopiston toiminnasta vastasi metsähallitus. Vuonna 1973 Tuomarniemen metsäopisto siirtyi ammattikasvatushallituksen alaisuuteen ja sittemmin opetushallitukselle, jonka hallintoaikana ryhdyttiin käyttämään nimeä Tuomarniemen metsäoppilaitos. Vuodesta 1997 lähtien Tuomarniemen ylläpitäjänä on ollut Seinäjoen ammatillisen korkeakouluopetuksen kuntayhtymä, johon kuuluu 11 eteläpohjalaista kuntaa."@fi ;
    rdaa:P50407 "Tuomarniemen metsänvartijakoulu"@fi ;
    rdau:P61101 "Yhteisön kotisivu, (20.01.2004)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Tuomarniemen metsänvartijakoulu"@fi .

