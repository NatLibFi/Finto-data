        yso:p22463 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "The Boys"@fi ;
    rdaa:P50035 "The Boys -yhtyeen alkuperäiseen kokoonpanoon kuuluivat: kitaristi Jussi Raittinen, rumpali Eero Raittinen ja basisti Harry Sjöberg. Elokuun 1964 Itä-Saksan esiintymismatka edellytti kuitenkin nelihenkistä yhtyettä, joten kokoonpano täydentyi soolokitaristi Kaj Westerlundilla (lähde: Suomalaisen rockin tietosanakirja. A-L / Lehtonen)."@fi,
        "Yhtyeen keulahahmo on Jussi Raittinen ja yhtyeen kokoonpanoon on vuosien mittaan kuulunut monia merkittäviä suomalaisia muusikoita, kuten mm. Eero Raittinen, Jarkka Rissanen ja Antero Jakoila (lähde: Wikipedia)."@fi ;
    rdaa:P50037 "1964" ;
    rdaa:P50237 mts:m1100 ;
    rdaa:P50336 finaf:000020173 ;
    rdaa:P50350 yso:p94426 ;
    rdaa:P50407 "Boys"@fi ;
    rdau:P61101 "<a href='http://yle.fi/aihe/artikkeli/2008/09/11/eero-ja-jussi-boys-soittanut-beatmusaa-lapi-vuosikymmenten'>Yle. Elävä arkisto</a>, katsottu 14.3.2016"@fi,
        "Hatakka, Heimo: Muistan vielä vuonna -56 (2003)"@fi,
        "Suomalaisen rockin tietosanakirja. A-L / Lehtonen"@fi ;
    skos:altLabel "The Boys"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Boys"@fi .

