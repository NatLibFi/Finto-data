    rdaa:P50407 "Kouvolan jumppaseura"@fi ;
    rdau:P61101 "Omakuva, 2000: t.p. (Kouvolan naisvoimistelijat)"@fi,
        "Seuran kotisivu (5.6.2007)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Kouvolan jumppaseura"@fi .

