    rdaa:P50104 mts:m2437,
        mts:m2441,
        mts:m2666 ;
    rdaa:P50109 yso:p176820 ;
    rdaa:P50113 "Alankomaalainen, Amsterdamissa (vuodesta 1728 alkaen) ja Leipzigissa (kirjojen myyntiä pääsiäismarkkinoilla) toiminut kirjanpainaja, kustantaja ja kirjakauppias. Vuosina 1728-1730 työskenteli yhdessä veljensä Cornelisin ja lankonsa Johannes Covensin kanssa. Kuoleman jälkeen hänen entinen alaisensa Johannes Schreuder julkaisi noin vuoteen 1762 asti nimellä \"Schreuder en Pieter Mortier de jonge\"."@fi ;
    rdaa:P50118 yso:p106815 ;
    rdaa:P50119 yso:p106815 ;
