    rdaa:P50025 "Sacrum (Sacrum-Kotimaa Oy)"@fi,
        "Sacrum Oy"@fi ;
    rdaa:P50035 "Sacrum-Kotimaa Oy toimii ulospäin kahtena brändinä, Sacrumina ja Kotimaana. Sacrum on erikoistunut kristillisiin kirjoihin ja kirkollisiin tarvikkeisiin. Kotimaa on mediayksikkö, joka tekee Kotimaa-lehteä ja sen verkkosivustoa Kotimaa.fi sekä Askel-lehteä. Sacrum-Kotimaa Oy syntyi, kun Sacrum Oy osti Kotimaa Oy:n liiketoiminnan. Uusi osakeyhtiö aloitti vuoden 2022 alussa. Sacrum-Kotimaa on kokonaan Kirkkopalvelut ry:n omistama."@fi ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Sacrum (yhtiö)"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Sacrum-Kotimaa'>Wikipedia</a>, katsottu 21.8.2024"@fi,
        "<a href='https://sacrum.fi/'>Yhteisön verkkosivut</a>, katsottu 21.8.2024"@fi,
        "<a href='https://www.kirkkopalvelut.fi/viestinta/'>Kirkkopalvelut ry:n verkkosivut</a>, katsottu 21.8.2024"@fi,
        "Oman uskon ystäväkirja, 2023"@fi ;
    skos:altLabel "Sacrum (Sacrum-Kotimaa Oy)"@fi,
        "Sacrum Oy"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Sacrum (yhtiö)"@fi .

