finaf:000000423 a rdac:C10005,
        skos:Concept ;
    dct:created "1998-12-16"^^xsd:date ;
    dct:modified "2020-11-04T20:00:52"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000000423" ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50393 "Kesällä 1958 aloitti Insinööritoimisto Ensio Miettinen toimintansa. 1970-luvun alussa yhtiö muuttui osakeyhtiöksi ja nimi muutettin Oy Ensio Miettinen Ab:ksi. 1973 perustettiin ensimmäinen tytäryhtiö Ruotsiin, 1972 perustettiin Mikkelin sähkökeskuksia vamistava tehdas ja uusi tehdashalli Porvooseen. 1980-liku oli kansainvälistymisen aikaa. Vuosituhannen vaihteessa toteutettiin sukupolven vaihdos, jolloin Ensto jakoi toimintansa neljään liiketoiminnan alueeseen: Ensto tietotekniikka, Ensto Verkonrakennus, Ensto Kotelot ja komponentit, Ensto Teollisuus. Konsernin omistaja Ensto Capital Oy omistaa Enston ohella Mattio Oy:n ja Opa Oy:n"@fi ;
    rdaa:P50407 "Ensto (yhtiö)"@fi ;
    rdau:P61101 "Omistamisen taito : perheyritykset kansakunnan rakentajina / Pauli Komsi, Jan Lindström, Seppo Zetterberg, 2002"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Ensto (yhtiö)"@fi .

