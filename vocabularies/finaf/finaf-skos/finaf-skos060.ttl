rdaa:P50001 a rdf:Property ;
    rdfs:label "is respondent of"@en,
        "väitöskirja"@fi ;
    rdakit:hasElementType "2" ;
    rdakit:instructionNumber "18.5" ;
    rdakit:toolkitDefinition "A thesis provided by the praeses in an academic disputation that is defended or opposed by a candidate for a degree."@en,
        "Väitöskirja, jonka preeses esittelee akateemisessa väitöstilaisuudessa, ja jota oppiarvoa tavoiteleva kandidaatti puolustaa tai opponoi."@fi ;
    rdakit:toolkitLabel "respondent of"@en,
        "väitöskirja"@fi ;
    reg:hasSubproperty <http://rdaregistry.info/Elements/a/datatype/P50001>,
        <http://rdaregistry.info/Elements/a/object/P50001> ;
    reg:hasUnconstrained rdau:P60001 ;
    reg:lexicalAlias rdaa:respondentOf.en,
        rdaa:vaitoskirja.fi ;
    reg:name "respondentOf"@en,
        "vaitoskirja"@fi ;
    reg:status <http://metadataregistry.org/uri/RegStatus/1001> ;
    rdfs:domain rdac:C10004 ;
    rdfs:isDefinedBy rdaa: ;
    rdfs:subPropertyOf rdaa:P50542 ;
    skos:definition "Relates a person to a thesis provided by the praeses in an academic disputation that is defended or opposed by a candidate for a degree."@en,
        "Liittää oppiarvoa tavoittelevan, puolustavan tai opponoivan kandidaatin väitöskirjaan, jonka preeses esittelee akateemisessa väitöstilaisuudessa."@fi .

rdaa:P50002 a rdf:Property ;
    rdfs:label "is appellee corporate body of"@en,
        "yhteisöön kohdistuva muutoshakemus"@fi ;
    rdakit:hasElementType "2" ;
    rdakit:instructionNumber "18.5" ;
    rdakit:toolkitDefinition "A legal work of a higher court that records a decision of a lower court that appeals against a corporate body."@en,
        "Hakemus, jolla haetaan muutosta alemman oikeusasteen päätökseen ja joka kohdistuu yhteisöön."@fi ;
    rdakit:toolkitLabel "appellee corporate body of"@en,
        "yhteisöön kohdistuva muutoshakemus"@fi ;
    reg:hasSubproperty <http://rdaregistry.info/Elements/a/datatype/P50002>,
        <http://rdaregistry.info/Elements/a/object/P50002> ;
    reg:hasUnconstrained rdau:P60601 ;
    reg:lexicalAlias rdaa:appelleeCorporateBodyOf.en,
        rdaa:yhteisoonKohdistuvaMuutoshakemus.fi ;
    reg:name "appelleeCorporateBodyOf"@en,
        "yhteisoonKohdistuvaMuutoshakemus"@fi ;
    reg:status <http://metadataregistry.org/uri/RegStatus/1001> ;
    rdfs:domain rdac:C10005 ;
    rdfs:isDefinedBy rdaa: ;
    rdfs:subPropertyOf rdaa:P50844 ;
    skos:definition "Relates a corporate body to a legal work of a higher court that records a decision of a lower court that appeals against a corporate body."@en,
        "Liittää muutoshakemuksen kohteena olevan yhteisön hakemukseen, jolla haetaan muutosta alemman oikeusasteen päätökseen."@fi .

rdaa:P50003 a rdf:Property ;
    rdfs:label "is degree granting institution of"@en,
        "yhteisön myöntämä oppiarvo"@fi ;
    rdakit:hasElementType "2" ;
    rdakit:instructionNumber "18.5" ;
    rdakit:toolkitDefinition "A work that is a thesis associated with an academic degree that is approved by a corporate body."@en,
        "Yhteisölle myönnetty akateeminen oppiarvo."@fi ;
    rdakit:toolkitLabel "degree granting institution of"@en,
        "yhteisön myöntämä oppiarvo"@fi ;
    reg:hasSubproperty <http://rdaregistry.info/Elements/a/datatype/P50003>,
        <http://rdaregistry.info/Elements/a/object/P50003> ;
    reg:hasUnconstrained rdau:P60002 ;
    reg:lexicalAlias rdaa:degreeGrantingInstitutionOf.en,
        rdaa:yhteisonMyontamaOppiarvo.fi ;
    reg:name "degreeGrantingInstitutionOf"@en,
        "yhteisonMyontamaOppiarvo"@fi ;
    reg:status <http://metadataregistry.org/uri/RegStatus/1001> ;
    rdfs:domain rdac:C10005 ;
    rdfs:isDefinedBy rdaa: ;
    rdfs:subPropertyOf rdaa:P50844 ;
    skos:definition "Relates a corporate body to a work that is a thesis associated with an academic degree that is approved by a corporate body."@en,
        "Liittää akateemisen oppiarvon myöntävän yhteisön teokseen."@fi .

rdaa:P50004 a rdf:Property ;
    rdfs:label "is hosting institution of"@en,
        "isäntäorganisaationa tapahtumassa"@fi ;
    rdakit:hasElementType "2" ;
    rdakit:instructionNumber "18.5" ;
    rdakit:toolkitDefinition "A work that arises from a conference, exhibition, or other event that is hosted by a corporate body with little or no responsibility for the content."@en,
        "Yhteisön isännöimä tapahtuma, näyttely, konferenssi tms., jonka johdosta syntyneen teoksen sisällöstä yhteisöllä on vähän tai ei lainkaan vastuuta."@fi ;
    rdakit:toolkitLabel "hosting institution of"@en,
        "isäntäorganisaationa tapahtumassa"@fi ;
    reg:hasSubproperty <http://rdaregistry.info/Elements/a/datatype/P50004>,
        <http://rdaregistry.info/Elements/a/object/P50004> ;
    reg:hasUnconstrained rdau:P60003 ;
    reg:lexicalAlias rdaa:hostingInstitutionOf.en,
        rdaa:isantaorganisaationaTapahtumassa.fi ;
    reg:name "hostingInstitutionOf"@en,
        "isantaorganisaationaTapahtumassa"@fi ;
    reg:status <http://metadataregistry.org/uri/RegStatus/1001> ;
    rdfs:domain rdac:C10005 ;
    rdfs:isDefinedBy rdaa: ;
    rdfs:subPropertyOf rdaa:P50329 ;
    skos:altLabel "host institution of"@en ;
    skos:definition "Relates a corporate body to a work that arises from a conference, exhibition, or other event that is hosted by a corporate body with little or no responsibility for the content."@en,
        "Liittää yhteisön teokseen, johon sisältyy tapahtuman, näyttelyn, konferenssin tms. isännöintiä, ja jonka johdosta teos on syntynyt."@fi .

rdaa:P50005 a rdf:Property ;
    rdfs:label "is production company of"@en,
        "tuotantoyhtiönä teoksessa"@fi ;
    rdakit:hasElementType "2" ;
    rdakit:instructionNumber "18.5" ;
    rdakit:toolkitDefinition "A work that involves a responsibility for managing the financial, technical, and organizational aspects of a production for stage, screen, sound recording, television, webcast, etc."@en,
        "Teos, joka sisältää näyttämöteoksen, elokuvan, äänitallenteen, televisio-ohjelman, suoratoistolähetyksen tms. tuotannon taloudellisen, teknisen ja organisatorisen johtamisen."@fi ;
    rdakit:toolkitLabel "production company of"@en,
        "tuotantoyhtiönä teoksessa"@fi ;
    reg:hasSubproperty <http://rdaregistry.info/Elements/a/datatype/P50005>,
        <http://rdaregistry.info/Elements/a/object/P50005> ;
    reg:hasUnconstrained rdau:P60004 ;
    reg:lexicalAlias rdaa:productionCompanyOf.en,
        rdaa:tuotantoyhtionaTeoksessa.fi ;
    reg:name "productionCompanyOf"@en,
        "tuotantoyhtionaTeoksessa"@fi ;
    reg:status <http://metadataregistry.org/uri/RegStatus/1001> ;
    rdfs:domain rdac:C10005 ;
    rdfs:isDefinedBy rdaa: ;
    rdfs:subPropertyOf rdaa:P50844 ;
    skos:definition "Relates a corporate body to a work that involves a responsibility for managing the financial, technical, and organizational aspects of a production for stage, screen, sound recording, television, webcast, etc."@en,
        "Liittää yhteisön teokseen, joka sisältää näyttämöteoksen, elokuvan, äänitallenteen, televisio-ohjelman, suoratoistolähetyksen tms. tuotannon taloudellisen, teknisen ja organisatorisen johtamisen."@fi .

rdaa:P50006 a rdf:Property ;
    rdfs:label "has identifier for corporate body"@en,
        "yhteisön tunniste"@fi,
        "servoša dovddaldat"@se,
        "har identifikator för institutionen"@sv ;
    rdakit:hasElementType "3" ;
    rdakit:instructionNumber "11.12" ;
    rdakit:toolkitDefinition "An appellation of corporate body that consists of a code, number, or other string, usually independent of natural language and social naming conventions, used to identify a corporate body."@en,
        "Merkkijono, joka yhdistetään yksinomaan yhteisöön tai esimerkiksi yhteisöä edustavaan auktoriteettitietueeseen."@fi ;
    rdakit:toolkitLabel "identifier for corporate body"@en,
        "yhteisön tunniste"@fi,
        "identifikator för institutionen"@sv ;
    reg:hasSubproperty <http://rdaregistry.info/Elements/a/datatype/P50006>,
        <http://rdaregistry.info/Elements/a/object/P50006> ;
    reg:hasUnconstrained rdau:P60053 ;
    reg:lexicalAlias rdaa:identifierForCorporateBody.en,
        rdaa:yhteisonTunniste.fi ;
    reg:name "identifierForCorporateBody"@en,
        "yhteisonTunniste"@fi ;
    reg:status <http://metadataregistry.org/uri/RegStatus/1001> ;
    rdfs:domain rdac:C10005 ;
    rdfs:isDefinedBy rdaa: ;
    rdfs:subPropertyOf rdaa:P50380,
        rdaa:P50384 ;
    skos:definition "Relates a corporate body to an appellation of corporate body that consists of a code, number, or other string, usually independent of natural language and social naming conventions, used to identify a corporate body."@en,
        "Liittää yhteisön merkkijonoon, joka yhdistetään yksinomaan yhteisöön tai esimerkiksi yhteisöä edustavaan auktoriteettitietueeseen."@fi ;
    skos:scopeNote "Tunniste erottaa yhteisön muista yhteisöistä."@fi .

