finaf:000000282 a rdac:C10005,
        skos:Concept ;
    dct:created "1993-07-14"^^xsd:date ;
    dct:modified "2022-09-01T19:00:11"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/000000047436566X>,
        "Asteri ID: 000000282",
        "Y-tunnus: 0107011-5" ;
    rdaa:P50022 yso:p18704 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50035 "Yrityksen historia juontaa juurensa Sören Berneriin, joka tuli Norjasta ensi kerran Helsinkiin vuonna 1881 ja sittemmin perusti tuontikauppaa harjoittavan yrityksen. Aluksi tuotiin silliä, v. 1885 lähtien kuivattua turskaa, 1890-luvulla agentuuritoiminta laajeni viljatiuotteisiin, marsipaaniin, lakritsiin, rusinoihin ja säilykkeihin, sokeriin, kahviin ja typpilannotteihin. Brasilian tuonnin myötä yritys oli kahvintuonnin uranuurtaja. Vientikauppa kehittyi vähitelleen. Aluksi vietiin mm. rapuja Saksaan. 1920-luvulla vientikauppa laajeni kun paperia vietiin mm. Egyptiin ja Kreikkaan. Toiminimi Sören Berner & Co. merkittiin avoimena yhtiönä kaupparekisteriin. Vuonna 1941 se muutettiin osakeyhtiöksi. 1950-luvun alussa perustettiin Helsingin Herttoniemeen kasvinsuojeluaineita ja teknokemian tuotteita valmistava tehdas. 1954 liiketoiminta laajennettiin autoihin, auto-osastosta luovuttiin 1975. 1990-luvulla ostettiin Alkon Rajamäen tehtaat, Askolan urheiluvälinetehdas, Sareko Agron kasvinsuojeluliiketoiminta, Bergenheim Oy:n liiketoimi ja 2001 Heinävedeltä teknokemian tehdas. 2002 alussa tytäryhtiö Karl Beus ja Bernerin Medical-ryhmä yhdistyivät Terveys- ja tutkimus -osastoiksi"@fi ;
    rdaa:P50037 "1883" ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Berner (yhtiö)"@fi ;
    rdau:P61101 "<a href='https://www.berner.fi/'>Verkkosivut 23.4.2018</a>"@fi,
        "Komsi, Pauli. Omistamisen taito : perheyritykset kansakunnan rakentajina / Pauli Komsi, Jan Lindström, Seppo Zetterberg, 2002"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Berner (yhtiö)"@fi .

