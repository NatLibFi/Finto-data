    rdaa:P50025 "Finlands gymnastik- och idrottsförbund"@fi,
        "SVUL (Suomen voimistelu- ja urheiluliitto)"@fi,
        "Suomalainen voimistelu ja urheiluliitto"@fi ;
    rdaa:P50035 "Valtakunnallinen urheiluseurojen keskusjärjestö. Suomalainen voimistelu ja urheiluliitto perustettiin 17.6.1900, mutta sai virallisen persutamisluvan vasta 11.3.1906, jolloin otettiin käyttöön nimenmuoto Suomen voimistelu- ja urheiluliitto, SVUL. Nimenmuutos vuonna 1961, jolloin SVUL-lyhenteen merkitys muuttui Suomen Valtakunnan Urheiluliitoksi. Toiminta loppui vuonna 1994."@fi ;
    rdaa:P50037 "1900" ;
    rdaa:P50038 "1961" ;
    rdaa:P50237 mts:m401 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Suomen voimistelu- ja urheiluliitto"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Suomen_Valtakunnan_Urheiluliitto'>Wikipedia</a>, katsottu 18.10.2018"@fi,
        "Arponen, Antti O. 100 vuotta Karjalan urheilua : SVUL:n Viipurin (Etelä-Karjalan) piiri 1906-2006, (2006)"@fi ;
    skos:altLabel "Finlands gymnastik- och idrottsförbund"@fi,
