finaf:000025460 a rdac:C10005,
        skos:Concept ;
    dct:created "2007-10-02"^^xsd:date ;
    dct:modified "2021-06-18T19:08:11"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000025460" ;
    rdaa:P50012 finaf:000025461,
        finaf:000025462 ;
    rdaa:P50237 "oppilaitos"@fi ;
    rdaa:P50393 "Malmin kauppaopisto aloitti toimintansa 1.9.1957. Oppilaitoksen historia alkaa jo 1945, jolloin Malmin seudun yrittäjät ja liikemiehet perustivat Tehtaitten koulu -nimisen osakeyhtiön. Osakeyhtiö perusti Malmin kaupallisen keskikoulun, jossa yleissivistävään opetukseen yhdistettiin ammatillisia aineita. Keskikoulua kutsuttiin myös Tehtaitten kouluksi. Malmin kauppaopistosta tuli Malmin kauppaoppilaitos 1978. Vuodesta 2005 nimi on ollut Liiketalousopisto Helsinki-Malmi."@fi ;
    rdaa:P50407 "Liiketalousopisto Helsinki-Malmi"@fi ;
    rdau:P61101 "Kortetjärvi-Nurmi, Sirkka. Tehtaitten koulusta se alkoi, 2007: t.p. (Tehtaitten koulusta se alkoi kauppaopetusta Malmilla 50 vuotta Sirkka Kortetjärvi-Nurmi Helsinki Malmin kauppaoppilaitos)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Liiketalousopisto Helsinki-Malmi"@fi .

