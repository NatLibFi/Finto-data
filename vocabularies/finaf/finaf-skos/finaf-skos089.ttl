finaf:000025275 a rdac:C10005,
        skos:Concept ;
    dct:created "2012-01-02"^^xsd:date ;
    dct:modified "2021-06-18T19:08:06"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000025275" ;
    rdaa:P50016 finaf:000021775 ;
    rdaa:P50022 yso:p84 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "Kruunuhaan lukio"@fi ;
    rdaa:P50035 "Valtion omistama koulu perustettiin 1900-luvun alkupuolella tyttökouluksi ja vuodesta 1927 koulu tunnettiin nimellä Helsingin tyttölukio. 1970-luvulla koulutusjärjestelmää muutettiin ja tyttö- ja poikakoulujen aika päättyi. Helsingin tyttölukio ja niin ikään Kruununhaassa sijainnut Helsingin tyttökoulu muuttivat samaan rakennukseen Helsingin Liisankadulle. Yhdistetyt koulut saivat nimekseen Kruununhaan yhteislyseo. Koulun nimi muuttui Sibelius-lukioksi vuonna 1982 (lähde: Helsingin kaupunki. Sibelius-lukio)."@fi ;
    rdaa:P50229 finaf:000025274 ;
    rdaa:P50236 "1977/1982"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 "lukio"@fi ;
    rdaa:P50350 yso:p94137 ;
