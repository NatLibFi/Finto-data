    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50035 "Koiton Näyttämö (Koiton näytelmäseura 1906-1926) oli vuosina 1906–1933 toiminut helsinkiläinen teatteri. Vuonna 1933 Koiton näyttämö yhdistyi Kansan näyttämön kanssa Helsingin kansanteatteriksi, joka puolestaan solmi vuonna 1948 yhteistyösopimuksen Helsingin työväenteatterin kanssa. Lopulta vuonna 1965 ne yhdistyivät Helsingin Kaupunginteatteriksi."@fi ;
    rdaa:P50236 "1926/1933"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m898 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Koiton näyttämö"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Koiton_N%C3%A4ytt%C3%A4m%C3%B6'>Wikipedia</a>, katsottu 18.2.2020"@fi,
