        skos:Concept ;
    dct:created "1993-12-08"^^xsd:date ;
    dct:modified "2021-06-18T19:01:55"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000005874" ;
    rdaa:P50012 finaf:000016012 ;
    rdaa:P50016 finaf:000005873 ;
    rdaa:P50025 "Turun yliopisto. Humanistinen tiedekunta. Suomen kielen laitos"@fi,
        "Turun yliopiston suomen kielen laitos"@fi ;
    rdaa:P50237 "tiedekunta"@fi ;
    rdaa:P50393 "Turun yliopiston Suomen kielen ja fonetiikan laitos perustettiin 1955. Vuonna 1958 laitos jakaantui Suomen kielen laitokseksi ja Fonetiikan laitokseksi ja näiden rinnalle muodostettiin Suomalais-ugrilaisen kielentutkimuksen laitos 1965. Hallinnonuudistuksen myötä 1974 suomen kieli, suomalais-ugrilainen kielentutkimus, fonetiikka, puheoppi, yleinen kielitiede yhdistettiin Suomalaisen ja yleisen kielitieteen laitoksen alaisuuteen"@fi ;
    rdaa:P50407 "Turun yliopisto. Suomen kielen laitos"@fi ;
    skos:altLabel "Turun yliopisto. Humanistinen tiedekunta. Suomen kielen laitos"@fi,
        "Turun yliopiston suomen kielen laitos"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Turun yliopisto. Suomen kielen laitos"@fi .

