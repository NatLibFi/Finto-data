finaf:000017155 a rdac:C10005,
        skos:Concept ;
    dct:created "2001-03-21"^^xsd:date ;
    dct:modified "2021-06-18T19:06:02"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000017155" ;
    rdaa:P50012 finaf:000017154 ;
    rdaa:P50016 finaf:000004109 ;
    rdaa:P50237 "hoitolaitos"@fi,
        "parantola"@fi ;
    rdaa:P50393 "Satakuntalainen osakunta perusti Satakunnan keuhkotautiparantola osakeyhtiön (yhtiöjärjestys 16.6.1914) ja rakennutti sairaalan Harjavaltaan (avajaiset pidettiin 28.2.1925). - Osakunta möi joulukuussa 1949 Satakunnan parantolan Satakunnan tuberkuloosipiirin kuntainliitolle keskusparantolaksi (1950-1971). Virallisesti parantolan nimi muutettiin Satalinnan sairaalaksi 1970. - Sairaala siirtyi Satakunnan keskussairaalan kuntainliiton omistukseen vuoden 1972 alusta ja vuonna 1991 sairaalan omistajaksi ja ylläpitäjäksi tuli Satakunnan sairaanhoitopiirin kuntainliitto ja vuonna 1993 kuntayhtymä . - Kun keuhkosairauksien hoito siirrettiin Satakunnan keskussairaalaan Satalinnaa kehitetään monipuolisena kuntoutuskeskuksena"@fi ;
    rdaa:P50407 "Satakunnan parantola"@fi ;
    rdau:P61101 "Väänänen, Kyösti: Satalinna 1925-2000. - Harjavalta, 2000"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Satakunnan parantola"@fi .

