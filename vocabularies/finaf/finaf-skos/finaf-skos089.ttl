finaf:000018239 a rdac:C10005,
        skos:Concept ;
    dct:created "2002-04-04"^^xsd:date ;
    dct:modified "2021-06-18T19:06:23"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000018239" ;
    rdaa:P50012 finaf:000018240 ;
    rdaa:P50016 finaf:000006435 ;
    rdaa:P50237 "koulu"@fi,
        "lyseo"@fi ;
    rdaa:P50393 "Jyväskylän suomalainen tyttökoulu (yksityinen) 1864-1886, (valtion) 1886-1952. - Jyväskylän tyttölyseo 1952-1973. - Koulu tuli täysiluokkaiseksi tyttölyseoksi 1952, kun siihen liitettiin Jyväskylän tyttölukio (alkuaan Jyväskylän Suomalaiset Jatkoluokat), joka oli aloittanut toimintansa yksityiskouluna 1911. - Koulu muodostettiin kaksoislyseoksi 1.9.1963. - Voionmaan koulu 1973 lähtien (jolloin siiryttiin peruskouluun), koulussa toimii yläaste ja lukio sekä 1976-1983 'Vehkalammen ala-aste."@fi ;
    rdaa:P50407 "Jyväskylän tyttölyseo"@fi ;
    rdau:P61101 "Jyväskylän tyttölyseon ja Voionmaan koulun vaiheita : kuvia ja tarinoita menneiltä vuosikymmeniltä (1864-2001) / [toimituskunta: Eila Elomaa ... et al.]. - Jyväskylä, 2001"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Jyväskylän tyttölyseo"@fi .

