    rdaa:P50025 "Arbetararkivet"@fi,
        "Finnish Labour Archives"@fi ;
    rdaa:P50237 "arkisto"@fi ;
    rdaa:P50393 "Työväen Arkisto on maan vanhin kansanliikearkisto. Se perustettiin Suomen Sosialidemokraattisen Puolueen Kotkan puoluekokokouksessa vuonna 1909 poliittisen ja ammatillisen työväenliikkeen keskusarkistoksi. Arkistossa on vapaasti tutkittavana tuhansien työväenliikkeen organisaatioiden aineistot ja satojen yksityishenkilöiden arkistot. Lisäksi arkistolla on laajat kokoelmat julisteita ja valokuvia"@fi ;
    rdaa:P50407 "Työväen arkisto"@fi ;
    rdau:P61101 "Arkiston kotisivut 24.1.08"@fi,
        "Työväentutkimus, 1987-"@fi ;
    skos:altLabel "Arbetararkivet"@fi,
        "Finnish Labour Archives"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Työväen arkisto"@fi .

