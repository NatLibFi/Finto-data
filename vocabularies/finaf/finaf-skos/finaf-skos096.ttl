finaf:000202005 a rdac:C10005,
        skos:Concept ;
    dct:created "2018-11-21"^^xsd:date ;
    dct:modified "2022-09-07T19:07:33"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000492970011>,
        "Asteri ID: 000202005" ;
    rdaa:P50022 yso:p1801 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/eng>,
        <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "Aalto-yliopiston ylioppilaskunta. Prosessiteekkarit"@fi ;
    rdaa:P50035 "Prosessiteekkarit ry on vuonna 2012 perustettu korkeakouluyhdistys, joka syntyi Kemian tekniikan korkeakouluun kandidaattiuudistuksen myötä. Yhdistys on vielä nuori, mutta vuoden 2013 syyskuussa lähti toiminta ensimmäisten fuksien saavuttua pyörimään täyspäiväisesti. Yhdistys ottaa vastaan kemian-, bio- ja materiaalitekniikan koulutusohjelmassa aloittavat opiskelijat. Olemme voittoa tavoittelematon Aalto-yliopiston ylioppilaskunnan erityisaseman yhdistys ja tehtävänämme on yhdistää Kemian tekniikan korkeakoulun opiskelijoita, edistää jäseniemme yhteiskunnallisia, henkisiä ja sosiaalisia sekä opiskeluun ja opiskelijan asemaan korkeakoulussa liittyviä pyrkimyksiä"@fi ;
    rdaa:P50037 "2013" ;
    rdaa:P50237 "yhdistys"@fi ;
    rdaa:P50350 yso:p94105 ;
    rdaa:P50407 "Prosessiteekkarit (yhdistys)"@fi ;
    rdau:P61101 "<a href='https://www.ayy.fi/fi/yhdistyslistaus/erityisaseman-yhdistykset'>Aalto-yliopiston ylioppilaskunnan verkkosivut</a>, katsottu 13.9.2019"@fi ;
    skos:altLabel "Aalto-yliopiston ylioppilaskunta. Prosessiteekkarit"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Prosessiteekkarit (yhdistys)"@fi .

