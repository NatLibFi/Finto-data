finaf:000202608 a rdac:C10004,
        skos:Concept ;
    dct:created "1994-11-13"^^xsd:date ;
    dct:modified "2022-09-07T19:08:24"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/000000048428488X>,
        "Asteri ID: 000202608" ;
    rdaa:P50100 yso:p8500 ;
    rdaa:P50103 "Kangaji, Jaakko, 1945-2000"@fi ;
    rdaa:P50104 mts:m2413,
        mts:m2519,
        mts:m2589 ;
    rdaa:P50109 "Nkurenkuru, Namibia"@fi ;
    rdaa:P50120 "2000" ;
    rdaa:P50121 "1945" ;
    rdaa:P50291 "Kangayi" ;
    rdaa:P50292 "Jaakko" ;
    rdaa:P50411 "Kangayi, Jaakko, 1945-2000"@fi ;
    rdau:P61101 "<a href='http://www.kavango.info/Siteketa.htm'>Kavango-Info-verkkosivusto</a> (Severinus Siteketa is one of the recipients of a heroes' medal which were handed out during the inauguration of Heroes' Acre in Windhoek on 26th of August 2002. Together with Jaakko Kangayi (1945 – 2000) and Jona Hamukwaya (1949 – 1982), Siteketa is among the three persons from the Kavango to whom this honour is shown. As the only living person among the three he was honoured for his resistance against the effects of the Apartheid state and \"… to ensure that justice is done to all our deserving national heroes and heroines)"@fi,
        "<a href='https://www.lelamobile.com/content/76620/It-Was-In-My-Blood-Not-To-Waver-Siteketa/'>It Was In My Blood Not To Waver: Siteketa / Petrus Muronga, 25.8.2018</a> (At Bethanie he was kept in cells with 12 to 15 other freedom fighters from across Namibia, including the late composer of the Evangelical Lutheran Church in Namibia, Jaakko Kangayi.)"@fi,
        "Re-Viewing Resistance in Namibian History / edited by Jeremy Silvester (Among them were Severinus Siteketa, a prominent businessmen, the late Jaakko Kangayi, the principal of Nkurenkuru combined school, Jonas Hamukwaya, a teacher at Namutuntu who died after being interrogated and tortured by Koevoet forces, and a number of civilians who owned vehicles)"@fi ;
    skos:altLabel "Kangaji, Jaakko, 1945-2000"@fi ;
    skos:hiddenLabel "Jaakko Kangaji"@fi,
        "Jaakko Kangayi"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Kangayi, Jaakko, 1945-2000"@fi .

