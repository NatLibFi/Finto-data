    rdaa:P50121 "1947" ;
    rdaa:P50291 "Korppi" ;
    rdaa:P50292 "Timo" ;
    rdaa:P50411 "Korppi, Timo, 1947-"@fi ;
    rdau:P61101 "<a href='https://naytelmat.fi/writer/ant-46'>Näytelmät.fi</a>, katsottu 14.4.2025 (Timo Korppi: Timo Korppi 28.3.1947 -. Kirjoitin YLE:lle yhden näytelmän ja jatkokuunnelman varsin kauan sitten, mutta varsinainen kirjoittajakarriääri on ollut paitsi proosan kääntäjänä ja kirjailijana (useille kustantajille), myös kolmen vuosikymmenen mittainen ura päätoimittajana ja julkaisujohtajana amerikkalais-kansainvälisessä mediamailmassa. Pohjana oli toki uutistoimittajan työ mm. STT:ssä ja sen pohjoismaisissa sisartoimistoissa Tukholmassa, Oslossa ja Kööpenhaminassa.)"@fi,
        "Kirjasampo, katsottu 14.4.2025"@fi,
        "Lihaa säästämättä : 30 vuotta suomalaisen pornobisneksen etulinjassa, 2002"@fi ;
    skos:hiddenLabel "Timo Korppi"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Korppi, Timo, 1947-"@fi .

