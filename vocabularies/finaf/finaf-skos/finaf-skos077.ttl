finaf:000162613 a rdac:C10004,
        skos:Concept ;
    dct:created "2016-04-13"^^xsd:date ;
    dct:modified "2023-04-20T12:30:26"^^xsd:dateTime ;
    rdaa:P50094 "Asteri ID: 000162613" ;
    rdaa:P50103 "Törngren, A., 1824-1895"@fi ;
    rdaa:P50113 "Turun hovioikeuden ylimääräinen notaari 1845. Varatuomari 1848. Tehtailija ja liikemies Tampereella ja Helsingissä. Perusti Tampereelle yhdessä Gust. Aug. Wasastjernan kanssa pellavatehtaan ja konepajan 1856 sekä muodosti niistä 1861 Tampereen Pellava- ja Rauta-Teollisuus Oy:n, sen johtokunnan puheenjohtaja 1861-1866. Rahoitti Jokioisten verkatehtaan siirron Tampereelle 1858, verkatehdas teki sittemmin varakon. Rakensi Helsinkiin Hietalahden kuivatelakan ja konepajan 1864, vararikko. Liikemies Helsingissä 1867. Mukana perustamassa Tampereelle Asfaltti ja Kattohuopa Oy:tä 1877, sen toimitusjohtaja ja osakas 1880-luvun puoliväliin. Omisti Vesilahden Laukon, Pirkkalan Nokian, Urjalan Nuutajärven ja vaimonsa kautta Pirkkalan Haapaniemen, asuen viimeksi siellä keksintöjä harrastaen. Valtiopäivämies 1863-1864."@fi ;
    rdaa:P50118 yso:p94436 ;
    rdaa:P50119 yso:p94447 ;
    rdaa:P50120 "1895" ;
    rdaa:P50121 "1824" ;
    rdaa:P50291 "Törngren" ;
    rdaa:P50292 "Adolf" ;
    rdaa:P50411 "Törngren, Adolf, 1824-1895"@fi ;
    rdau:P61101 "Förteckning öfver vicehäradshöfdingen A. Törngrens konkursmassa tillhöriga böcker, som skola å auktionskammaren i Helsingfors försäljas den [ ] Februari 1868"@fi,
        "Kotivuori, Yrjö. Ylioppilasmatrikkeli 1640-1852"@fi ;
