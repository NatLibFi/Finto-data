finaf:000028075 a rdac:C10005,
        skos:Concept ;
    dct:created "2002-03-25"^^xsd:date ;
    dct:modified "2022-04-13T16:04:24"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000028075" ;
    rdaa:P50025 "Aleksandrovski teatr"@fi,
        "Helsingin kaupungin kulttuuriasiainkeskus. Aleksanterin teatteri"@fi,
        "Helsingin kaupunki. Kulttuuriasiainkeskus. Aleksanterin teatteri"@fi ;
    rdaa:P50035 "Helsingin venäläinen teatteri perustettiin 1868. Vuosina 1868-1875 teatteri toimi Arkadiateatterissa (avajaisesitys 29.10.1868). Jatkossa teatterin toiminta siirtyi Aleksanterin teatteriin, jonka rakennus valmistui lokakuussa 1879. Maistraatin todistus rakennuksen tarkastuksesta on päivätty 13.11.1879. Helsingin uusi venäläinen teatteritalo nimettiin keisarin mukaan Aleksanterin teatteriksi (Aleksandrovski teatr) helmikuussa 1880 ja teatterin avajaiset pidettiin 30.3.1880. Helsingin venäläisen teatterin lakkautuksen jälkeen 1918 Aleksanterin teatteri siirtyi Suomalaisen oopperan käyttöön 1919."@fi ;
    rdaa:P50037 "1879" ;
    rdaa:P50237 mts:m898 ;
    rdaa:P50336 finaf:000004561,
        finaf:000016431,
        finaf:000028073 ;
    rdaa:P50407 "Aleksanterin teatteri"@fi ;
    rdau:P61101 "Aleksanterin teatteri 120 vuotta / Liisa Byckling. - Helsinki, 2000"@fi ;
    skos:altLabel "Aleksandrovski teatr"@fi,
        "Helsingin kaupungin kulttuuriasiainkeskus. Aleksanterin teatteri"@fi,
        "Helsingin kaupunki. Kulttuuriasiainkeskus. Aleksanterin teatteri"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Aleksanterin teatteri"@fi .

