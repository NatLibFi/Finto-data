    rdaa:P50025 "School of Social Sciences"@fi,
        "YKK (Yhteiskunnallinen korkeakoulu)"@fi ;
    rdaa:P50035 "Yliopiston pohjana oleva korkeakoulu perustettiin Helsinkiin vuonna 1925 nimellä Kansalaiskorkeakoulu. Nimi muutettiin vuonna 1930 muotoon Yhteiskunnallinen korkeakoulu (YKK). Vuonna 1956 sovittiin laitoksen siirtämisestä Tampereelle, mikä toteutettiin vuonna 1960. Yhteiskunnallisen Korkeakoulun nimi muuttui vuonna 1966 Tampereen yliopistoksi."@fi ;
    rdaa:P50037 "1930" ;
    rdaa:P50038 "1966" ;
    rdaa:P50237 "korkeakoulu"@fi ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Yhteiskunnallinen korkeakoulu"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Tampereen_yliopisto_(1925%E2%80%932018)'>Wikipedia</a>, katsottu 28.3.2019"@fi ;
    skos:altLabel "School of Social Sciences"@fi,
        "YKK (Yhteiskunnallinen korkeakoulu)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Yhteiskunnallinen korkeakoulu"@fi .

