    rdaa:P50025 "AYY (Aalto-yliopiston ylioppilaskunta)"@fi,
        "Aalto University Student Union"@fi,
        "Aalto-universitetets studentkår"@fi ;
    rdaa:P50035 "Aalto-yliopiston ylioppilaskunta (AYY) aloitti virallisesti toimintansa 1. tammikuuta 2010, kun kolme pääkaupunkiseudun yliopistoa Helsingin kauppakorkeakoulu, Taideteollinen korkeakoulu ja Teknillinen korkeakoulu yhdistyivät Aalto-yliopistoksi. Kyseisten yliopistojen ylioppilaskunnat Helsingin kauppakorkeakoulun ylioppilaskunta KY, Taideteollisen korkeakoulun ylioppilaskunta TOKYO ja Teknillisen korkeakoulun ylioppilaskunta TKY yhdistyivät samalla hetkellä Aalto-yliopiston ylioppilaskunnaksi, jonka toiminta käynnistettiin syksyllä 2009 edeltäneiden ylioppilaskuntien rinnalla 1.8.2009 voimaan astuneen uuden yliopistolain voimaanpanolain nojalla. (Wikipedia, katsottu 12.9.2019.)"@fi ;
    rdaa:P50037 "2010" ;
    rdaa:P50232 finaf:000028743,
        finaf:000028744,
        finaf:000032047 ;
    rdaa:P50237 "ylioppilaskunta"@fi ;
    rdaa:P50407 "Aalto-yliopiston ylioppilaskunta"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Aalto-yliopiston_ylioppilaskunta'>Wikipedia</a>, katsottu 12.9.2019 (historiatiedot)"@fi,
        "Ylioppilaskunnan kotisivut 25.5.10"@fi,
        "Ylioppilaslehti Aino, 2009-: t.p. (Ylioppilaslehti Aino / Helsingin kauppakorkeakoulun ylioppilaskunta (KY), Taideteollisen korkeakoulun ylioppilaskunta TOKYO, Teknillisen korkeakoulun ylioppilaskunta (TKY) Helsinki : Helsingin kauppakorkeakoulun ylioppilaskunta,)"@fi ;
    skos:altLabel "AYY (Aalto-yliopiston ylioppilaskunta)"@fi,
        "Aalto University Student Union"@fi,
        "Aalto-universitetets studentkår"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Aalto-yliopiston ylioppilaskunta"@fi .

