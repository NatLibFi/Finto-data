finaf:000018978 a rdac:C10005,
        skos:Concept ;
    dct:created "2003-02-14"^^xsd:date ;
    dct:modified "2023-02-06T10:56:25"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000492939567>,
        "Asteri ID: 000018978" ;
    rdaa:P50012 finaf:000018979,
        finaf:000018980,
        finaf:000018981 ;
    rdaa:P50237 "ammattilinen oppilaitos"@fi,
        "oppilaitos"@fi ;
    rdaa:P50393 "Ensimmäinen aloite Rovaniemen hotelli- ja ravintolakoulun perustamisesta tehtiin 1964 .- Rovaniemen hotelli- ja ravintolakoulun toiminta käynnistettiin 1971. - Elokuussa 1986 koulun nimi muutettiin Rovaniemen hotelli- ja ravintolaoppilaitokseksi. - Elokuussa 1996 aloitti väliaikainen ammattikorkeakoulu toimintansa. - Joulukuussa 1997 Rovaniemen hotelli- ja ravintolaoppilaitos lakkasi olemasta. - 31.12.1997 tilalle tuli Rovaniemen liiketalouden, matkailun ja ravitsemisalan oppilaitos ROMAROL. - Elokuussa 1998 Rovaniemen ammattikorkeakoulu vakinaistettiin. - Tammikuussa 1999 oppilaitoksen nimi muuttui Rovaniemen palvelualojen oppilaitokseksi."@fi ;
    rdaa:P50407 "Rovaniemen palvelualojen oppilaitos"@fi ;
    rdau:P61101 "30 vuotta hotelli- ja ravintola-alan koulutusta Rovaniemellä : 1971-2001/ toimittajat: Eeva-Liisa Hirvikoski, Toini Rossi, 2002"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Rovaniemen palvelualojen oppilaitos"@fi .

