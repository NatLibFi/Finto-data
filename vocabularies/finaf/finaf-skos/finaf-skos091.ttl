    rdaa:P50025 "Oy Strömberg Ab"@fi,
        "Stremberg (yhtiö)"@fi,
        "Стремберг (yhtiö)"@fi ;
    rdaa:P50035 "Oy Strömberg Ab oli suomalainen sähköteknisen alan yritys. Gottfrid Strömberg perusti Helsinkiin vuonna 1889 Gottfr. Strömbergin sähköliikkeen, josta tuli Ab Gottfr. Strömberg Oy -niminen osakeyhtiö vuonna 1909. Myöhemmin nimi muuttui muotoon Oy Strömberg Ab. Fuusion seurauksena nimi muuttui vuonna 1983 muotoon Kymi-Strömberg Oy ja vuonna 1988 muotoon ABB Strömberg ja viime vuosina puhtaasti ABB:n Suomen yksikkö."@fi ;
    rdaa:P50037 "1909" ;
    rdaa:P50038 "1988" ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Strömberg (yhtiö)"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Str%C3%B6mberg_(yritys)'>Wikipedia</a>, katsottu 25.4.2019"@fi,
        "Mikkonen, Tuija. Corporate architecture in Finland in the 1940s and 1950s : factory buildings as architecture, investments and image / Tuija Mikkonen, 2005"@fi ;
    skos:altLabel "Oy Strömberg Ab"@fi,
        "Stremberg (yhtiö)"@fi,
        "Стремберг (yhtiö)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Strömberg (yhtiö)"@fi .

