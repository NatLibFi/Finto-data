        <http://lexvo.org/id/iso639-3/fin>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50025 "Fortum Oyj"@fi ;
    rdaa:P50035 "Fortum Oyj muodostettiin vuonna 1998 yhdistämällä Imatran Voima Oy ja Neste Oy, joissa molemmissa Suomen valtio oli enemmistöomistajana. Fortum jakautui 1. toukokuuta 2004 kahdeksi yhtiöksi, joista Fortumiin jäi sähkön- ja lämmöntuotanto ja Neste Oilille siirtyi öljyliiketoiminta. Neste Oil kuului koko vuoden 2004 Fortum-konserniin ja irtaantui siitä vasta keväällä 2005."@fi ;
    rdaa:P50037 "1998" ;
    rdaa:P50232 finaf:000037790,
        finaf:000037791 ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50350 yso:p94105 ;
    rdaa:P50407 "Fortum (yhtiö)"@fi ;
    rdau:P61101 "<a href='http://www.fortum.fi'>Kotisivut</a>, katsottu 21.10.2020"@fi,
        "Rissanen, Erkki. Fortum - tarina : pettikö virkamiesten moraali? / Erkki Rissanen, 2003"@fi,
        "Wikipedia, 24.5.2017"@fi ;
    skos:altLabel "Fortum Oyj"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Fortum (yhtiö)"@fi .

