finaf:000013430 a rdac:C10005,
        skos:Concept ;
    dct:created "1995-05-02"^^xsd:date ;
    dct:modified "2021-06-18T19:04:36"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000013430" ;
    rdaa:P50016 finaf:000018133,
        finaf:000018175,
        finaf:000029275 ;
    rdaa:P50393 "Helsingfors karamellfabrik perustettu 1890; v 1908 Oy Hellas Ab makeistehdas (Huhtamäki Oy); Huhtamäen suom. makeisyksikkö Hellas sulautui Huhtamäki-yhtymän tytäryhtiöön Leaf:iin 1987. - Lähde: Muuttuvat makeisyritykset Suomessa 1950-1994 / toim. Päivi Eriksson, (1994)"@fi,
        "Osakeyhtiö Hellas perustamiskokous 15.12.1910. - Heinäkuussa 1929 Makeistehdas Oy Hellas. - Vuonna 1920 perustettu Oy Huhtamäen tehtaat-Huhtamäki Fabriker Ab yhdistettiin Hellaksen kanssa 1930-luvun alussa Huhtamäki-Hellas Oy.ksi. - 1940 luvulla nimenä oli Suklaatehdas Hellas Oy. - Vuoden 1940 lopulla Hellas, Ipnos ja Jalostaja liitettiin Huhtamäli-yhtymä Oy:hyn, joka laajeni lääketehdas Leiraksella ja juomatehdas Marlilla.- 1943 Huhtamäki yhtymän osake-enemmistö siirtyi Suomen kulttuurirahastolle. - Loppuvuodesta 1983 ostetiin monialayritys Beatrice Foodsin makeisyksikkö, Leaf Confectionery ja General Millsin Donruss. - Kauppojen tuloksena muodostettiin Leaf. - 1986 Leaf osti hollantilaisen Maple Leafin ja 1989-1990 ostettiin Elizabeth Shaw-yhtiö. - Vuoden 1987 alusta Hellas kuului toiminnallisena osana Huhtamäen tytäryhtiöön Leafiin. - Kevään 1989 aikana Hellas otti virallisesti käyttöön nimen Leaf (kotimaassa käytettiin muotoa Leaf Hellas makeiset). - 1992 Huhtamäki luovutti vaihtokaupassa Rettingille Marlin ja sai auralaisen Sereksen ja oululaisen Merijalin. - Hollantilainen yritys CSM osti Leaf-makeisryhmän (sopimus 26.4.1999, kaupparekisteriin 1.7.1999)."@fi ;
    rdaa:P50407 "Hellas"@fi ;
    rdau:P61101 "Vuosisata turkulaista makeisteollisuutta / Juha Vahe. - Turku, 2000"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Hellas"@fi .

