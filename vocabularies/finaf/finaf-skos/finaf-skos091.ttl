    rdaa:P50012 finaf:000001812 ;
    rdaa:P50016 finaf:000037246 ;
    rdaa:P50025 "Kemifacket"@fi ;
    rdaa:P50035 "Kemianliitto oli suomalainen vuosina 1993–2009 toiminut SAK:lainen ammattiliitto. Järjestö perustettiin, kun Kemian Työntekijäin Liitto (KTL) ja Kumi- ja nahkatyöväen liitto (KNL) yhdistyivät. Vuonna 2009 Kemianliitto päätti fuusioitua Viestintäalan ammattiliiton kanssa Teollisuusalojen ammattiliitoksi (TEAM) ja uusi liitto aloitti vuoden 2010 alussa."@fi ;
    rdaa:P50236 "1993/2009"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m401 ;
    rdaa:P50407 "Kemianliitto"@fi ;
    skos:altLabel "Kemifacket"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Kemianliitto"@fi .

