        "Suomi. Maatalousteknologian tutkimus"@fi,
        "Vakola"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Maa- ja elintarviketalouden tutkimuskeskus. Maatalousteknologian tutkimus"@fi .

