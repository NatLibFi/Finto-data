finaf:000093415 a rdac:C10004,
        skos:Concept ;
    dct:created "1998-09-08"^^xsd:date ;
    dct:modified "2026-03-17T08:11:43"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/000000012276611X>,
        <http://viaf.org/viaf/12735260>,
        "Asteri ID: 000093415" ;
    rdaa:P50097 yso:p94383,
        yso:p94426 ;
    rdaa:P50100 yso:p3830,
        yso:p454,
        yso:p6227 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/lat>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Gadolin, Jacob, 1719-1802"@fi,
        "Gadolin, Jacobus, 1719-1802"@fi ;
    rdaa:P50104 mts:m2638,
        mts:m2773,
        mts:m2816,
        mts:m2946 ;
    rdaa:P50109 yso:p94447 ;
    rdaa:P50113 "Suomenruotsalainen luterilainen pappi, luonnontieteilijä ja poliitikko. Syntyi Ruotsissa vanhempiensa ollessa isovihaa paossa. Kävi Porin triviaalikoulua. Opiskeli Turun akatemiassa matematiikkaa ja teologiaa, valmistui filosofian maisteriksi vuonna 1736. Turun akatemian matematiikan apulaisprofessori vuodesta 1745, fysiikan professori vuodesta 1753 ja teologian professori vuodesta 1762. Vuonna 1788 hänet vihittiin Turun hiippakunnan piispaksi. Vuodesta 1751 Kuninkaallisen tiedeakatemian jäsen numero 127. Suomen Talousseuran perustajia ja ensimmäinen puheenjohtaja. Papiston valtiopäiväedustajana (hattupuolueen kannattaja) vuosina 1755-1756, 1760-1762, 1771-1772, 1786, 1789, 1792 ja 1800."@fi ;
    rdaa:P50118 yso:p94447 ;
    rdaa:P50119 "Strängnäs, Ruotsi"@fi ;
    rdaa:P50120 "1802" ;
    rdaa:P50121 "1719" ;
    rdaa:P50291 "Gadolin" ;
    rdaa:P50292 "Jakob" ;
    rdaa:P50346 yso:p94351 ;
    rdaa:P50411 "Gadolin, Jakob, 1719-1802"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Jakob_Gadolin'>Wikipedia</a>, katsottu 16.3.2026 (Jakob Gadolin)"@fi ;
    skos:altLabel "Gadolin, Jacob, 1719-1802"@fi,
        "Gadolin, Jacobus, 1719-1802"@fi ;
    skos:closeMatch <http://urn.fi/urn:nbn:fi:sks-kbg-002260> ;
    skos:hiddenLabel "Jacob Gadolin"@fi,
        "Jacobus Gadolin"@fi,
        "Jakob Gadolin"@fi ;
