    rdaa:P50095 "Karjalan laamannikunta"@fi ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/lat> ;
    rdaa:P50103 "Krogius, Fridericus Wilhelmus, 1770-1833"@fi ;
    rdaa:P50104 mts:m2890 ;
    rdaa:P50113 "Oikeusrevision toimituskunnan ylim. kanslisti 1791. Pääesikunnan päällikön toimiston sotasihteeri Suomessa 1792-1801. Karjalan laamannikunnan laamanni 1803-1833, samalla hallituskonseljin (senaatin) oikeusosaston jäsen 1809-1833. Protokollasihteerin arvonimi 1796. Valtioneuvos 1822. Todellinen valtioneuvos 1828. Krogius vuoteen 1817, jolloin aateloitiin nimellä Edelheim."@fi ;
    rdaa:P50118 yso:p94137 ;
    rdaa:P50119 yso:p94352 ;
    rdaa:P50120 "1833" ;
    rdaa:P50121 "1770" ;
    rdaa:P50291 "Edelheim" ;
    rdaa:P50292 "Fredrik Wilhelm" ;
    rdaa:P50411 "Edelheim, Fredrik Wilhelm, 1770-1833"@fi ;
    rdau:P61101 "<a href='http://www.helsinki.fi/ylioppilasmatrikkeli/henkilo.php?id=10313'>Kotivuori, Yrjö. Ylioppilasmatrikkeli 1640-1852</a>"@fi,
        "<a href='https://fi.wikipedia.org/wiki/Fredrik_Wilhelm_Edelheim'>Wikipedia</a>, katsottu 27.3.2025 (Fredrik Wilhelm Edelheim: Fredrik Vilhelm Krogius, aateloituna vuodesta 1817 Edelheim (23. heinäkuuta 1770 Porvoo – 25. toukokuuta 1833 Helsinki) oli suomalainen senaattori ja todellinen valtioneuvos.)"@fi,
        "Vallinkoski, Jorma. Turun akatemian väitöskirjat 1642-1828. II"@fi ;
    skos:altLabel "Krogius, Fridericus Wilhelmus, 1770-1833"@fi ;
