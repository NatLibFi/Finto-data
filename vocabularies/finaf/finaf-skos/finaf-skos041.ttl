finaf:000106175 a rdac:C10004,
        skos:Concept ;
    dct:created "1998-09-10"^^xsd:date ;
    dct:modified "2026-02-24T09:59:43"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000122838283>,
        <http://viaf.org/viaf/106964661>,
        "Asteri ID: 000106175" ;
    rdaa:P50097 yso:p104990,
        yso:p105111,
        yso:p105841 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/fra>,
        <http://lexvo.org/id/iso639-3/ita> ;
    rdaa:P50103 "Bonapart, Napoléon, 1769-1821"@fi,
        "Bonaparte, Napoleon, 1769-1821"@fi,
        "Bonaparte, Napoléon, 1769-1821"@fi,
        "Buonaparte, Napoleone di, 1769-1821"@fi ;
    rdaa:P50104 mts:m2374 ;
    rdaa:P50109 yso:p104996 ;
    rdaa:P50110 mts:m470 ;
    rdaa:P50113 "Korsikalaissyntyinen aatelinen. Sai koulutuksensa Ranskan arvostetuimmassa sotilasakatemiassa ja eteni sen jälkeen nopeasti tykistöupseerina niin, että ylennettiin prikaatikenraaliksi jo 24-vuotiaana. Valittiin vuonna 1791 Korsikan kansalliskaartin johtoon. Palattuaan Ranskan mantereelle vuonna 1793 hän oli jonkin aikaa vailla armeijaa. Kutsuttiin kuitenkin loppuvuodesta 1795 kukistamaan Pariisin rojalistikapina. Vuonna 1796 nimitettiin Italiassa olevien ranskalaisjoukkojen ylipäälliköksi. Perusti vuonna 1797 Pohjois-Italiaan Cisalppisen tasavallan, jossa olivat voimassa vallankumoukselliset Ranskan lait. Samantyyppisiä tasavaltoja syntyi muihinkin Ranskan miehittämiin maihin. Pariisissa oli direktori Paul Barras suorittanut sotilasvallankaappauksen ja Napoleonin suuri kansansuosio sai direktoriohallituksen määräämään hänet sotaretkelle Egyptiin. Retken epäonnistuminen ei kuitenkaan vähentänyt hänen suosiotaan. Niinpä hän onnistui kaappaamaan 9.11.1799 vallan, joka aluksi oli muodollisesti kolmella vuosikymmenen välein vaihtuvalla konsulilla, mutta käytännössä Napoleon oli viimeistään vuonna 1802 Ranskan yksinvaltias. Jo konsulina ollessaan jatkoi aggressiivista sodankäyntiä mm. Itävaltaa, Preussia, Britanniaa ja Venäjää vastaan. Vuonna 1814 nämä valtiot lopulta nujersivat ranskalaiset ja marssittivat omat joukkonsa Pariisiin. Napoleon karkotettiin Italiaan Elban saarelle, josta hän onnistui kuitenkin vielä palaamaan Pariisiin sadaksi päiväksi. Viimein Napoleon antautui briteille 15.7.1815 ja joutui vankina Saint Helenan saarelle, missä hän kuoli."@fi ;
    rdaa:P50119 yso:p104968,
        yso:p151150,
        "Ajaccio, Ranska"@fi ;
    rdaa:P50120 "1821" ;
    rdaa:P50121 "1769" ;
    rdaa:P50292 "Napoleon" ;
    rdaa:P50346 yso:p108897,
        yso:p120938,
        yso:p178205,
        "Valence, Ranska"@fi ;
    rdaa:P50411 "Napoleon I, Ranskan keisari, 1769-1821"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Napoleon_I'>Wikipedia</a>, katsottu 23.2.2026 (Napoleon I)"@fi ;
