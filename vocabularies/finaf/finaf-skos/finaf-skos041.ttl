finaf:000105012 a rdac:C10004,
        skos:Concept ;
    dct:created "2000-11-02"^^xsd:date ;
    dct:modified "2025-09-18T11:20:20"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000061354380>,
        "Asteri ID: 000105012" ;
    rdaa:P50103 "Horn, Gustavus, 1592-1657"@fi ;
    rdaa:P50104 "sotakollegion presidentti"@fi ;
    rdaa:P50113 "Palvellut Evert Hornin joukoissa Luoteis-Venäjällä 1612-1614. Kustaa II Adolfin hovimies 1618. Norlannin rykmentin eversti 1621. Valtaneuvos 1625. Suomen sotaväen ylipäällikkö, Pohja-Suomen laamanni 1625. Kenraalimajuri 1626. Sotamarsalkka, Liivinmaalla olevien joukkojen ylipäällikkö 1628. Pommerissa ja Neumarkissa olevien joukkojen komentaja 1631. Frankkilaisen armeijan komentaja 1631. Reinin armeijan komentaja 1632. Sotaneuvos 1633. Skånessa olevien joukkojen ylipäällikkö 1644. Etelä-Suomen laamanni 1644. Liivinmaan kenraalikuvernööri 1652. Valtakunnanmarski, sotakollegion presidentti 1653. Ruotsissa olevien joukkojen ylipäällikkö 1656."@fi ;
    rdaa:P50118 "Skara, Ruotsi"@fi ;
    rdaa:P50119 "Vendel, Ruotsi"@fi ;
    rdaa:P50120 "1657" ;
    rdaa:P50121 "1592" ;
    rdaa:P50291 "Horn" ;
    rdaa:P50292 "Gustaf Carlsson" ;
    rdaa:P50411 "Horn, Gustaf Carlsson, 1592-1657"@fi ;
