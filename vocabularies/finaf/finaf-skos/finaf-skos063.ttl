    rdaa:P50094 <http://isni.org/isni/0000000387381063>,
        <http://viaf.org/viaf/53333469>,
        "Asteri ID: 000139839" ;
    rdaa:P50103 "Carl, Hertig av Södermanland, 1748-1818"@fi,
        "Carolus XIII, rex Sueciae, 1748-1818"@fi,
        "Charles XIII, roi de Suède et de Norvège, 1748-1818"@fi,
        "Karl II, konung av Norge, 1748-1818"@fi,
        "Karl XIII, konung av Sverige och Norge, 1748-1818"@fi ;
    rdaa:P50104 mts:m2374 ;
    rdaa:P50110 mts:m939 ;
    rdaa:P50113 "Ruotsalainen aatelinen, kuningas Aadolf Fredrikin toiseksi vanhin poika ja Kustaa III:n veli. Sai meriupseerikoulutuksen ja matkusteli Euroopassa. Kustaa III:n sodassa vuosina 1788-1789 Kaarle palveli laivaston amiraalina. Toimi veljensä kuoltua tämän alaikäisen pojan, Kustaa IV Aadolfin muodollisena sijaishallitsijana. Pojan täysi-ikäistyttyä vuonna 1796 menetti Kaarle asemansa, mutta vuoden 1809 sotilasvallankaappauksen jälkeen hänet nostettiin ensin valtionhoitajaksi ja pian valtiopäivät valitsivat hänet uudeksi kuninkaaksi. Oli myös Norjan kuningas (hallitsijanimellä Kaarle II) vuosina 1814-1818."@fi ;
    rdaa:P50120 "1818" ;
    rdaa:P50121 "1748" ;
    rdaa:P50292 "Kaarle" ;
    rdaa:P50411 "Kaarle XIII, Ruotsin kuningas, 1748-1818"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Kaarle_XIII'>Wikipedia</a>, katsottu 25.2.2026 (Kaarle XIII)"@fi ;
    skos:altLabel "Carl, Hertig av Södermanland, 1748-1818"@fi,
        "Carolus XIII, rex Sueciae, 1748-1818"@fi,
        "Charles XIII, roi de Suède et de Norvège, 1748-1818"@fi,
        "Karl II, konung av Norge, 1748-1818"@fi,
        "Karl XIII, konung av Sverige och Norge, 1748-1818"@fi ;
    skos:closeMatch <http://urn.fi/urn:nbn:fi:sks-kbg-006132> ;
    skos:inScheme finaf: ;
    skos:prefLabel "Kaarle XIII, Ruotsin kuningas, 1748-1818"@fi .

