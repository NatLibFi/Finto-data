finaf:000179795 a rdac:C10005,
        skos:Concept ;
    dct:created "1994-11-08"^^xsd:date ;
    dct:modified "2021-06-19T15:07:41"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000179795" ;
    rdaa:P50016 finaf:000179796 ;
    rdaa:P50022 yso:p768 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50035 "Vuosikymmenien tauon jälkeen vuonna 1967 uudelleen toimintansa aloittaneen Savonlinnan Oopperajuhlien kuorona lauloi ensimmäiset reilut kymmenen vuotta pääosin paikallisista kuoroharrastajista mutta myös muista, kuten Savonlinnan musiikkipäivien launopiskelijoista, koottu kuoro. Kuoro toimi ympärivuotisesti muutakin ohjelmistoa harjoitellen ja esittäen. Kun oopperajuhlien uuden yhdistysten myötä Savonlinnan Oopperajuhlakuoro otti vastuun oopperajuhlien kuorotehtävistä, Savonlinnan Oopperakuoro jatkoi toimintaansa ”normaalina” paikallisena harrastajasekakuorona, kunnes muutti nimensä vuonna 1992 Savonlinna-kuoroksi (lähde: Sähköposti)."@fi ;
    rdaa:P50237 mts:m2068 ;
    rdaa:P50350 yso:p94402 ;
    rdaa:P50407 "Savonlinnan Oopperakuoro"@fi ;
    rdau:P61101 "Sähköposti 14.3.2018"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Savonlinnan Oopperakuoro"@fi .

