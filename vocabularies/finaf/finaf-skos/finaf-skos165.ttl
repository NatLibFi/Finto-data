        yso:p8434 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "7 Seinähullua Veljestä"@fi ;
    rdaa:P50035 "Yhtye syntyi Raumalla, kun kolme Penttiä, Nieminen, Ilmonen ja Kangas, musisoivat yhdessä Rauman seminaarissa 1960-luvun puolivälissä. Ensimmäinen keikka oli vuonna 1966 Vehmersalmen tanssilavalla. Yhtye esiintyi ennen vuotta 1968 mm. seuraavilla nimillä: Hammond Quintet, Pentti Kankaan tangosextetti ja Pentti Oskari Kankaan showseitsikko, ja solisteina toimivat mm. Lea Laven, Irwin Goodman, Juha Vainio ja muut 1960-luvun artistit. Vuodesta 1968 lähtien yhtye tunnettiin nimellä Pentti Oskari Kankaan Seitsemän Seinähullua veljestä."@fi ;
    rdaa:P50037 "1966" ;
    rdaa:P50237 mts:m1100 ;
    rdaa:P50407 "Seitsemän Seinähullua Veljestä"@fi ;
    rdau:P61101 "<a href='http://7seinahullua.net/'>Yhtyeen kotisivut</a>, katsottu 2.2.2018"@fi,
        "Hankalat musiikkinimet"@fi ;
    skos:altLabel "7 Seinähullua Veljestä"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Seitsemän Seinähullua Veljestä"@fi .

