finaf:000180766 a rdac:C10005,
        skos:Concept ;
    dct:created "2018-03-16"^^xsd:date ;
    dct:modified "2020-11-06T20:12:46"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000474699651>,
        "Asteri ID: 000180766" ;
    rdaa:P50022 yso:p8351 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "Spin-Farm Records"@fi,
        "Spine Records"@fi,
        "Spinefarm Records (levymerkki)"@fi ;
    rdaa:P50035 "Spin-Farm Oy oli Riku Pääkkösen vuonna 1991 perustama levy-yhtiö, joka keskittyi suomalaisen metallimusiikin julkaisemiseen. Spinefarm Recordsin taustayhtiön Spin-Farm Oy:n osake-enemmistö myytiin kansainväliselle Universal Musicille keväällä 2002. Universal Music osti yhtiön kokonaan vuonna 2005 ja se sulautettiin Universal Music Oy:hyn vuoden 2014 lopussa. Spinefarm Recordsin (ala)levymerkki on Ranka Recordings. Spinefarm Records on nykyisin Universal Musicin levymerkki."@fi ;
    rdaa:P50037 "1991" ;
    rdaa:P50038 "2014" ;
    rdaa:P50237 "levy-yhtiö"@fi ;
    rdaa:P50302 finaf:000179948 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Spin-Farm Oy"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Spinefarm_Records'>Wikipedia</a>, katsottu 16.3.2018 (historia)"@fi,
        "Yritys- ja yhteisötietojärjestelmä YTJ, katsottu 16.3.2018 (ajankohdat ja historia)"@fi ;
    skos:altLabel "Spin-Farm Records"@fi,
        "Spine Records"@fi,
        "Spinefarm Records (levymerkki)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Spin-Farm Oy"@fi .

