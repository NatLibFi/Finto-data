finaf:000180877 a rdac:C10005,
        skos:Concept ;
    dct:created "2017-03-22"^^xsd:date ;
    dct:modified "2025-02-19T18:45:38"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000474700309>,
        "Asteri ID: 000180877" ;
    rdaa:P50022 yso:p8351 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "AAB-Tuotanto"@fi ;
    rdaa:P50035 "A.A.B. Tuotanto Oy oli vuonna 1982 toimintansa aloittanut suomalainen levy-yhtiö, jonka omistivat Polarvoxin Leena Juuranto sekä Johanna-levymerkin Atte Blom. Vuosina 1982–1984 yhtiö toimi monen Johanna-levymerkillä julkaistun levyn tuotantoyhtiönä ja levy-yhtiönä. A.A.B. Tuotannon artisteja olivat muun muassa Pelle Miljoona, Tuomari Nurmio, Dave Lindholm, Hanoi Rocks ja Rauli Badding Somerjoki. A.A.B. Tuotanto toimi sekä eräiden vanhojen Johanna-merkin äänitteiden uudelleen- että ensijulkaisijana. Uusia Johanna-albumeja se julkaisi noin neljäkymmentä. A.A.B. Tuotannon toiminta hiljeni 1990-luvun lopulla. Vuonna 1998 Love Kustannus osti A.A.B. Tuotannon tuotantokatalogin ja julkaisuoikeudet ja yhtiö hakeutui konkurssiin maaliskuussa 2000. A.A.B. Tuotannon katalogi siirtyi vuonna 2010 Universal Musicin haltuun, kun Universal osti Love Kustannuksen. Levymerkki: AAB."@fi ;
    rdaa:P50037 "1982" ;
    rdaa:P50038 "2004" ;
    rdaa:P50237 "levy-yhtiö"@fi ;
    rdaa:P50334 finaf:000190036 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "A.A.B. Tuotanto"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/A.A.B._Tuotanto'>Wikipedia</a>, katsottu 18.3.2017 (toiminnan kuvaus)"@fi,
        "Patentti- ja rekisterihalitus. Virre, katsottu 18.3.2017 (ajankohdat)"@fi,
        "Yritys- ja yhteisötietojärjestelmä YTJ, katsottu 18.3.2017 (yrityksen perustiedot)"@fi ;
    skos:altLabel "AAB-Tuotanto"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "A.A.B. Tuotanto"@fi .

