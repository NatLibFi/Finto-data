finaf:000179148 a rdac:C10005,
        skos:Concept ;
    dct:created "2011-12-29"^^xsd:date ;
    dct:modified "2020-12-03T20:21:24"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000492955567>,
        "Asteri ID: 000179148" ;
    rdaa:P50012 finaf:000179149 ;
    rdaa:P50025 "Eteläisen koulun musiikkiluokat"@fi,
        "Riihimäen Eteläisen koulun musiikkiluokat"@fi ;
    rdaa:P50035 "Eteläinen kansakoulu aloitti toimintansa nimellä Riihimäen-Herajoen koulu vuonna 1903. Jo 1907 rakennettiin uusi tilavampi koulurakennus ja tuolloin (1907-1912) koulun nimi oli Riihimäen kansakoulu. Vuonna 1913 koulun nimeksi tuli Eteläinen kansakoulu. Eteläisen kansakoulun nimeä koulu piti aina peruskoulu-uudistukseen asti (1976), jolloin koulun nimi muuttui Eteläisen peruskoulun ala-asteeksi. Vuodesta 1996 alkaen koulun nimi on virallisesti ollut Eteläinen koulu."@fi ;
    rdaa:P50237 "alakoulu"@fi ;
    rdaa:P50350 yso:p94377 ;
    rdaa:P50393 "Vuodesta 1996 lähtien koulun virallinen nimi: Eteläinen koulu"@fi ;
    rdaa:P50407 "Eteläinen koulu (Riihimäki)"@fi ;
    rdau:P61101 "<a href='http://www.riihimaki.fi/palvelut/sivistyspalvelut/perusopetus/alakoulut/etelainen-koulu/historia/'>Riihimäki. Perusopetus. Eteläinen koulu</a>, katsottu 20.2.2018"@fi ;
    skos:altLabel "Eteläisen koulun musiikkiluokat"@fi,
        "Riihimäen Eteläisen koulun musiikkiluokat"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Eteläinen koulu (Riihimäki)"@fi .

