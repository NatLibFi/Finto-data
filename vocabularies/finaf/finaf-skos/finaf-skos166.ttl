    rdaa:P50022 yso:p3779,
        yso:p5363 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50025 "Jakobstads Mekaniska Verkstad (1915-)"@fi,
        "Jakobstads Mekaniska Verkstads Ab"@fi,
        "Pietarsaaren Konepaja Oy"@fi ;
    rdaa:P50035 "Pietarsaaren Konepaja Oy - Jakobstads Mekaniska Verkstads Ab oli suomalainen Pietarsaaressa toiminut konepaja ja valimo. Konepajan toiminta alkoi 1898, kun Birger Serlachius (1874–1934) perusti Jakobstads Mekaniska Verkstad -nimisen kengitys- ja konepajan. Konepajan yhteydessä oli vuodesta 1899 valimo ja vuonna 1909 konepaja muutettiin osakeyhtiöksi. Yhtiön toiminta päättyi konkurssiin 1913, mutta sen toimintaa jatkamaan perustettiin 1915 uusi yhtiö Pietarsaaren Konepaja Oy. Vuonna 1937 sen osti Wärtsilä Oy, joka fuusioi yhtiön itseensä seuraavana vuonna. Konepajan toiminta jatkui Wärtsilän omistuksessa 1970-luvun lopulle saakka."@fi ;
    rdaa:P50236 "1915/.."^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50302 finaf:000007907 ;
    rdaa:P50350 yso:p94337 ;
    rdaa:P50407 "Pietarsaaren Konepaja"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Pietarsaaren_Konepaja'>Wikipedia</a>, katsottu 22.8.2024"@fi ;
    skos:altLabel "Jakobstads Mekaniska Verkstad (1915-)"@fi,
        "Jakobstads Mekaniska Verkstads Ab"@fi,
        "Pietarsaaren Konepaja Oy"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Pietarsaaren Konepaja"@fi .

