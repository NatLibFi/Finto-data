    rdaa:P50104 mts:m2437,
        mts:m2441 ;
    rdaa:P50113 "Belgialainen, Brysselissä vuosina 1654-1685 toiminut kirjanpainaja ja kirjakauppias. Käytti usein keksittyjä painopaikkoja (Mons, Haag, Amsterdam, Köln jne.) ja pseudonyymejä. Syytettin vuonna 1668 luvattomasta painamisesta. Leski jatkoi toimintaa miehensä nimellä vuoteen 1683 saakka ja vielä senkin jälkeen aina vuoteen 1690 asti painettiin julkaisuja, jotka on ilmeisen virheellisesti pantu tämän nimiin."@fi ;
    rdaa:P50291 "Vleugaert" ;
    rdaa:P50292 "Philippe" ;
    rdaa:P50346 yso:p105254 ;
