        yso:p94383 ;
    rdaa:P50100 yso:p3830,
        yso:p8758 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/eng>,
        <http://lexvo.org/id/iso639-3/lat>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Serenius, Jacobus, 1700-1776"@fi,
        "Serenius, Jakob, 1700-1776"@fi,
        "Sirenius, Jakob, 1700-1776"@fi ;
    rdaa:P50104 mts:m2638,
        mts:m2816 ;
    rdaa:P50109 yso:p104995,
        "Nyköping, Ruotsi"@fi,
        "Strängnäs, Ruotsi"@fi ;
    rdaa:P50113 "Ruotsalainen luterilainen pappi. Pappisvihkimyksensä (1722) jälkeen lähetettiin Lontoon luterilaisen seurakunnan pastoriksi ja palasi kotimaahan vasta vuonna 1735. Laati Englannissa asuessaan englanti-ruotsi-latina -sanakirjan, koska arvosti englantilaista koulutusjärjestelmää. Vuonna 1736 sai Nyköpingistä kirkkoherran viran. Teologian tohtori vuonna 1752. Strängnäsin piispa vuodesta 1763. Hoiti tarmokkaasti virkaansa, edisti koulutusta mm. perustamalla omilla varoillaan luonnontieteen lehtoraatin Strängnäsin lukioon. Vaikutti suuresti konfirmaation käyttöönottoon Ruotsissa antamalla hiippakuntaansa määräyksen, jonka mukaan paastoaikana ehtoollista vastaanottavien lasten tulee saada papeilta opetusta ja heitä on kuulusteltava uskonasioista seurakunnan läsnä ollessa sunnuntaiaamuisin. Toimi säätynsä hattupuoluelaisten johtajana valtiopäivillä."@fi ;
    rdaa:P50118 "Strängnäs, Ruotsi"@fi ;
    rdaa:P50119 "Färentuna, Ruotsi"@fi ;
    rdaa:P50120 "1776" ;
    rdaa:P50121 "1700" ;
    rdaa:P50291 "Serenius" ;
    rdaa:P50292 "Jacob" ;
    rdaa:P50346 yso:p106813 ;
    rdaa:P50411 "Serenius, Jacob, 1700-1776"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Jakob_Serenius'>Wikipedia</a>, katsottu 6.3.2026 (Jakob Serenius)"@fi ;
