        <http://viaf.org/viaf/64837738>,
        "Asteri ID: 000095045" ;
    rdaa:P50097 yso:p94383 ;
    rdaa:P50100 yso:p2996,
        yso:p3830,
        yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/lat>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Beronius, Magnus Olavus, 1692-1775"@fi,
        "Beronius, Magnus, 1692-1775"@fi ;
    rdaa:P50104 mts:m2479,
        mts:m2816,
        mts:m2901,
        mts:m3368 ;
    rdaa:P50109 yso:p106813,
        yso:p110129 ;
    rdaa:P50113 "Ruotsalainen luterilainen pappi. Toimi jonkin aikaa lehtorina Gävlessä, sitten Uppsalan yliopistossa ensin runouden, sitten teologian professorina. Vuonna 1745 hänestä tuli Kalmarin piispa ja vuonna 1764 arkkipiispa. Osallistui valtiopäiville (myssypuolueen kannattaja) vuosina 1746, 1751, 1755, 1760 ja säätynsä puhemiehenä vuosina 1765-1766. Nimitettiin myös Uppsalan yliopiston prokansleriksi."@fi ;
    rdaa:P50118 yso:p106813 ;
    rdaa:P50119 yso:p106813 ;
    rdaa:P50120 "1775" ;
    rdaa:P50121 "1692" ;
