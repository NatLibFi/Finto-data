    rdaa:P50103 "Luetkemann, Gabriel Timotheus, 1723-1795"@fi,
        "Lütkemann, Gabriel Thimotheus, 1723-1795"@fi ;
    rdaa:P50104 mts:m2638 ;
    rdaa:P50109 yso:p105464,
        yso:p234571 ;
    rdaa:P50113 "Ruotsalainen luterilainen pappi. Valmistui filosofian maisteriksi Greifswaldissa vuonna 1740 ja teologian tohtoriksi vuonna 1750. Hänestä tuli Tukholman ylisaarnaaja vuonna 1753, Visbyn superintendentti vuonna 1759 ja hiippakunnan ensimmäinen piispa vuonna 1772. Kustaa III nimitti hänet yhdeksi kruununprinssi Kustaa Adolfin kummivanhemmista tämän kastetilaisuudessa 10. marraskuuta 1778. Vuonna 1788 hänestä tuli Gotlannin varakuvernööri."@fi ;
    rdaa:P50118 yso:p192082 ;
    rdaa:P50119 yso:p105464 ;
    rdaa:P50120 "1795" ;
