    rdaa:P50103 "Fredenstjerna, Adamus, 1685-1772"@fi,
        "Schyts, Adamus, 1685-1772"@fi,
        "Schütz, Adam, 1685-1772"@fi ;
    rdaa:P50104 mts:m2729 ;
    rdaa:P50113 "Svean hovioikeuden ylim. kanslisti 1710. Valtiosäätyjen pankin varaviskaali 1711, kanneviskaali 1716. Turun hovioikeuden asessori 1721. Svean hovioikeuden asessori 1728, hovioikeudenneuvos 1736. Oikeuskansleri 1755. Turun hovioikeuden presidentti 1758. Svean hovioikeuden presidentti 1768. Valtiopäivämies 1726-1727, 1731, 1734, 1738-1739, 1740-1741, 174-1743, 1746-1747, 1751-1752, 1755-1756, 1760-1762 ja 1765–66. Vuoteen 1726 Schütz, jolloin aateloitiin nimellä Fredenstierna. Oikeuskanslerin arvonimi 1752."@fi ;
    rdaa:P50118 yso:p105464 ;
    rdaa:P50119 "Viipuri, Karjala"@fi ;
