        "Asteri ID: 000094246" ;
    rdaa:P50097 yso:p94383 ;
    rdaa:P50100 yso:p16911,
        yso:p3830 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/lat>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "AminthOR, 1677-1761"@fi,
        "Rhyzelius, Anders Olofsson, 1677-1761"@fi ;
    rdaa:P50104 mts:m2638,
        mts:m3294,
        mts:m3368 ;
    rdaa:P50113 "Ruotsalainen luterilainen pappi ja historioitsija. Suuri Pohjan sota esti häntä ottamasta vastaan teologian professuuria Turun kuninkaallisessa akatemiassa, joten arkkipiispa H. Spegel nimitti hänet alipastoriksi Tukholmaan. Sai teologian lehtorin mandaatin Uppsalaan vuonna 1712. Jo seuraavana vuonna kuningas Kaarle XII kutsui hänet hovi- ja sotilassaarnaajaksi. Vuonna 1717 hänet nimitettiin kuninkaan rippi-isäksi ja hovin kenttäkonsistorin puheenjohtajaksi. Vuonna 1720 sai ylennyksen Linköpingin tuomiorovastin virkaan. Vuonna 1732 väitteli teologian tohtoriksi ja vuonna 1743 sai Linköpingin hiippakunnan piispan viran."@fi ;
    rdaa:P50118 yso:p234959 ;
    rdaa:P50119 "Skara, Ruotsi"@fi ;
    rdaa:P50120 "1761" ;
    rdaa:P50121 "1677" ;
    rdaa:P50291 "Rhyzelius" ;
    rdaa:P50292 "Andreas Olavi" ;
    rdaa:P50346 yso:p106813 ;
    rdaa:P50411 "Rhyzelius, Andreas Olavi, 1677-1761"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Andreas_Olavi_Rhyzelius'>Wikipedia</a>, katsottu 4.3.2026 (Andreas Olavi Rhyzelius)"@fi ;
