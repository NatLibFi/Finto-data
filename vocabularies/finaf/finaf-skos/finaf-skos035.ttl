finaf:000095115 a rdac:C10004,
        skos:Concept ;
    dct:created "1998-09-28"^^xsd:date ;
    dct:modified "2026-03-20T11:37:24"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000062946812>,
        <http://viaf.org/viaf/5574162669689655500008>,
        "Asteri ID: 000095115" ;
    rdaa:P50097 yso:p105087,
        yso:p94383 ;
    rdaa:P50100 yso:p3582,
        yso:p454,
        yso:p7480 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/lat>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Hochschild, Johannes Henricus, 1711-1776"@fi,
        "Hochschildt, Johan Hindric, 1711-1776"@fi ;
    rdaa:P50104 mts:m2773,
        mts:m2780,
        mts:m2816,
        mts:m3294 ;
    rdaa:P50109 yso:p105464,
        yso:p234571 ;
    rdaa:P50113 "Ruotsalainen, Greifswaldissa tohtoriksi vuonna 1728 väitellyt juristi ja poliitikko. Vuodesta 1731 alkaen toimi auskultanttina ja notaarina Tukholmassa. Raatimies vuodesta 1761 ja vuodesta 1768 Tukholman pohjoisen esikaupungin läntisen kämnerinoikeuden puheenjohtaja. Näiden tehtävien lisäksi Hochschild toimi Ruotsin ritarihuoneenkanslian ylimääräisenä kanslistina valtiopäivillä 1734 ja 1738–1739 sekä valtiopäivämiehenä vuosina 1765–1766 ja 1771–1772. Vuonna 1775 Julkaisi anonyyminä teoksen \"Utkast till historisk beskrifning om Swea rikes äldre province- eller landskapslagar så wäl som allmänna stads- och landslagen. Med tilläggning om 1734 års lag”"@fi ;
    rdaa:P50118 yso:p105464 ;
    rdaa:P50119 yso:p94486 ;
    rdaa:P50120 "1776" ;
    rdaa:P50121 "1711" ;
    rdaa:P50291 "Hochschild" ;
    rdaa:P50292 "Johan Henrik" ;
    rdaa:P50411 "Hochschild, Johan Henrik, 1711-1776"@fi ;
    rdau:P61101 "<a href='https://journal.fi/helsinkilawreview/issue/view/HelLRev-2008'>Helsinki Law Review 1/2008. Vasara, Marianne: Oikeustiedettä ulkomailla – suomalaisten opintomatkat 1600- ja 1700-luvuilla.</a> (Johan Henrik Hochschild - kauppiaan poika 1700-luvulta)"@fi ;
    skos:altLabel "Hochschild, Johannes Henricus, 1711-1776"@fi,
        "Hochschildt, Johan Hindric, 1711-1776"@fi ;
    skos:hiddenLabel "Johan Henrik Hochschild"@fi,
        "Johan Hindric Hochschildt"@fi,
        "Johannes Henricus Hochschild"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Hochschild, Johan Henrik, 1711-1776"@fi .

