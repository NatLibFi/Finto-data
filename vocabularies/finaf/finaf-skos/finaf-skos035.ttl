    rdaa:P50103 "Brahe, Eric, 1722-1756"@fi,
        "Brahe, Erich, 1722-1756"@fi,
        "Brahe, Ericus, 1722-1756"@fi ;
    rdaa:P50104 mts:m2359,
        mts:m2773 ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen, sotilas ja poliitikko. Uppsalassa suoritettujen opintojensa jälkeen liittyi Skånen ratsuväkirykmenttiin vuonna 1741, ylennettiin everstiluutnantiksi vuonna 1752. Hovipuolueen kannattaja, vuosien 1751-1752 valtiopäivillä salaisen komitean jäsen. Toimi puhemiehenä varsinaisen puheenjohtajan Henning Adolf Gyllenborgin sairastaessa. Vuoden 1756 valtiopäivillä jäi kiinni osallistumisesta kuninkaanvallan laajentamista ajavaan salaliittoon. Tuomittiin teloitettavaksi sekä menettämään omaisuutensa ja kunniansa."@fi ;
    rdaa:P50118 yso:p105464 ;
    rdaa:P50119 yso:p105464 ;
