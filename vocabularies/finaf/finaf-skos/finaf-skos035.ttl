    rdaa:P50094 <http://isni.org/isni/0000000484561621>,
        "Asteri ID: 000094746" ;
    rdaa:P50095 "Sääksmäen ylisen ja alisen kihlakunnan tuomiokunta"@fi ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/lat>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Ignatius, Andr. And., 1682-1737"@fi ;
    rdaa:P50104 mts:m3197 ;
    rdaa:P50113 "Seurasi Raaseporin ja Hattulan tuomiokunnan tuomaria käräjillä. Turun hovioikeuden asianajaja 1709. Sääksmäen tuomiokunnan vt. tuomari 1712. Karjalan laamannikunnan vt. laamanni 1712. Asianajajana Köpingissä, Västeråsissa ja Tukholmassa 1713-1716. Pohjois-Roslagenin meriväkirykmentin sotatuomari 1718, toimi sotatuomarina myös tukholmalaisessa laivastoeskaaderissa. Sääksmäen ylisen ja alisen kihlakunnan tuomiokunnan tuomari 1719-1736. Samalla Hämeenlinnan pormestari 1723."@fi ;
    rdaa:P50118 yso:p94432 ;
    rdaa:P50119 yso:p94137 ;
    rdaa:P50120 "1737" ;
    rdaa:P50121 "1682" ;
