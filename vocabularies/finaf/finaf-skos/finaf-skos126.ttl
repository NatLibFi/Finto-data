    rdaa:P50103 "Friesendorff, Friedrich von, 1707-1770"@fi ;
    rdaa:P50104 mts:m2452,
        mts:m2773,
        mts:m2816 ;
    rdaa:P50109 yso:p105464 ;
    rdaa:P50110 mts:m3657 ;
    rdaa:P50113 "Ruotsalainen aatelinen poliitikko. Toimi jonkin aikaa kruununprinssi Adolf Fredrikin hovimarsalkkana ja sai vuonna 1747 Västmanlandin läänin maaherran viran, jota piti vuoteen 1761 saakka. Valtiopäivillä kannatti hattupuoluetta ja oli hovin näkyvä vastustaja. Vuosina 1751, 1755 ja 1760 hänet valittiin salaiseen komiteaan. Vuonna 1761 hän sai nimityksen neuvostoon, jonka paikan sai pitää puolueensa kukistuttua vuonna 1765, koska oli osoittanut olevansa eri linjoilla hattujen kanssa äänestäessään Ranskan kanssa tehtyä avustussopimusta vastaan. Hänet nimitettiin jo samana vuonna valtakunnankansleriksi. C.G. Löwenhielmin kuoltua vuonna 1768 hän toimi kansliapresidenttinä. Hattujen palatessa valtaan vuonna 1769 hän menetti paikkansa valtuustossa."@fi ;
    rdaa:P50118 "Vallstanäs, Ruotsi"@fi ;
    rdaa:P50119 "Vallstanäs, Ruotsi"@fi ;
    rdaa:P50120 "1770" ;
    rdaa:P50121 "1707" ;
    rdaa:P50291 "Friesendorff" ;
    rdaa:P50292 "Fredrik von" ;
    rdaa:P50411 "Friesendorff, Fredrik von, 1707-1770"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Fredrik_von_Friesendorff'>Wikipedia</a>, katsottu 10.3.2026 (Fredrik von Friesendorff)"@fi ;
    skos:altLabel "Friesendorff, Friedrich von, 1707-1770"@fi ;
    skos:hiddenLabel "Fredrik von Friesendorff"@fi,
        "Friedrich von Friesendorff"@fi ;
