finaf:000235869 a rdac:C10004,
        skos:Concept ;
    dct:created "2026-03-03"^^xsd:date ;
    dct:modified "2026-03-03T12:10:45"^^xsd:dateTime ;
    rdaa:P50094 <http://viaf.org/viaf/3646168850946867620001>,
        "Asteri ID: 000235869" ;
    rdaa:P50097 yso:p104968,
        yso:p94081,
        yso:p94383 ;
    rdaa:P50100 yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/lat>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50104 mts:m2359,
        mts:m2773,
        mts:m3363 ;
    rdaa:P50113 "Ruotsalainen aatelinen. Palveli nuorena kuningas Kaarle XII:n henkivartiostossa ja oli läsnä Fredrikshaldissa vuonna 1718. Seurasi kenttämarsalkka Erik Sparre af Sundbytä Ranskaan ja jäi sinne 1720-1730-lukujen ajaksi Saksin kreivin, marsalkka Moritzin alaisuuteen. Palattuaan vuonna 1738 Ruotsiin antautui politiikkaan hattupuolueen innokkaana kannattajana. Osallistui valtiopäiville vuosina 1738-1743 ja 1746-1747, tästä suuren osan salaisen valtuuskunnan jäsenenä. Sodan loppuvaiheessa hän palveli Ahvenanmaalla. Merkittävin panoksensa oli lähettilään työ Tanskan hovissa, jossa hän mm. sai aikaan Holsteinin vaihtosopimuksen. Osallistui valtiopäiville vielä vuonna 1755. Vastusti puolueensa äärimmäistä valuutta- ja teollisuuspolitiikkaa, mutta jäi yksin mielipiteineen. Myssypuolueen voitettua joutui eroamaan valtuutetun tehtävästä ja hallituksen vaihduttua vuonna 1769 kieltäytyi ikäänsä vedoten."@fi ;
    rdaa:P50118 "Björklinge, Ruotsi"@fi ;
    rdaa:P50120 "1778" ;
    rdaa:P50121 "1696" ;
    rdaa:P50291 "Fleming" ;
    rdaa:P50292 "Otto Hermansson" ;
    rdaa:P50411 "Fleming, Otto Hermansson, 1696-1778"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Otto_Fleming'>Wikipedia</a>, katsottu 3.3.2026 (Otto Fleming)"@fi ;
    skos:hiddenLabel "Otto Hermansson Fleming"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Fleming, Otto Hermansson, 1696-1778"@fi .

