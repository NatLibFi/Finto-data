    rdaa:P50006 <http://isni.org/isni/0000000474637768>,
        "Asteri ID: 000038139" ;
    rdaa:P50025 "Ruotsi. Haapaniemen sotakoulu"@fi ;
    rdaa:P50035 "Suomen ensimmรคinen maavoimien upseerikoulu, Haapaniemen Sotakoulu, sai alkunsa Savon Prikaatin komentajan, eversti Yrjรถ Maunu Sprengtportenin Ruotsin kuninkaalle Kustaa III:lle 20.3.1779 tekemรคstรค aloitteesta. Koulun tarkoituksena oli valmistaa upseereja Savon ja Karjalan joukko-osastojen tarpeisiin. Se aloitti toimintansa Kuopiossa 1.8.1780, ja vappuna 1781 se muutti Haapaniemen tilalle Rantasalmen pitรคjรครคn, missรค se toimi sota-aikoja lukuun ottamatta ensin Ruotsin ja sitten Venรคjรคn vallan alla vuoteen 1819 saakka. Vuosina 1781-1790 koulun nimi oli Haapaniemen Sotakoulu, vuosina 1791-1808 Haapaniemen Kadettikoulu ja vuosina 1812-1819 Haapaniemen Kenttรคmittauskoulu."@fi ;
    rdaa:P50236 "1781/1790"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 "koulu"@fi,
        "sotilasopetuslaitos"@fi ;
    rdaa:P50350 yso:p94371 ;
    rdaa:P50407 "Haapaniemen sotakoulu"@fi ;
    rdau:P61101 "<a href='http://www.rantasalmi.fi/index.php?id=149'>Verkkosivut, 14.12.2012</a>"@fi,
        "Kotkien varjot, 2012: t.p. (Kotkien varjot : Suomi vuonna 1812 = รrnarnas skuggor : Finland รฅr 1812 / toimittaneet = redaktรถrer: Jussi Nuorteva & Pertti Hakala. Helsinki : Arkistolaitos,)"@fi ;
    skos:altLabel "Ruotsi. Haapaniemen sotakoulu"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Haapaniemen sotakoulu"@fi .

