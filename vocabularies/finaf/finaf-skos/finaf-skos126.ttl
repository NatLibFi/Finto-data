    rdaa:P50097 yso:p104968,
        yso:p94383 ;
    rdaa:P50100 yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Falckengren, Christopher, 1722-1789"@fi,
        "Falkengren, Christoffer, 1722-1789"@fi,
        "Falkengren, Kristofer, 1722-1789"@fi,
        "Falkengren, Kristoffer, 1722-1789"@fi ;
    rdaa:P50104 mts:m2726,
        mts:m2770,
        mts:m2773,
        mts:m2816,
        mts:m5091 ;
    rdaa:P50110 mts:m3657 ;
    rdaa:P50113 "Ruotsalainen aatelinen, meriupseeri ja poliitikko. Palveli nuorena Ruotsin laivastossa, astui Ranskan merivoimiin vuonna 1745 ja menestyi taisteluissa englantilaisia vastaan. Myöhemmin hän sai fregattikapteenin arvon ansiostaan Flanderin sodassa. Ruotsiin palattuaan vuonna 1746 hänet ylennettiin kapteeniksi vuonna 1750. Drottningholmin komentajana hän osallistui Suomen-retkikuntaan vuonna 1751. Vuonna 1755 hän osallistui marokkolaisia vastaan suunnattuun retkeen. Kadettijoukkojen päällikkö vuonna 1757, schoutbynacht vuonna 1765, kaleerilaivaston päällikkö vuonna 1767 ja vara-amiraali vuonna 1769. Osallistui valtiopäiville vuosina 1760-1762 ja 1765-1766. Kannatti hattupuoluetta ja vastusti Augustin Ehrensvärdiä. Aateloitiin vuonna 1771. Vuonna 1776 hänet nimitettiin Amiraliteetin korkeakoulun presidentiksi."@fi ;
    rdaa:P50118 yso:p105464 ;
    rdaa:P50119 yso:p112241 ;
    rdaa:P50120 "1789" ;
    rdaa:P50121 "1722" ;
