    rdaa:P50102 <http://lexvo.org/id/iso639-3/lat> ;
    rdaa:P50103 "Laski, Samuel, noin 1553-1611"@fi,
        "Lasky, Samuel, noin 1553-1611"@fi,
        "Ласкі, Самуэль, noin 1553-1611"@fi ;
    rdaa:P50104 mts:m2532,
        mts:m2776,
        mts:m3078,
        mts:m3363 ;
    rdaa:P50109 yso:p105464,
        yso:p105683 ;
    rdaa:P50113 "Puolalainen aatelinen, sotilas ja diplomaatti. Kunnostautui Stefan Báthoryn Liivinmaan-sodissa. Sitten hänestä tuli uuden kuninkaan (Sigismundin) sihteeri ja neuvonantaja. Vuonna 1597 hän oli mukana Tukholmassa sovittelemassa Sigismundin ja Kaarle-herttuan välistä konfliktia tehtävänään myös tiedusteluinformaation keruu säätyjen suhtautumisesta asiaan. Seuraavana vuonna hän osallistui Sigismundin yritykseen Ruotsin palauttamisesta tämän hallintaan, ja onnistuikin valtaamaan Tukholman, jonka kuvernöörinä toimi Klas Bielken kanssa pari kuukautta. Sigismundin hävittyä Stångebron taistelun kukistui myös Laskin asema, ja hän joutui palaamaan Puolaan. Vuonna 1605 hän toimi sovittelijana Danzigissa luterilaisten ja kalvinistien välillä."@fi ;
    rdaa:P50118 "Szynwałd, Puola"@fi ;
    rdaa:P50120 "1611" ;
    rdaa:P50121 "1553~" ;
    rdaa:P50291 "Łaski" ;
    rdaa:P50292 "Samuel Gotard" ;
    rdaa:P50411 "Łaski, Samuel Gotard, noin 1553-1611"@fi ;
