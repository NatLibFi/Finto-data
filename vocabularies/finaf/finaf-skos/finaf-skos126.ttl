finaf:000236105 a rdac:C10004,
        skos:Concept ;
    dct:created "2026-03-24"^^xsd:date ;
    dct:modified "2026-03-25T10:11:16"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000019931471>,
        <http://viaf.org/viaf/72592482>,
        "Asteri ID: 000236105" ;
    rdaa:P50097 yso:p105244,
        yso:p94383 ;
    rdaa:P50100 yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Brahe zu Wisingsborg, Erik, 1552-1614"@fi,
        "Brahe, Eric, 1552-1614"@fi,
        "Brahe, Erich, 1552-1614"@fi,
        "Brahe, Ericus, 1552-1614"@fi,
        "Brahé, Eric, 1552-1614"@fi ;
    rdaa:P50104 mts:m2773,
        mts:m3363 ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen. Toimi Juhana III:n ja tämän seuraajan Sigismundin hovissa. Osallistui Sigismundin valintaan Puolan kuninkaaksi vuonna 1587. Seurasi tätä Puolaan vuonna 1591 ja kääntyi katolisuuteen. Samana vuonna peri isältään Visingsborgin kreivikunnan. Palasi Ruotsiin ja sai nimityksen Tre Kronor -linnan kuvernööriksi, mutta hänellä oli vaikeuksia tehdä yhteistyötä Kaarle-herttuan kanssa, joka piti häntä Sigismundin kätyrinä. Kaarle yritti, onnistumatta, viedä häneltä maaomaisuuden siveettömyyteen vedoten. Sigismundin maihinnousun aikaan hän vielä kannatti tätä, mutta Stångebron taistelun jälkeen hän siirtyi Kaarle-herttuan puolelle saavuttamatta kuitenkaan herttuan luottamusta. Vuonna 1600 hän jätti Ruotsin ja yritti turhaan päästä takaisin Sigismundin suosioon."@fi ;
    rdaa:P50118 yso:p109864 ;
    rdaa:P50119 "Sundholmen (Borås), Ruotsi"@fi ;
    rdaa:P50120 "1614" ;
    rdaa:P50121 "1552" ;
    rdaa:P50291 "Brahe" ;
    rdaa:P50292 "Erik" ;
    rdaa:P50411 "Brahe, Erik, 1552-1614"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Erik_Brahe_(1552%E2%80%931614)'>Wikipedia</a>, katsottu 24.3.2026 (Erik Brahe (1552-1614))"@fi ;
    skos:altLabel "Brahe zu Wisingsborg, Erik, 1552-1614"@fi,
        "Brahe, Eric, 1552-1614"@fi,
        "Brahe, Erich, 1552-1614"@fi,
        "Brahe, Ericus, 1552-1614"@fi,
        "Brahé, Eric, 1552-1614"@fi ;
    skos:hiddenLabel "Eric Brahe"@fi,
        "Eric Brahé"@fi,
        "Erich Brahe"@fi,
        "Ericus Brahe"@fi,
        "Erik Brahe"@fi,
        "Erik Brahe zu Wisingsborg"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Brahe, Erik, 1552-1614"@fi .

finaf:000236106 a rdac:C10004,
        skos:Concept ;
    dct:created "2026-03-24"^^xsd:date ;
    dct:modified "2026-03-25T10:12:25"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000054731985>,
        <http://viaf.org/viaf/2448743>,
        "Asteri ID: 000236106" ;
    rdaa:P50097 yso:p105244,
        yso:p94383 ;
    rdaa:P50100 yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Arvid Gustafsson Stenbock, 1541-noin 1607"@fi,
        "Gustafsson Stenbock, Arvid, 1541-noin 1607"@fi,
        "Gustafsson, Arvid, 1541-noin 1607"@fi,
        "Gustavi, Arvidus, 1541-noin 1607"@fi,
        "Gustavus Arvidus in Boxholm, 1541-noin 1607"@fi ;
    rdaa:P50104 mts:m2749,
        mts:m2773,
        mts:m3363 ;
    rdaa:P50109 yso:p105464 ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen. Joutui vangiksi Kööpenhaminassa vuonna 1563 ja vapautui vasta vallan vaihduttua vuonna 1568. Tämän jälkeen hän eteni Ruotsin laivastossa amiraalin sijaiseksi vuonna 1570. Seuraavana vuonna hänet nimitettiin hovimestariksi ja vuonna 1573 Viron sotakomissaariksi. Puukotettuaan kenttämarsalkka Ivar Månsson Stiernkorsin hengiltä hänet tuomittiin joksikin aikaa vankilaan ja suuriin sakkoihin surmansa saaneen pojille, mutta aateloitiin silti jo vuonna 1580 ja palkittiin laajoilla läänityksillä. Hän osallistui vuoden 1582 valtiopäiville. Vuonna 1593 kuningas Sigismund nimitti hänet Itä-Göötanmaan maaherraksi. Vuonna 1596 hänen nimityksensä peruttiin ja hän lähti Puolaan säätyjen ja Kaarle-herttuan asioissa. Vuonna 1597 hänestä tuli Viron kenraalikuvernööri. Vuonna 1600 sai kruunulta korvauksia menettämistään kartanoista."@fi ;
    rdaa:P50118 yso:p109864 ;
    rdaa:P50119 yso:p506834 ;
    rdaa:P50120 "1607~" ;
    rdaa:P50121 "1541" ;
