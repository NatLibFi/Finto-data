    rdaa:P50094 <http://isni.org/isni/0000000118164706>,
        <http://viaf.org/viaf/102440496>,
        "Asteri ID: 000235931" ;
    rdaa:P50097 yso:p94383 ;
    rdaa:P50100 yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Rudbeck, T. G. (Thure Gustaf), 1714-1786"@fi,
        "Rudbeck, Ture Gustaf, 1714-1786"@fi ;
    rdaa:P50104 mts:m2452,
        mts:m2726,
        mts:m2773,
        mts:m2816 ;
    rdaa:P50109 yso:p105464 ;
    rdaa:P50110 mts:m3657 ;
    rdaa:P50113 "Ruotsalainen aatelinen, sotilas ja poliitikko. Vuonna 1731 liittyi vapaaehtoisena Hämeenlinnan läänin jalkaväkirykmenttiin ja kohosi sotilasurallaan nopeasti aina vuonna 1766 myönnettyyn kenraalimajurin arvoon asti. Kunnostautui neuvokkuudellaan hattujen sodassa (1741-1743). Taalainmaan kapinassa hän oli mukana Riddarholmin siltojen miehityksessä. Pommerin sodan alussa hän toimi Ungern-Sternbergin adjutanttina. Vuonna 1758 hänet nimitettiin Porin rykmentin everstiksi ja seuraavana vuonna Upplannin rykmentinpäälliköksi. Hän oli saavuttanut mainetta myös puhujana ja maaseututalouden asiantuntijana. Osallistui valtiopäiville myssyjen kannattajana. Vuosien 1760-1762 valtiopäivillä hän taisteli salaisen valiokunnan jäsenenä hattuja vastaan. Vuosina 1773-1782 toimi Uppsalan läänin maaherrana."@fi ;
    rdaa:P50118 "Sollentuna, Ruotsi"@fi ;
    rdaa:P50119 "Rasbo, Ruotsi"@fi ;
    rdaa:P50120 "1786" ;
    rdaa:P50121 "1714" ;
    rdaa:P50291 "Rudbeck" ;
    rdaa:P50292 "Thure Gustaf" ;
    rdaa:P50411 "Rudbeck, Thure Gustaf, 1714-1786"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Thure_Gustaf_Rudbeck_(1714%E2%80%931786)'>Wikipedia</a>, katsottu 10.3.2026 (Thure Gustaf Rudbeck (1714–1786))"@fi ;
