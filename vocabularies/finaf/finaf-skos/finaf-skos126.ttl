    rdaa:P50094 <http://viaf.org/viaf/7426163274282112440003>,
        "Asteri ID: 000235982" ;
    rdaa:P50097 yso:p105087,
        yso:p94383 ;
    rdaa:P50100 yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Lilliehorn, Per, 1729-1798"@fi,
        "Lilljehorn, Pehr, 1729-1798"@fi ;
    rdaa:P50104 mts:m2773,
        mts:m2816,
        mts:m5088 ;
    rdaa:P50109 yso:p105464 ;
    rdaa:P50113 "Ruotsalainen aatelinen. Sotilas ja valtiopäiväedustaja. Palveli vuosina 1749-1758 useiden muiden maiden (Alankomaat, Napolin kuningaskunta, Iso-Britannia ja Ranska) laivastoissa. Ruotsin amiraliteetin kapteeniluutnantti 1760, kapteeni 1770, everstiluutnantti 1773, eversti 1777, vara-amiraali 1789 ja kontra-amiraali pari kuukautta myöhemmin samana vuonna. Osallistui valtiopäiviin vuosina 1760-1762, 1765-1766, 1769-1772, 1778-1779, 1786 ja 1789, näistä viimeisillä säätynsä vt. puhemiehenä. Joutui eroamaan armeijasta vuonna 1790. Amiraliteettioikeus tuomitsi hänet laiminlyönneistä syytettynä kuolemaan, mutta kuningas Kustaa III uskoi hänen väitteensä aateliston kostosta ja armahti hänet sillä ehdolla, että pysyy poissa Ruotsista kolme vuotta, jonka ajan viettikin sitten Saksassa."@fi ;
    rdaa:P50118 "Mönsterås, Ruotsi"@fi ;
    rdaa:P50119 "Döderhult, Ruotsi"@fi ;
    rdaa:P50120 "1798" ;
    rdaa:P50121 "1729" ;
    rdaa:P50291 "Lilliehorn" ;
    rdaa:P50292 "Pehr" ;
    rdaa:P50411 "Lilliehorn, Pehr, 1729-1798"@fi ;
    rdau:P61101 "<a href='https://d-nb.info/gnd/1241834156'>DNB</a>, katsottu 16.3.2026 (Lilliehorn, Pehr)"@fi,
        "<a href='https://sv.wikipedia.org/wiki/Per_Lilliehorn'>Wikipedia</a>, katsottu 16.3.2026 (Per Lilliehorn)"@fi ;
