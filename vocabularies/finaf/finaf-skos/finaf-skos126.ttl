        mts:m3004 ;
    rdaa:P50109 yso:p104996,
        yso:p109223 ;
    rdaa:P50113 "Ranskalainen, Pariisissa (1526-1551) ja Genevessä (1551-1559) toiminut kirjanpainaja, kirjakauppias ja humanisti. Kirjoitti useita sanakirjoja ja kielioppeja latinan ja kreikan kielistä sekä Raamatun kommentaareja. Oli kuningas Frans I:n suojeluksessa, toimi tämän lukijana vuodesta 1527 ja kirjastonhoitajana vuodesta 1540. Kuninkaan kuoltua vuonna 1547 joutui Sorbonnen teologien silmätikuksi ja pakeni Geneveen vuonna 1550."@fi ;
    rdaa:P50118 yso:p109223 ;
    rdaa:P50119 yso:p104996 ;
    rdaa:P50120 "1559" ;
