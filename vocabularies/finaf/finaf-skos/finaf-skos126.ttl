finaf:000235915 a rdac:C10004,
        skos:Concept ;
    dct:created "2026-03-09"^^xsd:date ;
    dct:modified "2026-03-13T11:25:03"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000061265118>,
        <http://viaf.org/viaf/310506165>,
        "Asteri ID: 000235915" ;
    rdaa:P50097 yso:p104968,
        yso:p94383 ;
    rdaa:P50100 yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/fra>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Fersen, Fredric Axel von, der Ältere, 1719-1794"@fi,
        "Fersen, Fredrik Axel von, 1719-1794"@fi,
        "Von Fersen, Fredrik Axel, 1719-1794"@fi ;
    rdaa:P50104 mts:m2726,
        mts:m2773,
        mts:m2816 ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen, sotilas ja poliitikko. Palattuaan vuonna 1748 Ranskasta pyrki käyttämään siellä saavuttamaansa kenraalimajurin arvoa, mutta kruununprinssi Adolf Fredrik torjui ajatuksen vanhempia upseereita loukkaavana. Fersenin ystävät saivat kuitenkin jo seniilin kuningas Fredrikin nimittämään hänet. Tapaus varjosti Fersenin suhdetta hoviin myöhemmin. Vuosien 1755-1756 valtiopäivillä hänestä aatelissäädyn puhemies ja hattupuolueen johtaja. Pommerin sotaan osallistuminen keskeytti politiikan harjoittamisen, mutta Fersen palasi puhemieheksi vuonna 1760 ja onnistui hidastamaam puolueensa häviötä. Seuraavina vuosina hän lähentyi hovia ja osallistui kaartin päällikkönä Adolf Fredrikin suunnitelmaan painostaa parlamenttia kruunustaluopumisuhkauksella. Vuonna 1769 hänet valittiin kolmannen kerran kenttämarsalkaksi (aateliston puhemieheksi), mutta ei ollutkaan enää yhtä halukas monarkian vahvistamiseen. Kustaa III:n noustua valtaistuimelle kieltäytyi puhemiesvaalista, mutta suostui sovitteluyritykseen muiden säätyjen hattupuoluelaisten kanssa supistamalla aatelisoikeuksia. Aie epäonnistui, mutta Kustaa-kuninkaan vuoden 1772 vallankaappaus ei. Fersen otti yhteen kuninkaan kanssa vuosien 1778-1779 valtiopäivillä. Tästä huolimatta kuningas nimitti Fersenin Ruotsin akatemiaan vuonna 1786. Vuoden 1786 valtiopäivillä Fersen esiintyi opposition johtajana, ja hillitsi kiihkeimpiä puoluetovereitaan. Vuonna 1789 Fersen taisteli salaisen komitean vallan rajoittamisen puolesta, mikä johti oppositiojohdon vangitsemisiin. Fersen pysyi vangittuna valtiopäiväkauden loppuun."@fi ;
    rdaa:P50118 yso:p105464 ;
    rdaa:P50119 yso:p105464 ;
    rdaa:P50120 "1794" ;
    rdaa:P50121 "1719" ;
    rdaa:P50291 "Fersen" ;
    rdaa:P50292 "Axel von" ;
    rdaa:P50411 "Fersen, Axel von, 1719-1794"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Axel_von_Fersen_den_%C3%A4ldre'>Wikipedia</a>, katsottu 9.3.2026 (Axel von Fersen den äldre)"@fi ;
