finaf:000235929 a rdac:C10004,
        skos:Concept ;
    dct:created "2026-03-10"^^xsd:date ;
    dct:modified "2026-03-13T11:25:34"^^xsd:dateTime ;
    rdaa:P50094 <http://viaf.org/viaf/9237163092002695070000>,
        "Asteri ID: 000235929" ;
    rdaa:P50097 yso:p94383 ;
    rdaa:P50100 yso:p4029,
        yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50104 mts:m2443,
        mts:m2773,
        mts:m2816 ;
    rdaa:P50109 yso:p105464 ;
    rdaa:P50113 "Ruotsalainen tukkukauppias ja poliitikko. Osallistui valtiopäiville (hattujen kannattaja) vuosina 1738-1762, jonka ajan hän oli myös salaisen valiokunnan jäsen. Pääsi valtuutetuksi manufaktuurikonttoriin ja valtionpankkiin. Säätynsä puhemieheksi hänet valittiin vuosina 1755 ja 1760. Vuodesta 1757 toimi Tukholman kauppapormestarina ja hieman myöhemmin alkoi johtaa Itä-Intian kauppakomppaniaa. Hyödynsi asemaansa omaksi edukseen valtion kustannuksella. Hattupuolueen kukistuminen tuhosi myös Kiermanin, hänen omaisuutensa takavarikoitiin ja hänet tuomittiin vuonna 1765 vankeuteen, jonka aikana hän kuoli."@fi ;
    rdaa:P50118 "Marstrand, Ruotsi"@fi ;
    rdaa:P50119 "Askersund, Ruotsi"@fi ;
    rdaa:P50120 "1766" ;
    rdaa:P50121 "1702" ;
    rdaa:P50291 "Kierman" ;
    rdaa:P50292 "Gustaf" ;
    rdaa:P50411 "Kierman, Gustaf, 1702-1766"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Gustaf_Kierman'>Wikipedia</a>, katsottu 10.3.2026 (Gustaf Kierman)"@fi ;
    skos:hiddenLabel "Gustaf Kierman"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Kierman, Gustaf, 1702-1766"@fi .

