    rdaa:P50006 <http://isni.org/isni/000000047463396X>,
        "Asteri ID: 000037566" ;
    rdaa:P50008 finaf:000000481,
        finaf:000017756 ;
    rdaa:P50035 "Viktor Svaetichin teokset kerรคttiin Viipurin historiallisen museon kokoelmiin vuosina 1912-1938. \"Kokoelma\" syntyi vasta sodan jรคlkeen ja muodostamisen peruste oli se, ettรค nimenomaan nรคmรค tyรถt olivat pelastuneet. Viipurin kaupungin omaisuuden mukana kokoelma siirtyi Suomen valtiolle ja sijoitettiin Lahden kaupunginmuseoon sรคilytettรคvรคksi ja hoidettavaksi. Torkkelin sรครคtiรถn, nykyisen Viipuri-sรครคtiรถn, omistukseen ja hallintaan se tuli vuonna 1991. Osa kokoelmasta, mukana neljรคsosa Viipuri-aiheisista, siirrettiin Lahdesta Lappeenrantaan Etelรค-Karjalan maakuntamuseoon vuonna 1962."@fi ;
    rdaa:P50237 "kokoelma"@fi ;
    rdaa:P50407 "Svaetichin-kokoelma"@fi ;
    rdau:P61101 "Svaetichin, Viktor. Viktor Svaetichin, 2009"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Svaetichin-kokoelma"@fi .

