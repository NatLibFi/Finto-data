    rdaa:P50103 "Sternberg, Mattias Alexander von Ungern-, 1689-1763"@fi,
        "Ungern-Sternberg, Mattias Alexander von, 1689-1763"@fi ;
    rdaa:P50104 mts:m2773,
        mts:m3363 ;
    rdaa:P50110 mts:m3657 ;
    rdaa:P50113 "Ruotsalainen aatelinen, sotilas ja poliitikko (myssypuolueen kannattaja). Liittyi Ruotsin armeijaan vuonna 1704 ja oli jo seuraavana vuonna amiraliteetin luutnantti. Osallistui vuodesta 1706 alkaen Espanjan perimyssotaan, ensin Ranskan ja sitten Alankomaiden palveluksessa. Vuonna 1709 palasi Ruotsiin ja osallistui vapaaehtoisena Helsingborgin taisteluun vuonna 1710. Eteni rakuunarykmentissä kapteeniksi vuonna 1713 ja everstiluutnantiksi vuonna 1731. Vapaudenaikana alkoi osallistua politiikkaan ja tuli myssypuoluelaisena valituksi säätynsä puhemieheksi vuoden 1742 valtiopäivillä. Oli myös Kuninkaallisen tiedeakatemian jäsen nro 110 vuodesta 1747."@fi ;
    rdaa:P50118 "Äs (Katrineholm), Ruotsi"@fi ;
    rdaa:P50119 yso:p105464 ;
    rdaa:P50120 "1763" ;
    rdaa:P50121 "1689" ;
    rdaa:P50291 "Ungern-Sternberg" ;
    rdaa:P50292 "Matthias Alexander von" ;
    rdaa:P50411 "Ungern-Sternberg, Matthias Alexander von, 1689-1763"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Mattias_Alexander_von_Ungern-Sternberg'>Wikipedia</a>, katsottu 3.3.2026 (Mattias Alexander von Ungern-Sternberg)"@fi ;
