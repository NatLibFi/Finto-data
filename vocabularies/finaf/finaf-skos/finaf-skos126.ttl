finaf:000235889 a rdac:C10004,
        skos:Concept ;
    dct:created "2026-03-05"^^xsd:date ;
    dct:modified "2026-03-18T13:01:21"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000385116020>,
        <http://viaf.org/viaf/9827268>,
        "Asteri ID: 000235889" ;
    rdaa:P50097 yso:p105087,
        yso:p94383 ;
    rdaa:P50100 yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Gyllenborg, Henning Adolph, 1713-1775"@fi,
        "Gyllenborg, Henning, 1713-1775"@fi ;
    rdaa:P50104 mts:m2773,
        mts:m3363 ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen, poliitikko (hattupuolueen kannattaja). Toimi vuosien 1738-1741 valtiopäivillä salaisessa komiteassa. Puhetaitonsa ansiosta yleni majurin arvoon ilman sotilaallista asemaa. Joutui ongelmiin oman puolueensa kanssa, mutta onnistui välttämään tilanteen eskaloitumisen varovaisuudellaan. Vuonna 1743 hänet lähetettiin Hampuriin kertomaan Holsteinin herttuattarelle, että tämän poika oli valittu Ruotsin kruununperijäksi. Sieltä hän siirtyi Berliiniin auttamaan Tessiniä Adolf Fredrikin ja Loviisa Ulrikan avioliittosopimuksen solmimisessa. Nimitettiin prinsessan vt. kamariherraksi, ja Ruotsiin palattuaan ylennettiin superintendentiksi. Vuosien 1746-1747 ja 1755-1756 valtiopäivillä toimi jälleen salaisessa komiteassa. Toimi säätynsä puhemiehenä, mutta sairasteli niin, että tehtävää hoiti usein Erik Brahe. Oli vuonna 1756 mukana laatimassa kuninkaan ja kuningattaren välisen epäonnistuneen vallankaappausyrityksen jälkeistä kuninkaanvaltaa rajoittavaa lakia. Samana vuonna sai paikan kuninkaallisessa neuvostossa, ja seuraavana vuonna kannatti sodanjulistusta Preussia vastaan. Vuonna 1761 hän erosi poliittisista tehtävistään. Oli Ruotsin tiedeakatemian jäsen vuodesta 1752 alkaen."@fi ;
    rdaa:P50118 yso:p105464 ;
    rdaa:P50119 "Järlåsa, Ruotsi"@fi ;
    rdaa:P50120 "1775" ;
    rdaa:P50121 "1713" ;
    rdaa:P50291 "Gyllenborg" ;
    rdaa:P50292 "Henning Adolf" ;
    rdaa:P50346 yso:p105255,
        yso:p105612,
        yso:p106813,
        yso:p167868 ;
    rdaa:P50411 "Gyllenborg, Henning Adolf, 1713-1775"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Henning_Adolf_Gyllenborg'>Wikipedia</a>, katsottu 5.3.2026 (Henning Adolf Gyllenborg)"@fi ;
    skos:altLabel "Gyllenborg, Henning Adolph, 1713-1775"@fi,
        "Gyllenborg, Henning, 1713-1775"@fi ;
