    rdaa:P50094 <http://isni.org/isni/0000000039051703>,
        <http://viaf.org/viaf/61106739>,
        "Asteri ID: 000236007" ;
    rdaa:P50097 yso:p94383 ;
    rdaa:P50100 yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Duvall, Joh. Diedrich, 1723-1801"@fi,
        "Duwall, Johan Diedrik, 1723-1801"@fi ;
    rdaa:P50104 mts:m2773,
        mts:m2816,
        mts:m3154 ;
    rdaa:P50109 yso:p105464 ;
    rdaa:P50110 mts:m3657 ;
    rdaa:P50113 "Ruotsalainen aatelinen, sotilas ja poliitikko. Sotilasuralla eteni kapteeniksi, mutta vuonna 1757 johtavan hattupuolueen jäsenen tyttären, Ulrika Kiermanin kanssa solmitun avioliiton myötä kiinnostui politiikasta. Jo vuosien 1760-1762 valtiopäivillä häntä ehdotettiin valtioneuvostoon ja ylennettiin everstiksi vuonna 1762. Hattujen palattua enemmistöksi vuonna 1769 hänet nimitettiin salaiseen valiokuntaan. Vuosien 1771-1772 valtiopäivillä hän oli yhtenä kolmesta hattupuoluelaisesta, jotka kuninkaan aloitteesta neuvottelivat myssyjen kanssa, kuitenkin tuloksetta. Vuonna sai ylennyksen kenraalimajuriksi ja vuonna 1786 kenraaliluutnantiksi. Samana vuonna hänestä tuli myös säätynsä puhemies. Vuoden 1789 valtiopäivillä hän palasi perustuslaillisen vapauden puolustajaksi, mutta välttyi kuitenkin pidätykseltä."@fi ;
    rdaa:P50118 "Näsby, Ruotsi"@fi ;
    rdaa:P50119 "Näsby, Ruotsi"@fi ;
    rdaa:P50120 "1801" ;
    rdaa:P50121 "1723" ;
    rdaa:P50291 "Duwall" ;
    rdaa:P50292 "Johan Didrik" ;
    rdaa:P50411 "Duwall, Johan Didrik, 1723-1801"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Johan_Diedric_Duwall'>Wikipedia</a>, katsottu 17.3.2026 (Johan Diedric Duwall)"@fi ;
    skos:altLabel "Duvall, Joh. Diedrich, 1723-1801"@fi,
