rdaa:P50001 a rdf:Property ;
    rdfs:label "is respondent of"@en,
        "väitöskirja"@fi ;
    rdakit:hasElementType "2" ;
    rdakit:instructionNumber "18.5" ;
    rdakit:toolkitDefinition "A thesis provided by the praeses in an academic disputation that is defended or opposed by a candidate for a degree."@en,
        "Väitöskirja, jonka preeses esittelee akateemisessa väitöstilaisuudessa, ja jota oppiarvoa tavoiteleva kandidaatti puolustaa tai opponoi."@fi ;
    rdakit:toolkitLabel "respondent of"@en,
        "väitöskirja"@fi ;
    reg:hasSubproperty <http://rdaregistry.info/Elements/a/datatype/P50001>,
        <http://rdaregistry.info/Elements/a/object/P50001> ;
    reg:hasUnconstrained rdau:P60001 ;
    reg:lexicalAlias rdaa:respondentOf.en,
        rdaa:vaitoskirja.fi ;
    reg:name "respondentOf"@en,
        "vaitoskirja"@fi ;
    reg:status <http://metadataregistry.org/uri/RegStatus/1001> ;
    rdfs:domain rdac:C10004 ;
    rdfs:isDefinedBy rdaa: ;
    rdfs:subPropertyOf rdaa:P50542 ;
    skos:definition "Relates a person to a thesis provided by the praeses in an academic disputation that is defended or opposed by a candidate for a degree."@en,
        "Liittää oppiarvoa tavoittelevan, puolustavan tai opponoivan kandidaatin väitöskirjaan, jonka preeses esittelee akateemisessa väitöstilaisuudessa."@fi .

rdaa:P50002 a rdf:Property ;
    rdfs:label "is appellee corporate body of"@en,
        "yhteisöön kohdistuva muutoshakemus"@fi ;
    rdakit:hasElementType "2" ;
    rdakit:instructionNumber "18.5" ;
    rdakit:toolkitDefinition "A legal work of a higher court that records a decision of a lower court that appeals against a corporate body."@en,
        "Hakemus, jolla haetaan muutosta alemman oikeusasteen päätökseen ja joka kohdistuu yhteisöön."@fi ;
    rdakit:toolkitLabel "appellee corporate body of"@en,
        "yhteisöön kohdistuva muutoshakemus"@fi ;
    reg:hasSubproperty <http://rdaregistry.info/Elements/a/datatype/P50002>,
        <http://rdaregistry.info/Elements/a/object/P50002> ;
    reg:hasUnconstrained rdau:P60601 ;
    reg:lexicalAlias rdaa:appelleeCorporateBodyOf.en,
        rdaa:yhteisoonKohdistuvaMuutoshakemus.fi ;
    reg:name "appelleeCorporateBodyOf"@en,
        "yhteisoonKohdistuvaMuutoshakemus"@fi ;
    reg:status <http://metadataregistry.org/uri/RegStatus/1001> ;
    rdfs:domain rdac:C10005 ;
    rdfs:isDefinedBy rdaa: ;
    rdfs:subPropertyOf rdaa:P50844 ;
    skos:definition "Relates a corporate body to a legal work of a higher court that records a decision of a lower court that appeals against a corporate body."@en,
        "Liittää muutoshakemuksen kohteena olevan yhteisön hakemukseen, jolla haetaan muutosta alemman oikeusasteen päätökseen."@fi .

rdaa:P50003 a rdf:Property ;
