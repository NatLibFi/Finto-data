    rdaa:P50109 yso:p105464,
        yso:p106813,
        yso:p120569 ;
    rdaa:P50113 "Ruotsalainen luterilainen pappi (vihkimys vuonna 1776). Hovisaarnaaja vuosina 1780-1782, Växjön piispa vuodesta 1787 alkaen. Osallistui valtiopäiville vuosina 1786, 1789-1792 ja 1800. Tuki siellä monarkiaa. Salaisen komitean jäsenenä onnistui vastuuttamaan säädyt valtionvelan hoidosta. Teologian tohtori hänestä tuli 1793, sen jälkeen kun oli palannut hiippakuntaansa."@fi ;
    rdaa:P50118 yso:p110922 ;
    rdaa:P50119 yso:p234960 ;
    rdaa:P50120 "1800" ;
    rdaa:P50121 "1755" ;
