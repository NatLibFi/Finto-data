    rdaa:P50292 "Maunu" ;
    rdaa:P50411 "Tavast, Maunu, noin 1370-1452"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Maunu_Tavast'>Wikipedia</a>, katsottu 19.9.2022 (Magnus II Tavast, myös Magnus Olai (\"Maunu Olavinpoika\") (k. 9. maaliskuuta 1452 Mynämäki) oli Suomen keskiajan huomattavin katolinen piispa eli Suomen piispa. Hän toimi Suomen piispana vuosina 1412–1450. Maunun on väitetty syntyneen 14. lokakuuta 1357. Tietoa pidetään kuitenkin epäuskottavana, varsinkin kun hän olisi tällöin elänyt 94-vuotiaaksi. Todennäköisempi synnyinajankohta on 1370-luvun alkupuolella.)"@fi ;
    skos:altLabel "Magnus Olai, noin 1370-1452"@fi ;
    skos:closeMatch <http://urn.fi/urn:nbn:fi:sks-kbg-000230> ;
    skos:hiddenLabel "Maunu Tavast"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Tavast, Maunu, noin 1370-1452"@fi .

