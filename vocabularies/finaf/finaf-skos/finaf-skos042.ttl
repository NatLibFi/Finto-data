finaf:000106521 a rdac:C10004,
        skos:Concept ;
    dct:created "1997-11-11"^^xsd:date ;
    dct:modified "2024-09-22T08:43:40"^^xsd:dateTime ;
    rdaa:P50094 "Asteri ID: 000106521" ;
    rdaa:P50097 yso:p105078 ;
    rdaa:P50103 "Amonute, noin 1596-1617"@fi,
        "Matoaka, noin 1596-1617"@fi,
        "Matoaka, prinsessa, noin 1596-1617"@fi,
        "Matoax, noin 1596-1617"@fi,
        "Pocahontas, prinsessa, noin 1596-1617"@fi,
        "Pokahontas, noin 1596-1617"@fi,
        "Rolfe, Rebecca, Lady, noin 1596-1617"@fi,
        "Rolfe, Rebecca, noin 1596-1617"@fi,
        "White Feather, noin 1596-1617"@fi,
        "Матаок, noin 1596-1617"@fi,
        "Матаока, noin 1596-1617"@fi,
        "Матоака, noin 1596-1617"@fi,
        "Покахонтас, noin 1596-1617"@fi ;
    rdaa:P50104 mts:m3143 ;
    rdaa:P50110 mts:m1544 ;
    rdaa:P50118 "Gravesend, Kent, Englanti"@fi ;
    rdaa:P50119 "Werowocomoc, Gloucester, Virginia"@fi ;
    rdaa:P50120 "1617" ;
    rdaa:P50121 "[1595..1597]" ;
    rdaa:P50292 "Pocahontas" ;
    rdaa:P50411 "Pocahontas, noin 1596-1617"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Pocahontas'>Wikipedia</a>, katsottu 22.9.2024 (Pocahontas (s. 1595 – 21. maaliskuuta 1617) oli pohjoisamerikkalainen intiaanityttö, joka auttoi siirtolaisia perustamaan ensimmäisen englantilaisen siirtokunnan nyky-Yhdysvaltojen alueelle. Hänen isänsä oli powhatanien liittokunnan päällikkö Wahunsunacock, jonka poliittinen valta ylettyi lähes kaikkiin Virginian itäisiä rannikkoalueita (silloiselta nimeltään Tenakomakah) asuttaviin algonkin-kielisiin heimoihin. Kristinuskoon kastamisen jälkeen Pocahontas sai nimen Rebecca ja avioitumisensa jälkeen hänestä tuli Rebecca Rolfe.)"@fi,
        "<a href='https://www.geni.com/people/Pocahontas/6000000005385138952'>Geni</a>, katsottu 22.9.2024 (Pocahontas; Matoaka, later Amonute, 'Rebecca' Rolfe; gender: female; birth: 1596 Werowocomoco Village, (current day Tidewater, Virginia), Tsenacommacah, pre colonial America; death: 21 March 1617 (20-21) Gravesend, Kent, England (Old World disease - pneumonia, tuberculosis, or … ); place of burial: St. George's Church, Gravesend, Kent, England, United Kingdom; immediate family: daughter of Wahunseneca, Paramount chief of the Powhatan and Mother of Pocahontas & Matachanna; wife of Kocoum of the Patawomeke and Captain John Rolfe, ancient planter; mother of Lieut. Thomas Rolfe; sister of Matachanna, of the Powhatan; half sister of Tatacoope, \"Weroance of the Tapahanock\", \"Cleopatra\", of the Powhatan, Wife of Necotowance, Unknown, of the Powhatan, Nantaquas, of the Powhatan, Parahunt, of the Powhatan, Taux, of the Powhatan, Po-Chins, of the Powhatan, and Mehtafe, of the Powhatan)"@fi ;
    skos:altLabel "Amonute, noin 1596-1617"@fi,
        "Matoaka, noin 1596-1617"@fi,
        "Matoaka, prinsessa, noin 1596-1617"@fi,
        "Matoax, noin 1596-1617"@fi,
        "Pocahontas, prinsessa, noin 1596-1617"@fi,
