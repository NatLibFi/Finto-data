finaf:000105589 a rdac:C10004,
        skos:Concept ;
    dct:created "1998-10-08"^^xsd:date ;
    dct:modified "2026-03-18T13:00:16"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000059191690>,
        <http://viaf.org/viaf/86429806>,
        "Asteri ID: 000105589" ;
    rdaa:P50097 yso:p94383 ;
    rdaa:P50100 yso:p1271,
        yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Lagerberg Herrlund, Sven, 1672-1746"@fi,
        "Lagerberg, Sven, 1672-1746"@fi ;
    rdaa:P50104 mts:m2773,
        mts:m3277,
        mts:m3363 ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen, sotilas ja virkamies. Osallistui vänrikkinä suureen Pohjan sotaan, haavoittui Pultavassa, kuningas Kaarle XII:n ollessa Turkissa häntä käytettiin neuvotteluissa Krimin kaanin kanssa ja sai tämän suostumaan hyökkäykseen Venäjää vastaan. Ylennettiin vuonna 1710 Skaraborgin rykmentin everstiluutnantiksi ja vuonna 1714 Kronobergin rykmentin everstiksi, ja osallistui Wismarin piiritykseen. Ylennettynä kenraalimajuriksi ja Skaraborgin rykmentin komentajaksi vuonna 1717 hän osallistui tässä ominaisuudessa Norjan vastaiseen kampanjaan. Hänestä tuli paroni vuonna 1719 ja seuraavana vuonna valtionvarainministeriön (Statskontoret) puheenjohtaja. Vuonna 1723 aatelissääty valitsi hänet puhemiehekseen. Kreivin arvoon vuonna 1731. Kannatti myssypuoluetta, mutta sai silti jatkaa poliittista toimintaansa kuolemaansa asti."@fi ;
    rdaa:P50118 yso:p105464 ;
    rdaa:P50119 "Stora Kärr, Ruotsi"@fi ;
    rdaa:P50120 "1746" ;
    rdaa:P50121 "1672" ;
    rdaa:P50291 "Lagerberg" ;
    rdaa:P50292 "Swen" ;
    rdaa:P50411 "Lagerberg, Swen, 1672-1746"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Swen_Lagerberg'>Wikipedia</a>, katsottu 23.2.2026 (Swen Lagerberg)"@fi ;
