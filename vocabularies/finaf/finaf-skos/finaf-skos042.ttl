    rdaa:P50097 yso:p94383 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/lat>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Leijonhufvud, Axel Gabriel Carlsson, 1717-1789"@fi,
        "Leijonhuvud, Axel Gabriel, 1717-1789"@fi,
        "Leyonhufwud, Axel Gabriel, 1717-1789"@fi,
        "Leyonhuvud, Axel Gabriel, 1717-1789"@fi ;
    rdaa:P50109 yso:p105464,
        yso:p94447 ;
    rdaa:P50110 mts:m3657 ;
    rdaa:P50113 "Ruotsalainen aatelinen, sotilas ja hovimies. Opiskeli Uppsalan yliopistossa, aloitti työuransa kuninkaan kansliakollegiossa vuonna 1734. Henkivartiokaartin vapaaehtoinen vuonna 1737. Osallistui vänrikkinä hattujen sotaan. Vuodesta 1744 palveli Turun läänin jalkaväkirykmentissä kapteeniluutnanttina, yleni kapteeniksi vuonna 1746. Vuonna 1752 Länsipohjan rykmentin kapteeniksi. Kruununprinssi Kustaan kavaljeeri vuosina 1756-1762. Ylennettiin majuriksi vuonna 1757, everstiluutnantiksi vuonna 1763. Hovimarsalkka vuonna 1766 ja prinsessa Sofia Albertinan ylikamariherra vuosina 1767-1770. Toimi säätynsä puhemiehenä vuosien 1771-1772 valtiopäivillä. Vuodet 1775-1780 toimi Turun hovioikeuden presidenttinä."@fi ;
    rdaa:P50118 "Lindö, Ruotsi"@fi ;
    rdaa:P50119 "Säter, Ruotsi"@fi ;
    rdaa:P50120 "1789" ;
    rdaa:P50121 "1717" ;
    rdaa:P50291 "Leijonhufwud" ;
    rdaa:P50292 "Axel Gabriel Carlsson" ;
    rdaa:P50346 yso:p106813 ;
