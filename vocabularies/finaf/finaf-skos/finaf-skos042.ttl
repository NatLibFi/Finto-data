    rdaa:P50094 <http://isni.org/isni/0000000484636638>,
        "Asteri ID: 000107736" ;
    rdaa:P50095 "Porin läänin jalkaväkirykmentti"@fi ;
    rdaa:P50104 mts:m2359 ;
    rdaa:P50113 "Ratsumies Turun ja Porin läänin ratsuväkirykmentissä 1690. Musketööri henkikaartissa 1694, piikkimies 1694, varusmestari 1695, majoittaja 1695. Kuninkaan henkivartiosotilas 1700, korpraali 1706. Sivustakenraaliadjutantti 1711. 2-eversti leskikuningattaren henkiratsuväkirykmentissä 1712, eversti 1716-1720. Eversti Bohuslänin ratsuväkirykmentissä, siirto Kyminkartanon läänin jalkaväkirykmenttiin 1721, Porin läänin jalkaväkirykmenttiin 1727. Valtiopäivämies 1719, 1723, 1726-1727 ja 1731."@fi ;
    rdaa:P50118 yso:p105158 ;
    rdaa:P50119 yso:p94447 ;
    rdaa:P50120 "1733" ;
    rdaa:P50121 "1674" ;
    rdaa:P50291 "Wallenstierna" ;
    rdaa:P50292 "Samuel" ;
    rdaa:P50411 "Wallenstierna, Samuel, 1674-1733"@fi ;
    rdau:P61101 "<a href='http://www.helsinki.fi/ylioppilasmatrikkeli/henkilo.php?id=3149'>Kotivuori, Yrjö. Ylioppilasmatrikkeli 1640-1852</a>"@fi,
        "Vallinkoski, Jorma. Turun akatemian väitöskirjat 1642-1828. II"@fi ;
