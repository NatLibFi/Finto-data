finaf:000032279 a rdac:C10005,
        skos:Concept ;
    dct:created "2012-03-22"^^xsd:date ;
    dct:modified "2020-11-05T20:37:56"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000032279" ;
    rdaa:P50012 finaf:000032288 ;
    rdaa:P50025 "Frenckellin ja pojan kirjakauppa"@fi,
        "Frenckellin kirjakauppa"@fi,
        "J. C. Frenckell & son i Åbo"@fi,
        "J. C. Frenckell & sons bokhandel"@fi,
        "J. C. Frenckellin kirjakauppa"@fi ;
    rdaa:P50035 "Kirjanpainaja Johan Christopher Frenckell II (1757-1818) otti poikansa Johan Christopher Frenckellin III (1789-1844) vuonna 1814 yhtiökumppanikseen. Kirjakauppatoiminta alkoi 1783 Frenckell II toimesta. Se jatkui J. C. Frenckell III aikana. Hänen poikansa J. C. Frenckell IV (1819-1856) hoiti Turun kirjapainoa ja -kauppaa vuodesta 1844. J. C. Frenckell IV kuoli naimattomana ja suku myi Turun kirjapainon ja -kaupan. Kirjakauppa oli J. W. Lilljan omistuksessa vuodesta 1856. A. W. Edgren ja J. E. Reuter ostivat Lilljalta Frenckellin kirjakaupan 1860."@fi ;
    rdaa:P50237 "myymälä"@fi ;
    rdaa:P50336 finaf:000032278,
        finaf:000032280 ;
    rdaa:P50407 "Frenckellska bokhandeln i Åbo"@fi ;
    rdau:P61101 "Hakapää, Jyrki. Kirjan tie lukijalle, 2008."@fi,
        "Kirjakauppaluetteloita. Helsinki, Frenckell"@fi ;
    skos:altLabel "Frenckellin ja pojan kirjakauppa"@fi,
        "Frenckellin kirjakauppa"@fi,
        "J. C. Frenckell & son i Åbo"@fi,
        "J. C. Frenckell & sons bokhandel"@fi,
        "J. C. Frenckellin kirjakauppa"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Frenckellska bokhandeln i Åbo"@fi .

finaf:000032378 a rdac:C10005,
        skos:Concept ;
    dct:created "2011-05-18"^^xsd:date ;
    dct:modified "2021-06-19T15:01:57"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000032378" ;
    rdaa:P50012 finaf:000032376,
        finaf:000032377 ;
    rdaa:P50035 "Katedralskolan i Åbo on Turussa toimiva ruotsinkielinen lukio. Koulu jatkaa jo keskiajalla perustetun Turun katedraalikoulun perinteitä. Nykyään toimiva koulu syntyi vuonna 1971 kun yhdistettiin Svenska klassiska lyceum ja Åbo svenska flicklyceum. Neljä vuotta myöhemmin kouluun yhdistettiin vielä Svenska Samlyceum. Lisätietoja: http://fi.wikipedia.org/wiki/Katedralskolan_i_%C3%85bo"@fi,
        "Suomen eduskunta päätti, että Svenska klassiska lyceum i Åbo (Turun ruotsalainen klassillinen lyseo) ja Åbo svenska flicklyceum (Turun ruotsalainen tyttölyseo) muutettaisiin yhdeksi yhteislyseoksi syyslukukaudesta 1971 alkaen. Ylimenokausi kesti aina vuoteen 1975, ja tämän jälkeen kaikki oppikoululuokat kulkivat nimellä Katedralskolan i Åbo. Peruskoulun alkaessa Turussa lukuvuotena 1975-76 lukiosta tuli erillinen kouluyksikkönsä samalla nimellä.Lisätietoja: http://www.tkukoulu.fi/~katedral/suomeksi/historiikki.html#tanaan"@fi,
        "Turun katedraalikoulu eli Tuomiokirkkokoulu oli kirkon keskiajalla ylläpitämä koulu ja palveli lähinnä pappien koulutusta. Katedraalikoulu oli Suomen ensimmäinen koulu. Sen perustivat katoliset munkit 1200-luvulla, todennäköisesti vuonna 1276. Koulu muutettiin vuonna 1630 Turun kymnaasiksi, josta puolestaan tuli vuonna 1640 Turun akatemia. Akatemiaksi muuttamisen jälkeenkin kaupunkiin jäi silti yhä yliopistoon valmistava katedraalikoulu, josta alettiin vuonna 1641 käyttää triviaalikoulun nimeä. Vuonna 1830 koulu jaettiin ylempään alkeisoppilaitokseen ja lukioon, josta tuli uusi Turun kymnaasi, aina vuoteen 1872 saakka. Nykyisin koulun perinteitä jatkaa Katedralskolan i Åbo. Lisätietoja: http://fi.wikipedia.org/wiki/Turun_katedraalikoulu"@fi ;
    rdaa:P50236 "1971/.."^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50336 finaf:000032379 ;
    rdaa:P50407 "Katedralskolan i Åbo"@fi ;
    rdau:P61101 "<a href='http://fi.wikipedia.org/wiki/Katedralskolan_i_%C3%85bo'>Wikipedia:</a>"@fi,
        "<a href='http://www.tkukoulu.fi/~katedral/suomeksi/historiikki.html#tanaan'>Yhteisön kotisivu:</a>"@fi ;
    skos:inScheme finaf: ;
