finaf:000033739 a rdac:C10005,
        skos:Concept ;
    dct:created "2003-06-16"^^xsd:date ;
    dct:modified "2021-06-19T15:02:42"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000033739" ;
    rdaa:P50012 finaf:000033749 ;
    rdaa:P50016 finaf:000033740,
        finaf:000034451 ;
    rdaa:P50238 mts:m358 ;
    rdaa:P50393 "Tampereen tilakeskuksen historia alkaa vuodesta 1902, jolloin Rahatoimikamarin uudistettu johtosääntö astui voimaan. Sen alaisuudessa oli neljä osastoa, joista yksi oli Rakennuskonttori. Rakennuskonttorin alaisuudessa toimi mm. Arkkitehtiosasto. Vuonna 1929 Rahatoimikamarin tilalle tuli Kaupunginhallitus, Rakennuskonttorin tilalle Yleisten töiden lautakunta, jonka alaisuudessa Arkkitehtiosasto toimi. Vuoden 1951 alussa arkkitehtiosastosta lohkaistiin talonrakennusosasto omaksi yksikökseen. Yleisten töiden lautakunta lakkautettiin 1960 ja sen tilalle perustettiin seuraavana vuonna mm. talonrakennuslautakunta. Tässä vaiheessa arkkitehtiosasto ja talonrakennusosasto taas yhdistettiin talonrakennusvirastoksi. Nykyisen nimensä ja muotonsa organisaatio sai vuonna 1993, kun rakennusviraston tilalle perustettiin Tilakeskus"@fi ;
    rdaa:P50407 "Tampereen kaupunki. Talonrakennusosasto"@fi ;
    rdau:P61101 "Helen, Olli. Sadan vuoden urakka : Tampereen talojen rakentajat 1902-2002 / Olli Helen ; [julkaisija: Tampereen kaupungin tilakeskus], 2003"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Tampereen kaupunki. Talonrakennusosasto"@fi .

finaf:000033740 a rdac:C10005,
        skos:Concept ;
