finaf:000018408 a rdac:C10005,
        skos:Concept ;
    dct:created "2002-07-03"^^xsd:date ;
    dct:modified "2021-06-18T19:06:27"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000018408" ;
    rdaa:P50012 finaf:000018409 ;
    rdaa:P50016 finaf:000007321,
        finaf:000018410 ;
    rdaa:P50025 "Skolstiftelsen för vanföra"@fi ;
    rdaa:P50237 mts:m257 ;
    rdaa:P50393 "Raajarikkoisten auttamisyhdistyksen perustava kokous pidetty 27.10.1889. Keisari vahvisti 31.3.1890 yhdistyksen 15-kohtaiset säännöt, joiden mukaan yhdistyksen tuli perustaa raajarikkoisten koulu ja \"klinikka\". Raajarikkoisten työkoulu aloitti toimintansa 10.11.1890. Vuodesta 1941 lähtien se toimi erillisenä kansakouluna. Vuonna 1952 alettiin rakentaa ja vuonna 1953 vihittiin käyttöön Ruskeasuon koulu, joka myöhemmin irtaantui tukisäätiön yhteydestä ja siityi valtion huomaan. Vammaisten lasten ja nuorten tukisäätiö päätettiin lopettaa vuosikokouksessa 1948 ja sen tilalle perustettiin Raajarikkojen koulusäätiö - Skolstiftelsen för vanföra. Nimenmuutokset v. 1971 Lapsi-invalidien koulutussäätiö ja 11.12.1987 Vammaisten lasten ja nuorten tukisäätiö."@fi ;
    rdaa:P50407 "Raajarikkojen koulusäätiö"@fi ;
    rdau:P61101 "Vuolle, Tuula. Mahdollisen lapset : historiaa ja taidetta / Tuula Vuolle, Pirjo Hämäläinen-Forslund, 2001"@fi ;
    skos:altLabel "Skolstiftelsen för vanföra"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Raajarikkojen koulusäätiö"@fi .

