finaf:000012657 a rdac:C10005,
        skos:Concept ;
    dct:created "2017-03-24"^^xsd:date ;
    dct:modified "2025-10-01T14:12:02"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/000000047445665X>,
        "Asteri ID: 000012657" ;
    rdaa:P50008 finaf:000035318 ;
    rdaa:P50010 finaf:000176895 ;
    rdaa:P50022 yso:p857 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "Yle Radio Suomi"@fi,
        "Yleisradio. Radio Suomi"@fi ;
    rdaa:P50035 "Yle Radio Suomi on uutis-, palvelu-, ja kontaktikanava, jonka ohjelmistossa painottuu myös viihde. Musiikkitarjonta on kotimaista ja ulkomaista iskelmää, melodista aikuisrockia sekä nostalgiapoppia. Yle Radio Suomen edeltäjinä oli Yleisohjelma (1963–1985) ja 1-verkko (1985–1990) sekä aiemmin erillisenä radioasemina toimineet aluetoimitukset. Yleisradion ensimmäinen alueradio Ylen aikainen aloitti toimintansa 1975. Tämän jälkeen aloittivat toimintansa aluradiot Turussa ja Tampereella 1982."@fi ;
    rdaa:P50037 "1990" ;
    rdaa:P50237 mts:m818 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Radio Suomi"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Yle_Radio_Suomi'>Wikipedia</a>, katsottu 24.3.2017"@fi ;
    skos:altLabel "Yle Radio Suomi"@fi,
        "Yleisradio. Radio Suomi"@fi ;
