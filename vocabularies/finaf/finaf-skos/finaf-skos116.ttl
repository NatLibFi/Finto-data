finaf:000016980 a rdac:C10005,
        skos:Concept ;
    dct:created "2000-10-23"^^xsd:date ;
    dct:modified "2026-01-07T17:54:10"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000016980" ;
    rdaa:P50016 finaf:000016983 ;
    rdaa:P50022 yso:p7457 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "Asevarikko Kuopio"@fi ;
    rdaa:P50035 "Kuopion Asevarikko perustettiin 18. heinäkuuta 1918. Vuonna 1921 muuttuivat asevarikoiden nimet ase- ja ampumatarvikevarikoiksi, jolloin varikosta tuli Ase- ja Ampumatarvikevarikko 3. Vuoden 1930 lopulla se sai jälleen uuden nimen Asevarikko 3. Vuoden 1944 alussa Asevarikko 3 sai jälleen nimekseen Ase- ja ampumatarvikevarikko 3, mutta varikosta tuli jo vuonna 1945 Keskusvarikko 6. Keskusvarikko 6:sta tuli Pääesikunnan taisteluvälinepäällikön alainen Asevarikko 1 vuonna 1952. Kuopion Asevarikko lakkautettiin itsenäisenä joukko-osastona 31.12.2007."@fi ;
    rdaa:P50236 "1918/1930"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 "sotilasyksikkö"@fi ;
    rdaa:P50350 yso:p94234 ;
    rdaa:P50393 "Asevarikko Kuopio 1918-1921, Ase- ja ampumatarvikevarikko 3 1921-1930, Asevarikko 3 1930-1944, Keskusvarikko 6 1944-1952, Asevarikko 1 1952-1992, Kuopion asevarikko 1.1.1993-"@fi ;
    rdaa:P50407 "Ase- ja ampumatarvikevarikko 3"@fi ;
    rdau:P61101 "Laine, Leo: Kuopion asevarikko 1918-1998. 1998"@fi ;
    skos:altLabel "Asevarikko Kuopio"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Ase- ja ampumatarvikevarikko 3"@fi .

