finaf:000037920 a rdac:C10005,
        skos:Concept ;
    dct:created "2011-01-04"^^xsd:date ;
    dct:modified "2022-03-08T11:42:48"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000037920" ;
    rdaa:P50012 finaf:000037923 ;
    rdaa:P50016 finaf:000038027 ;
    rdaa:P50022 yso:p18824 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "Suomen Työväen Keskinäinen Vakuutusyhdistys Turva"@fi ;
    rdaa:P50035 "Palkansaajat ja työväenjärjestöt perustivat Turvan Tampereella vuonna 1910. Vakuutusyhdistys sai nimekseen Hämeen Työväen Keskinäinen Paloapuyhdistys, ja sen päätoimialana ovat työväentalojen palovakuutukset. Vuonna 1914 kun yhdistyksen toiminta laajeni valtakunnalliseksi, uudeksi toiminimeksi tuli Suomen Työväen Keksinäinen Paloapuyhdistys Turva. Vuonna 1922 kun toiminta laajeni edelleen, yhdistyksen uusissa säännöisä vahvistettiin uudeksi nimeksi Suomen Työväen Keskinäinen Vakuutusyhdistys Turva. Vuonna 1934 Turva muuttui yhdistyksestä yhtiöksi, samalla nimi vaihtuu Työväen Keskinäinen Vakuutusyhtiö Turvaksi. Vuonna 2000 yhtiön virallinen nimi muutettiin muotoon Keskinäinen vakuutusyhtiö Turva."@fi ;
    rdaa:P50236 "1922/1934"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 "vakuutuslaitos"@fi ;
    rdaa:P50350 yso:p94436 ;
    rdaa:P50407 "Turva, Suomen Työväen Keskinäinen Vakuutusyhdistys"@fi ;
    rdau:P61101 "Turvan taival 1910-2010, 2010"@fi ;
    skos:altLabel "Suomen Työväen Keskinäinen Vakuutusyhdistys Turva"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Turva, Suomen Työväen Keskinäinen Vakuutusyhdistys"@fi .

