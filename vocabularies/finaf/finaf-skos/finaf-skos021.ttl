    rdaa:P50121 "1948" ;
    rdaa:P50291 "Czarniawska-Joerges" ;
    rdaa:P50292 "Barbara" ;
    rdaa:P50411 "Czarniawska-Joerges, Barbara, 1948-2024"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Barbara_Czarniawska'>Wikipedia</a>, katsottu 3.7.2025 (Barbara Czarniawska (2. joulukuuta 1948 Białystok - 7. huhtikuuta 2024 Göteborg) oli puolalais-ruotsalainen taloustieteen tohtori, ja Göteborgin yliopiston kauppakorkeakoulun yritystalouden professori.)"@fi,
        "Translating organizational change / edited by Barbara Czarniawska and Guje Sevón, 1996: sivu [273] (Barbara Czarniawska-Joerges holds the Chair in Management at Lund University, Sweden. Her research focuses on field studies of complex organizations, interorganizational management, the status of organizational knowledge and the connections between organization theory and fiction. She has published in the area of business and public administration in Polish, her native language, as well as in Swedish and English)"@fi ;
    skos:altLabel "Czarniawska, Barbara, 1948-2024"@fi,
        "Joerges, Barbara Czarniawska, 1948-2024"@fi,
        "Joerges, Barbara Czarniawska-, 1948-2024"@fi ;
    skos:hiddenLabel "Barbara Czarniawska"@fi,
        "Barbara Czarniawska Joerges"@fi,
        "Barbara Czarniawska- Joerges"@fi,
        "Barbara Czarniawska-Joerges"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Czarniawska-Joerges, Barbara, 1948-2024"@fi .

