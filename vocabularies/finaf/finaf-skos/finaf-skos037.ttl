finaf:000098408 a rdac:C10004,
        skos:Concept ;
    dct:created "1999-10-20"^^xsd:date ;
    dct:modified "2023-04-20T12:29:04"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000000685653>,
        "Asteri ID: 000098408" ;
    rdaa:P50095 "Turun akatemia"@fi ;
    rdaa:P50100 yso:p3830,
        yso:p685 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/lat> ;
    rdaa:P50104 mts:m2479,
        mts:m3368 ;
    rdaa:P50113 "Turun katedraalikoulun konrehtori noin 1628, rehtori 1630. Turun lukion kreikan kielen apulaisopettaja. Viipurin triviaalikoulun rehtori 1633-1634. Turun lukion rehtori 1634-1635, alempi teologian lehtori 1636-1640, samalla palkkapitäjänsä Liedon kirkkoherra 1636. Turun tuomiokapitulin jäsen 1628-1630 ja 1636-1670. Turun akatemian kreikan ja heprean kielten professori 1640, kolmas teologian professori 1654, toinen 1658, ero 1660. Samalla palkkapitäjänsä Naantalin ja Raision kirkkoherra 1654-1676"@fi ;
    rdaa:P50118 yso:p94302 ;
    rdaa:P50119 yso:p94447 ;
    rdaa:P50120 "1676" ;
    rdaa:P50121 "1590" ;
    rdaa:P50291 "Stodius" ;
