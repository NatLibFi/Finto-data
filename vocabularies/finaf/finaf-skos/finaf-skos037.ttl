    rdaa:P50346 yso:p106813 ;
    rdaa:P50411 "Brevikius, Andreas Petri, toiminta-aika 1633-1642"@fi ;
    rdau:P61101 "<a href='https://ylioppilasmatrikkeli.fi/henkilo.php?id=103'>Ylioppilasmatrikkeli</a>, katsottu 31.12.2025 (sl. 1640 Anders Brevichius Andreas Petri, Vermlandus ... Luultavasti talollisen poika Värmlannin Nyn pitäjän Brevikistä. Karlstadin koulun oppilas 1633 – 1635. Kirjoitti kouluaikana Karlstadissa viisi oraatiota. Ylioppilas Uppsalassa 27.5.1637 Andreas Petri Wermelandus. Ylioppilas Turussa sl. 1640 Brerikius‹¿› And. Petr. Vermel _ 7. — Mainitaan eräissä lähteissä maisteriksi, mutta mainintaa tukevia tietoja ei ole. — Oli ehdolla Turun akatemian filosofisen tiedekunnan apulaiseksi 1642, kuoli kotonaan Värmlannissa luultavasti pian sen jälkeen)"@fi ;
    skos:altLabel "Brerikius, Andr. Petr., toiminta-aika 1633-1642"@fi,
        "Brevichius, Anders, toiminta-aika 1633-1642"@fi,
