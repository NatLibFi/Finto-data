        "Asteri ID: 000079632" ;
    rdaa:P50097 yso:p104968 ;
    rdaa:P50100 yso:p17889 ;
    rdaa:P50103 "E. S. (Eugène Sue), 1804-1857"@fi,
        "Si, Eiz', 1804-1857"@fi,
        "Siu, Evgenii, 1804-1857"@fi,
        "Siw, Ēōžēn, 1804-1857"@fi,
        "Su, Ujen, 1804-1857"@fi,
        "Sue, Joseph-Marie, 1804-1857"@fi,
        "Sue, Marie-Joseph, 1804-1857"@fi,
        "Syu, Eyzshen, 1804-1857"@fi ;
    rdaa:P50104 mts:m3004 ;
    rdaa:P50113 "Ranskalainen välskäri ja kirjailija. Palkittiin vuonna 1839 kirjallisista ansioistaan Légion d'honneurin kunniamerkillä, mutta käännyttyään vuoden 1842 tienolla sosialismiin kiinnostui politiikasta ja tuli valituksi huhtikuussa 1850 Seinen departementin edustajana Ranska toisen tasavallan parlamenttiin. Louis-Napoléon Bonaparten kaapattua vallan joutui pakenemaan maasta jo seuraavana vuonna."@fi ;
    rdaa:P50118 "Annecy-le-Vieux, Ranska (Sardinian kuningaskunta)"@fi ;
    rdaa:P50119 yso:p104996 ;
