    rdaa:P50291 "Pesola" ;
    rdaa:P50292 "Vilho A." ;
    rdaa:P50411 "Pesola, Vilho A., 1892-1983"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Vilho_A._Pesola'>Wikipedia</a>, katsottu 16.12.2022 (Vilho Aleksanteri Pesola (20. marraskuuta 1892 Turku[1] – 31. joulukuuta 1983) oli suomalainen kasvinjalostaja. Hän oli Maatalouden tutkimuskeskuksen kasvinjalostuslaitoksen johtaja ja professori 1930–1960. Hän kehitti useita jalosteita, muun muassa rukiin, vehnän ja herneen. Hänet tunnettiin myös toiminnastaan järjestötoiminnassa, erityisesti nuorisoseuraliikkeen johtotehtävissä.)"@fi ;
    skos:altLabel "Pesola, V. A., 1892-1983"@fi ;
    skos:closeMatch <http://urn.fi/urn:nbn:fi:sks-kbg-004750> ;
