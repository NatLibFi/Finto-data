    rdaa:P50025 "Finland. Flygkrigsskolan"@fi,
        "Finland. Flygvapnet. Flygkrigsskolan"@fi,
        "Flygkrigsskolan"@fi,
        "Flygvapnet. Flygkrigsskolan"@fi,
