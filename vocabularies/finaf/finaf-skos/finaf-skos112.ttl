        "dubbausohjaajana produktiossa"@fi ;
    rdakit:hasElementType "2" ;
    rdakit:instructionNumber "18.5" ;
    rdakit:toolkitDefinition "An expression that includes a contribution by an agent of responsibility for the general management and supervision of the process of adding new dialogue or other sounds to complete a soundtrack."@en,
        "Teoksen ekspressio, joka sisältää vastuun uuden dialogin tai muiden äänien lisäämisprosessista ja sen valvonnasta ääniraidan täydentämiseksi."@fi ;
