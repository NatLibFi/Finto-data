    rdaa:P50035 "Lapin Kullankaivajain Liitto perustettiin 18. syyskuuta 1949 keskellГӨ Lemmenjoen kultaryntГӨystГӨ. Alkuvuosina liiton tavoitteena oli luoda kultamaille kerГӨГӨntyneestГӨ mieslaumasta sosiaalinen, jГӨrjestГӨytynyt ja toimiva yhteisГ¶, jonka arkeen ja tyГ¶oloihin pyrittiin kehittГӨmГӨГӨn parannuksia mm. liikenneyhteyksiГӨ ja tavaran- ja postinkulkua kehittГӨmГӨllГӨ."@fi ;
    rdaa:P50037 "1949" ;
    rdaa:P50237 mts:m401 ;
    rdaa:P50350 yso:p105976 ;
    rdaa:P50407 "Lapin kullankaivajain liitto"@fi ;
    rdau:P61101 "<a href='https://www.kullankaivajat.fi/'>Verkkosivut</a>, katsottu 21.9.2018"@fi ;
    skos:altLabel "LKL (Lapin kullankaivajain liitto)"@fi,
        "Lapin kullankaivajien liitto"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Lapin kullankaivajain liitto"@fi .

