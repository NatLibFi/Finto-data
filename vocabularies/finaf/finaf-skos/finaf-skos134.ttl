    rdaa:P50025 "LГӨse-bibliotheket i Wasa"@fi ;
    rdaa:P50035 "2.8.1794 perustettu Vaasan lukuseura oli ensimmГӨinen lukukirjastoja yllГӨpitГӨvistГӨ lukuseuroista Suomessa. Aluksi 17 vaasalaisen virkamiehen perustama, alkuunpanijana hovioikeudenneuvos Olof Langenstein. Lukuseuran kirjastoa voidaan pitГӨГӨ myГ¶s ensimmГӨisenГӨ yleisenГӨ kirjastona, sillГӨ seura salli kaupungin asukkaiden kГӨyttГӨГӨ kirjastoa maksua vastaan, eli se toimi lainakirjastona. Kirjasto lakkautettiin vuonna 1845."@fi ;
    rdaa:P50237 "kirjasto"@fi ;
    rdaa:P50350 yso:p94466 ;
    rdaa:P50407 "Vaasan luku-kirjasto"@fi ;
    rdau:P61101 "Г–hman, Berit. Vaasan Luku-Kirjasto 1794-1845, teoksessa Vaasan Luku-Kirjasto 1794-1845, 1995."@fi ;
    skos:altLabel "LГӨse-bibliotheket i Wasa"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Vaasan luku-kirjasto"@fi .

