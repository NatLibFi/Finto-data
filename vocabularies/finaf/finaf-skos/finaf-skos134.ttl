    rdaa:P50025 "JM (Joensuun Mieslaulajat)"@fi,
        "Joensuun mieslaulajat"@fi ;
    rdaa:P50035 "Mieskuoron historia alkaa vuodesta 1908, jolloin perustettiin Joensuun Musiikkiyhdistys. Vuonna 1911 ko. yhdistyksen liittyi 19-henkinen mieskuoro. Vuonna 1928 musiikkiyhdistykseen perustettiin alaosasto Joensuun Musiikkiyhdistyksen Mieskuoro. Kuoro tunnetaan myГ¶s Katajan mieskuoro ja Joensuun mieskuoro -nimillГӨ. Helmikuussa 1947 kuoron nimeksi tuli Joensuun Mieslaulajat (lГӨhde: Kuoron kotisivut)."@fi ;
    rdaa:P50237 "kuoro"@fi,
        "mieskuoro"@fi ;
    rdaa:P50350 yso:p94166 ;
    rdaa:P50407 "Joensuun Mieslaulajat"@fi ;
    rdau:P61101 "<a href='http://joensuunmieslaulajat.fi/historia/'>Kuoron kotisivut</a>, katsottu 1.3.2017"@fi ;
    skos:altLabel "JM (Joensuun Mieslaulajat)"@fi,
        "Joensuun mieslaulajat"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Joensuun Mieslaulajat"@fi .

