finaf:000015374 a rdac:C10005,
        skos:Concept ;
    dct:created "1998-09-29"^^xsd:date ;
    dct:modified "2020-11-05T20:09:36"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000474477346>,
        "Asteri ID: 000015374" ;
    rdaa:P50237 mts:m4990 ;
    rdaa:P50393 "Valtio osti HyvinkГӨГӨn tehtaan Oy:n 10.3.1920. Kieltolain kumouduttua vuonna 1932 vahvitettiin 11.2 Oy Alkoholiliike Ab:n yhtiГ¶jГӨrjestys. Vuonna 1935 valmistui ensimmГӨinen oma polttimo RajamГӨelle, toinen vuonna 1936 Ensoon ja Koskenkorvan tehtaan rakentaminen aloitettiin 1939. Koskenkorvan uuden polttimon vihkiГӨisjuhla 23.5.1973, RajamГӨen uusi alkoholijuomatehdas valmistui maaliskuussa 1975 ja Koskenkorvan uusi etanolitГӨrkkelystehdas vihittiin 22.10.1987. Vuoden 1995 alkoholilain yhteydessГӨ syntyi Primalco Oy, joka vastaa Alko-YhtiГ¶t Oy:n teollisuustoiminnasta. Vuodesta 1997 lГӨhtien alkoholijuomia valmistetaan ainoastaan RajamГӨellГӨ. LГӨhde: RajamГӨen tehtaat / Leena Jokimaa, 1996"@fi ;
    rdaa:P50407 "Primalco. RajamГӨen tehtaat"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Primalco. RajamГӨen tehtaat"@fi .

