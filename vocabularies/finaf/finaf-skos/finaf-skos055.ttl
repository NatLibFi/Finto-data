        "Tohtori Faust (myyttinen hahmo)"@fi ;
    skos:hiddenLabel "Johann Faust"@fi,
        "Johannes Faust"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Faust (myyttinen hahmo)"@fi .

