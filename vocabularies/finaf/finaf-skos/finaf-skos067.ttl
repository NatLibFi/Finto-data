    rdaa:P50121 "1917" ;
    rdaa:P50291 "Sihvola" ;
    rdaa:P50292 "Holger" ;
    rdaa:P50411 "Sihvola, Holger, 1917-1996"@fi ;
    rdau:P61101 "<a href='http://www.mediapinta.fi/isbn/978-952-235-425-9'>Mediapinta</a>, katsottu 22.8.2019 (Holger Sihvola syntyi Tuusulassa vuonna 1917. Vuonna 1949 hän suoritti Sibelius-Akatemiassa diplomitutkinnot kapellimestarin, kuoron ja teoria-aineiden linjoilla. Jo samana vuonna hänet valittiin kapellimestariksi Rovalaan, josta alkoi hänen vuosikymmeniä kestänyt musiikkiuransa Lapissa. Pääsoittimensa viulun lisäksi Sihvola soitti itse eri instrumentteja ja opetti musiikkiopistojen oppilaita, yksityisoppilaita ja kokonaisia koululuokkia. Lisäksi hänen merkityksensä oli huomattava maakunnan useiden orkesterien, kuorojen ja soittokuntien perustajana ja johtajana sekä tuotteliaana säveltäjänä.)"@fi,
        "<a href='https://www.geni.com/people/Holger-Sihvola/6000000016173525872'>Geni</a>, katsottu 22.8.2019 (elinvuodet)"@fi,
        "Lapin lumoissa, 2012: t.p. (Holger Sihvolan)"@fi ;
    skos:hiddenLabel "Holger Sihvola" ;
    skos:inScheme finaf: ;
    skos:prefLabel "Sihvola, Holger, 1917-1996"@fi .

