    rdaa:P50291 "Sihvola" ;
    rdaa:P50292 "Holger" ;
    rdaa:P50411 "Sihvola, Holger, 1917-1996"@fi ;
    rdau:P61101 "<a href='http://www.mediapinta.fi/isbn/978-952-235-425-9'>Mediapinta</a>, katsottu 22.8.2019 (Holger Sihvola syntyi Tuusulassa vuonna 1917. Vuonna 1949 hûÊn suoritti Sibelius-Akatemiassa diplomitutkinnot kapellimestarin, kuoron ja teoria-aineiden linjoilla. Jo samana vuonna hûÊnet valittiin kapellimestariksi Rovalaan, josta alkoi hûÊnen vuosikymmeniûÊ kestûÊnyt musiikkiuransa Lapissa. PûÊûÊsoittimensa viulun lisûÊksi Sihvola soitti itse eri instrumentteja ja opetti musiikkiopistojen oppilaita, yksityisoppilaita ja kokonaisia koululuokkia. LisûÊksi hûÊnen merkityksensûÊ oli huomattava maakunnan useiden orkesterien, kuorojen ja soittokuntien perustajana ja johtajana sekûÊ tuotteliaana sûÊveltûÊjûÊnûÊ.)"@fi,
        "<a href='https://www.geni.com/people/Holger-Sihvola/6000000016173525872'>Geni</a>, katsottu 22.8.2019 (elinvuodet)"@fi,
        "Lapin lumoissa, 2012: t.p. (Holger Sihvolan)"@fi ;
    skos:hiddenLabel "Holger Sihvola"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Sihvola, Holger, 1917-1996"@fi .

