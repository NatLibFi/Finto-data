    rdaa:P50104 mts:m2441,
        mts:m2666,
        mts:m2919 ;
    rdaa:P50109 yso:p104996,
        "Pont-à-Mousson, Ranska"@fi ;
    rdaa:P50113 "Ranskalainen, Pariisissa (1606-1669 ) ja Pont-à-Moussonissa (1621-1627) toiminut kirjanpainaja ja kustantaja sekä kirjastonhoitaja. Oppipoikana äidinisällään Sébastien Nivellellä (1525-1603). Johti Compagnie de la Grand-Navire -järjestöä ja oli myös Compagnie des usages -järjestön jäsen. Hoiti useita hallinnollisia tehtäviä kruunun ja kaupungin palveluksessa. Teki yhteistyötä veljensä Gabrielin kanssa vuosina 1629-1658."@fi ;
    rdaa:P50118 yso:p104996 ;
