        mts:m3237 ;
    rdaa:P50109 yso:p123962,
        yso:p234581,
        "Geneve, Sveitsi"@fi ;
    rdaa:P50113 "Ranskalainen, Lyonissa (1533-1572), Genevessä (1559-1564) ja Baselissa (1561-1568) toiminut kirjanpainaja, kustantaja, kirjakauppias ja Lyonin kaupunginkonsuli. Pidätettiin Lyonissa kalvistisuutensa tähden vuonna 1567, seuraavan vuonna hänen omaisuutensa takavarikoitiin. Lyonin Compagnie des libraires -yhdistyksen jäsen. Geneven-vuosien aikana Lyonissa liiketoimia hoiti esikoispoika Barthélemy. Baselin haarakonttori oli toisen pojan, Antoine nuoremman vastuulla."@fi ;
    rdaa:P50120 "1568" ;
    rdaa:P50121 "1500~" ;
