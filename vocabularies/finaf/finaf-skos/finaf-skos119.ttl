        "Långa lappflickan, 1819-1854"@fi,
        "Stina Kajsa, 1819-1854"@fi,
        "Tall Laponia Girl, 1819-1854"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Stor-Stina, 1819-1854"@fi .

