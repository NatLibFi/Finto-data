    rdaa:P50100 yso:p17341 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/fra>,
        <http://lexvo.org/id/iso639-3/lat> ;
    rdaa:P50103 "Iosset, Hélie, noin 1636-noin 1711"@fi,
        "Josset, Helias, noin 1636-noin 1711"@fi,
        "Josset, Hélie, noin 1636-noin 1711"@fi ;
    rdaa:P50104 mts:m2437,
        mts:m2441 ;
    rdaa:P50109 yso:p104996 ;
    rdaa:P50113 "Ranskalainen, Pariisissa vuosina 1660-1711 toiminut kirjanpainaja ja kirjakauppias. Oppipoikana vuodesta 1646 alkaen Jean Pilléllä ja vuodesta 1650 Nicolas Portier'lla. Oma kirjakauppa vuodesta 1660 ja kirjapaino vuodesta 1686. Leski Jeanne os. Pulliot myi yrityksen vuonna 1711 vävylleen Louis'lle ja Charles [I] Robustelille. Nämä ja vielä seuraavakin sukupolvi (Jean-François Josse & Charles-Jean-Baptiste Delespine) käyttivät usein Élie Josset'n nimeä julkaisuissaan ainakin vuoteen 1740 saakka."@fi ;
    rdaa:P50120 "1711~" ;
    rdaa:P50121 "1636~" ;
    rdaa:P50291 "Josset" ;
    rdaa:P50292 "Élie" ;
    rdaa:P50411 "Josset, Élie, noin 1636-noin 1711"@fi ;
