    rdaa:P50103 "Ribov, Iean, 1630-1702"@fi ;
    rdaa:P50104 mts:m2437,
        mts:m2441,
        mts:m2666 ;
    rdaa:P50109 yso:p104996 ;
    rdaa:P50113 "Ranskalainen, Pariisissa vuosina 1653-1700 toiminut kirjanpainaja, kustantaja ja kirjakauppias. Oppipoikana vuodesta 1647 Antoine [I] Robinot'lla, mestarinarvo vuonna 1653. Vangittiin Denis Davidin kanssa vuonna 1669 kiellettyjen kirjojen kaupasta. Tuomittiin kuolemaan, mutta rangaistus lievennettiin viiden vuoden karkotukseksi. Armahdettiin toukokuussa 1672, mutta vangittiin uudestaan jo maaliskuussa 1683. Nimeä käyttivät useat näytelmäkirjailijat (Claude Galbit, Daniel Gayet, Antoine Laurens ja Laurent Metton) pseudonyyminä vuosina 1661-1676 todellisuudessa Lyonissa Antoine Beaujolin kirjapainossa tuotetuissa julkaisuissa."@fi ;
    rdaa:P50120 "1702" ;
    rdaa:P50121 "1630" ;
    rdaa:P50291 "Ribou" ;
    rdaa:P50292 "Jean" ;
    rdaa:P50411 "Ribou, Jean, 1630-1702"@fi ;
    rdau:P61101 "<a href='https://catalogue.bnf.fr/ark:/12148/cb122299403'>BnF</a>, katsottu 16.10.2024 (Ribou, Jean)"@fi,
        "<a href='https://d-nb.info/gnd/1037547853'>DNB</a>, katsottu 16.10.2024 (Ribou, Jean)"@fi,
        "<a href='https://lccn.loc.gov/no2010031899'>LCNAF</a>, katsottu 16.10.2024 (Ribou, Jean)"@fi ;
    skos:altLabel "Ribov, Iean, 1630-1702"@fi ;
    skos:hiddenLabel "Iean Ribov"@fi,
        "Jean Ribou"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Ribou, Jean, 1630-1702"@fi .

