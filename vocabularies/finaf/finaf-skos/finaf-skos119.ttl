    rdaa:P50109 yso:p104996 ;
    rdaa:P50113 "Ranskalainen, Pariisissa vuosina 1717-1764 toiminut kirjanpainaja ja kirjakauppias. Oppipoikana vuosina 1699-1703 enonsa Michel Guignardin luona. Oma kirjakauppa vuodesta 1717 ja kirjapaino vuodesta 1739. Vuodesta 1747 työskenteli yhdessä vävynsä Nicolas-Franc̜ois Moreaun kanssa. Leski Marie-Anne os. Berruyer jatkoi toimintaa vuoteen 1770 asti."@fi ;
    rdaa:P50120 "1764" ;
    rdaa:P50121 "1687~" ;
