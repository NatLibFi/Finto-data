    rdaa:P50104 mts:m2437,
        mts:m2441 ;
    rdaa:P50109 yso:p104996,
        yso:p123962 ;
    rdaa:P50113 "Ranskalainen, Lyonissa (1672-1691) ja Pariisissa (1691-1707) toiminut kirjanpainaja. Teki yhteistyötä lankonsa Claude Rigaud'n kanssa, jonka hyväksi luopui kuninkaallisen kirjapainon johtajan tehtävästä. Yhteistyökumppaneina Lyonissa myös veli Jacques Anisson sekä toinen lanko Jean Posuel. Osallistui teknisenä neuvonantajana vuodesta 1675 alkaen kuninkaan tiedeakatemialta tilaamaan tutkimukseen (Jaugeon-komitea)."@fi ;
    rdaa:P50120 "1721" ;
    rdaa:P50121 "1642" ;
    rdaa:P50291 "Anisson" ;
