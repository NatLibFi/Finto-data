    rdaa:P50103 "Rigaud, Claudius, 1583-noin 1628"@fi ;
    rdaa:P50104 mts:m2437 ;
    rdaa:P50109 yso:p104996,
        yso:p123962 ;
    rdaa:P50113 "Ranskalainen, Pariisissa (1606-1625) ja Lyonissa (1597-1602 ja 1625-1627) toiminut kirjakauppias. Pierre [I] ja Simon Rigaud'n veli. Pierren ja Clauden yhteinen yritys toimi vuosina 1597-1601 nimellä \"Héritiers de Benoît Rigaud\". Teki vuosina 1622-1627 yhteistyötä Claude Obertin kanssa. Leski Marguerite os. Noubart (tai Niobert) jatkoi toimintaa vuoteen 1647 saakka."@fi ;
    rdaa:P50120 "1628~" ;
    rdaa:P50121 "1583" ;
