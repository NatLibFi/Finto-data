        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Troil, M. de (Uno), 1746-1803"@fi,
        "Troilius, Uno, 1746-1803"@fi,
        "Troilus, Uno von, 1746-1803"@fi,
        "Trulsson, Uno, 1746-1803"@fi,
        "Von Troil, Uno, 1746-1803"@fi ;
    rdaa:P50104 mts:m2479,
        mts:m2816,
        mts:m2901 ;
    rdaa:P50109 yso:p106813 ;
    rdaa:P50113 "Ruotsalainen luterilainen pappi. Matkusteli Euroopassa vuodesta 1770 alkaen, kävi vuonna 1772 myös Islannissa, josta julkaisemansa kuvaus käännettiin tuoreeltaan useille kielille. Vihittiin papiksi vuonna 1773. Rykmentinpastori 1773, hovisaarnaaja 1775, ylihovisaarnaaja 1777, Linköpingin piispa 1780, Uppsalan arkkipiispa 1786. Osallistui valtiopäiville vuonna 1786. Rojalistina hän oli epäluotettava, vältteli tukemasta kuninkaanvaltaa tukevia lakeja. Kuitenkin hän arkkipiispana oli läsnä Kustaa III:n kuollessa ja kruunasi tämän seuraajan Kustaa IV Aadolfin."@fi ;
    rdaa:P50118 "Sätra Brunn, Ruotsi"@fi ;
    rdaa:P50119 yso:p105464 ;
    rdaa:P50120 "1803" ;
    rdaa:P50121 "1746" ;
    rdaa:P50291 "Troil" ;
    rdaa:P50292 "Uno von" ;
    rdaa:P50411 "Troil, Uno von, 1746-1803"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Uno_von_Troil'>Wikipedia</a>, katsottu 13.3.2026 (Uno von Troil)"@fi,
        "Vallinkoski, Jorma. Turun akatemian väitöskirjat 1642-1828. II"@fi ;
    skos:altLabel "Troil, M. de (Uno), 1746-1803"@fi,
