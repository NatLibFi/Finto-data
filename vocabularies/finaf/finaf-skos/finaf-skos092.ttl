finaf:000033043 a rdac:C10005,
        skos:Concept ;
    dct:created "1993-10-26"^^xsd:date ;
    dct:modified "2020-12-03T20:11:53"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000492948199>,
        "Asteri ID: 000033043" ;
    rdaa:P50012 finaf:000033042,
        finaf:000033044,
        finaf:000033045,
        finaf:000033046 ;
    rdaa:P50025 "Äänekoski (kaupunki)"@fi ;
    rdaa:P50035 "Äänekosken kunta perustettiin vuonna 1911 erottamalla Laukaan kunnan pohjoinen osa sekä itäisiä osia Saarijärven kunnasta omaksi kunnakseen. Vuonna 1932 Äänekosken kunta jaettiin Äänekosken ja Suolahden kauppaloiksi sekä Äänekosken maalaiskunnaksi. Maalaiskunta liitettiin Äänekosken kauppalaan vuonna 1969. Kaupunginoikeudet Äänekoskelle myönnettiin vuonna 1973, ja vuonna 1993 kaupunkiin liitettiin Konginkankaan kunta. Vuonna 2007 liitettiin Suolahti ja Sumiainen"@fi ;
    rdaa:P50236 "1973/.."^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50238 mts:m358 ;
    rdaa:P50407 "Äänekosken kaupunki"@fi ;
    skos:altLabel "Äänekoski (kaupunki)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Äänekosken kaupunki"@fi .

