finaf:000009366 a rdac:C10005,
        skos:Concept ;
    dct:created "1992-10-27"^^xsd:date ;
    dct:modified "2025-10-06T15:26:01"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000095638293>,
        "Asteri ID: 000009366" ;
    rdaa:P50012 finaf:000000911 ;
    rdaa:P50025 "Faculty of Arts (Helsingin yliopisto)"@fi,
        "Helsingin yliopisto. Faculty of Arts"@fi,
        "Helsingin yliopisto. Humanistiska fakulteten"@fi,
        "Helsingin yliopiston humanistinen tiedekunta"@fi,
        "Humanistinen tiedekunta (Helsingin yliopisto)"@fi,
        "Humanistiska fakulteten (Helsingfors universitet)"@fi ;
    rdaa:P50035 "Humanistisen tiedekunnan juuret ovat vanhassa filosofisessa tiedekunnassa, joka oli yksi vuonna 1640 perustetun Turun Akatemian neljästä kantatiedekunnasta. Tiedekunta jaettiin 1852 kahteen osastoon, historiallis-kielitieteelliseen osastoon ja fyysis-matemaattiseen (myöhemmin matemaattis-luonnontieteelliseen) osastoon. 1992 vanha filosofinen tiedekunta lakkautettiin ja sen osastoista tuli itsenäisiä tiedekuntia, jolloin historiallis-kielitieteellinen osasto muuttui humanistiseksi tiedekunnaksi."@fi ;
    rdaa:P50119 yso:p94137 ;
    rdaa:P50236 "1992/.."^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m4751 ;
    rdaa:P50407 "Helsingin yliopisto. Humanistinen tiedekunta"@fi ;
    rdau:P61101 "<a href='https://www.helsinki.fi/fi/humanistinen-tiedekunta'>Verkkosivut 9.4.2018</a>"@fi ;
    skos:altLabel "Faculty of Arts (Helsingin yliopisto)"@fi,
        "Helsingin yliopisto. Faculty of Arts"@fi,
        "Helsingin yliopisto. Humanistiska fakulteten"@fi,
        "Helsingin yliopiston humanistinen tiedekunta"@fi,
        "Humanistinen tiedekunta (Helsingin yliopisto)"@fi,
        "Humanistiska fakulteten (Helsingfors universitet)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Helsingin yliopisto. Humanistinen tiedekunta"@fi .

