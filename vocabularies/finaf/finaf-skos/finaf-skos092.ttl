finaf:000018327 a rdac:C10005,
        skos:Concept ;
    dct:created "2002-05-13"^^xsd:date ;
    dct:modified "2021-06-18T19:06:25"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000018327" ;
    rdaa:P50012 finaf:000018324,
        finaf:000018325,
        finaf:000018326 ;
    rdaa:P50016 finaf:000026030 ;
    rdaa:P50237 "yhdistys"@fi ;
    rdaa:P50393 "Suomen autoilijaliiton Mikkelin osasto perustettiin 10.10.1926. - Sittemmin nimi muutettiin Henkilö- ja kuorma-autoilijain Mikkelin osastoksi. Seuraavaksi vuokra-autoiolijat ja kuorma-autoilijat liittyivät erikseen omiin ammattiliiitoihinsa, jonka johdosta kuorma-autoilijat rekisteröityivät yhdistysrekisteriin 12.3.1958 nimellä Mikkelin kuorma-autoilijat r.y. 15.1.1991 pidettiin Mikkelin kuorma-autoilijat ry:n ja Mikkelin seudun ammattiautoilijat ry:n yhteiskokous, jonka seurauksena yhdistykset yhdistettiin niin että Mikkelin seudun ammattiautoilijat ry lakkautettiin ja sen jäsenet liittyivät Mikkelin kuorma-autoilijat ry:hyn. Uudeksi nimeksi otettiin Mikkelin alueen kuorma-autoilijat"@fi ;
    rdaa:P50407 "Mikkelin alueen kuorma-autoilijat"@fi ;
    rdau:P61101 "Mikkelin alueen kuorma-autoilijat ry 75 vuotta : 1926-2001/ [toimittaja: Juhani Penttinen]. - Mikkeli, 2001"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Mikkelin alueen kuorma-autoilijat"@fi .

