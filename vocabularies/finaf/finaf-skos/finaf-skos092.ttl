finaf:000034962 a rdac:C10005,
        skos:Concept ;
    dct:created "1990-04-07"^^xsd:date ;
    dct:modified "2025-01-23T20:01:52"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000034962" ;
    rdaa:P50012 finaf:000034963 ;
    rdaa:P50013 finaf:000034964 ;
    rdaa:P50022 yso:p12732,
        yso:p2039 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/eng>,
        <http://lexvo.org/id/iso639-3/fin>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50025 "Finland. Folkhälsoinstitutet"@fi,
        "Finland. National Public Health Institute"@fi,
        "Finnland. Staatliches institut für gesundheit"@fi,
        "Folkhälsoinstitutet (Finland)"@fi,
        "KTL (Kansanterveyslaitos)"@fi,
        "NPHI (National Public Health Institute)"@fi,
        "National Public Health Institute (Finland)"@fi,
        "Sosiaali- ja terveysministeriö. Kansanterveyslaitos"@fi,
        "Staatliches institut für gesundheit (Finnland)"@fi,
        "Suomi. Kansanterveyslaitos"@fi ;
    rdaa:P50035 "Senaatin päätöksellä Lääkintöhallitus perusti 7.5.1911 väliaikaisen serologisen laboratorion, jossa valmistettiin rokotteita sekä harjoitettiin serologista tutkimus- ja opetustyötä. Toiminta vakinaistettiin vuonna 1915, jolloin laboratorion nimeksi tuli Valtion seerumlaboratorio. Oltuaan 1944–1947 yhdistettynä Helsingin yliopiston laitoksiin, laboratorio sai 1947 nimekseen Valtion serumlaitos. Laitos toimi lääkintöhallituksen alaisuudessa, mutta sen opetustoiminta jäi yliopistolle. Nimi vaihdettiin 1.3.1970 alkaen Kansanterveyslaboratorioksi, jonka tehtäväksi tuli toimia terveydenhoitolaitoksia palvelevana tutkimuslaitoksena ja asiantuntijavirastona. Siitä tehtiin edelleen 1982 Kansanterveyslaitos, jonka tehtäviin lisättiin yleinen väestön terveyden edistäminen ja terveysvalvonta. Vuoden 2009 alussa Stakes yhdistyi Kansanterveyslaitoksen kanssa. Uuden organisaation nimeksi tuli Terveyden ja hyvinvoinnin laitos (THL)"@fi ;
    rdaa:P50037 "1982" ;
    rdaa:P50038 "2008" ;
    rdaa:P50237 mts:m806 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Kansanterveyslaitos"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Kansanterveyslaitos'>Wikipedia</a>, katsottu 10.9.2012"@fi ;
    skos:altLabel "Finland. Folkhälsoinstitutet"@fi,
        "Finland. National Public Health Institute"@fi,
        "Finnland. Staatliches institut für gesundheit"@fi,
        "Folkhälsoinstitutet (Finland)"@fi,
        "KTL (Kansanterveyslaitos)"@fi,
        "NPHI (National Public Health Institute)"@fi,
        "National Public Health Institute (Finland)"@fi,
        "Sosiaali- ja terveysministeriö. Kansanterveyslaitos"@fi,
        "Staatliches institut für gesundheit (Finnland)"@fi,
        "Suomi. Kansanterveyslaitos"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Kansanterveyslaitos"@fi .

finaf:000014624 a rdac:C10005,
