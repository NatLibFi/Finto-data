finaf:000032278 a rdac:C10005,
        skos:Concept ;
    dct:created "2010-03-08"^^xsd:date ;
    dct:modified "2020-11-05T20:37:56"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000474600367>,
        "Asteri ID: 000032278" ;
    rdaa:P50025 "Frenckell, J. C. (yhtiö)"@fi,
        "J. C. Frenckell ja poika (yhtiö)"@fi ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50336 finaf:000028436,
        finaf:000028437,
        finaf:000032279,
        finaf:000032280,
        finaf:000174546,
        finaf:000174547 ;
    rdaa:P50393 "Yhtiöön kuului alunperin kirjapaino, kirjakauppa ja paperitehdas, myöhemmin myös muita toimialoja. Perustettu 1814 kun Johan Christopher Frenckell (1757-1818) otti poikansa Johan Christopher Frenckellin (1789-1844) yhtiökumppanikseen. Vuonna 1844 yhtiön johtaminen jaettiin kolmen pojan kesken: Johan Christopher Frenckell (1819-1856) hoiti Turun kirjapainoa ja -kauppaa, Frans Frenckell Tampereen paperitehdasta ja Reinhold Frenckell Helsingin kirjapainoa ja -kauppaa. 1856 Frans Frenckell lunasti yrityksen koko toiminnan itselleen. Vuonna 1900 Helsingin kirjapainosta muodostettiin oma osakeyhtiö ja J. C. Frenckell & sonin toiminta jatkui Tampereen paperitehtaassa. Paperitehdas myytiin Rosenlewille vuonna 1920, joka lakkautti sen 1929."@fi ;
    rdaa:P50407 "J. C. Frenckell & son (yhtiö)"@fi ;
    skos:altLabel "Frenckell, J. C. (yhtiö)"@fi,
        "J. C. Frenckell ja poika (yhtiö)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "J. C. Frenckell & son (yhtiö)"@fi .

