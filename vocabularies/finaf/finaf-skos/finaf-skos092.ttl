finaf:000030727 a rdac:C10005,
        skos:Concept ;
    dct:created "2011-07-08"^^xsd:date ;
    dct:modified "2021-06-19T15:01:16"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000030727" ;
    rdaa:P50012 finaf:000030724 ;
    rdaa:P50016 finaf:000030723,
        finaf:000030726,
        finaf:000039286 ;
    rdaa:P50035 "Koulun nimihistoria: Kuopion klassillinen lyseo 1940-1965, Kuopion klassillinen yhteislyseo 1965-1975, Puijonlaakson yläaste ja lukio 1975-1981, Kuopion klassillinen yläaste 1981-1994, Kuopion klassillinen lukio 1981-"@fi,
        "Kuopion klassillinen lyseo perustettiin 1940. Nimi vaihtui Kuopion klassilliseksi yhteislyseoksi 1965. Nimi vaihtui taas 1975 Puijonlaakson yläasteeksi ja lukioksi. Koulu toimi tällä nimellä aina vuoteen 1981, jolloin uudeksi nimeksi vahvistettiin Kuopion klassillinen koulu (peruskoulun yläaste) ja Kuopion klassillinen lukio. Vuonna 1994 kiinteästi koulun yhteydessä toiminut yläaste lakkautettiin, ja vuonna 1995 Kuopion yhteiskoulun lukio liitettiin osaksi Klassikkaa."@fi ;
    rdaa:P50237 "lukio"@fi,
        "yläkoulu"@fi ;
    rdaa:P50407 "Puijonlaakson yläaste ja lukio"@fi ;
    rdau:P61101 "Kuopion Klassikka 1940-2010, 2010"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Puijonlaakson yläaste ja lukio"@fi .

