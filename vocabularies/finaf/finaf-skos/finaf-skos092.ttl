    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Helsingin_yliopiston_maatalous-mets%C3%A4tieteellinen_tiedekunta'>Wikipedia</a>, katsottu 10.9.2025 (Helsingin yliopiston maatalous-metsätieteellinen tiedekunta on yksi Helsingin yliopiston 11:stä tiedekunnasta. Se on toimialallaan Suomen ainoa korkeinta yliopisto-opetusta tarjoava ja johtava koulutus- ja tutkimusyksikkö. Tiedekunta sijaitsee Viikin kampusalueella ... Vuonna 1924 maanviljelys-taloudellinen tiedekuntaosasto erotettiin filosofisesta tiedekunnasta, ja itsenäinen maatalous-metsätieteellinen tiedekunta aloitti toimintansa. ... Tiedekunnassa on nykyään (2023) kuusi osastoa. Elintarvike- ja ravitsemustieteiden osasto ... Maataloustieteiden osasto ... Metsätieteiden osasto ... Taloustieteen osasto ... Mikrobiologian osasto ... Ruralia-instituutti)"@fi,
        "<a href='https://www.helsinki.fi/fi/maatalous-metsatieteellinen-tiedekunta'>Yhteisön verkkosivut</a>, katsottu 2.4.2019"@fi ;
    skos:altLabel "Helsingin yliopisto. Agrikultur-forstvetenskapliga fakulteten"@fi,
        "Helsingin yliopisto. Faculty of Agriculture and Forestry"@fi,
        "Helsingin yliopiston maatalous-metsätieteellinen tiedekunta"@fi,
        "University of Helsinki. Faculty of Agriculture and Forestry"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Helsingin yliopisto. Maatalous-metsätieteellinen tiedekunta"@fi .

