finaf:000034964 a rdac:C10005,
        skos:Concept ;
    dct:created "2009-02-24"^^xsd:date ;
    dct:modified "2025-01-23T20:21:08"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000492950125>,
        "Asteri ID: 000034964",
        "Y-tunnus: 2229500-6" ;
    rdaa:P50022 yso:p12732,
        yso:p2039 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/eng>,
        <http://lexvo.org/id/iso639-3/fin>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50025 "Finland. Institutet för hälsa och välfärd"@fi,
        "Finland. National Institute for Health and Welfare"@fi,
        "Finnish Institute for Health and Welfare"@fi,
        "Institutet för hälsa och välfärd (Finland)"@fi,
        "Nacional'nyj institut zdravoohraneniâ i social'nogo blagosostoâniâ"@fi,
        "National Institute for Health and Welfare (Finland)"@fi,
        "Natsionalnyi institut zdravoohranenija i socialnogo blagosostojanija"@fi,
        "Sosiaali- ja terveysministeriö. Terveyden ja hyvinvoinnin laitos"@fi,
        "Suomi. Terveyden ja hyvinvoinnin laitos"@fi,
        "THL (Terveyden ja hyvinvoinnin laitos)"@fi,
        "Национальный институт здравоохранения и социального благосостояния"@fi ;
    rdaa:P50035 "Senaatin päätöksellä Lääkintöhallitus perusti 7.5.1911 väliaikaisen serologisen laboratorion, jossa valmistettiin rokotteita sekä harjoitettiin serologista tutkimus- ja opetustyötä. Toiminta vakinaistettiin vuonna 1915, jolloin laboratorion nimeksi tuli Valtion seerumlaboratorio. Oltuaan 1944–1947 yhdistettynä Helsingin yliopiston laitoksiin, laboratorio sai 1947 nimekseen Valtion serumlaitos. Laitos toimi lääkintöhallituksen alaisuudessa, mutta sen opetustoiminta jäi yliopistolle. Nimi vaihdettiin 1.3.1970 alkaen Kansanterveyslaboratorioksi, jonka tehtäväksi tuli toimia terveydenhoitolaitoksia palvelevana tutkimuslaitoksena ja asiantuntijavirastona. Siitä tehtiin edelleen 1982 Kansanterveyslaitos, jonka tehtäviin lisättiin yleinen väestön terveyden edistäminen ja terveysvalvonta. Vuoden 2009 alussa Stakes yhdistyi Kansanterveyslaitoksen kanssa. Uuden organisaation nimeksi tuli Terveyden ja hyvinvoinnin laitos (THL)."@fi,
        "Uusi englanninkielinen nimi Finnish Institute for Health and Welfare otettu käyttöön lokakuussa 2019."@fi ;
    rdaa:P50037 "2009" ;
    rdaa:P50232 finaf:000034962,
        finaf:000035111 ;
    rdaa:P50237 mts:m806 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Terveyden ja hyvinvoinnin laitos"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Terveyden_ja_hyvinvoinnin_laitos'>Wikipedia</a>, katsottu 10.9.2012"@fi,
        "<a href='https://thl.fi'>Yhteisön verkkosivut</a>, katsottu 19.12.2024"@fi,
        "Laitoksen raporttisarja, 2009-"@fi ;
    skos:altLabel "Finland. Institutet för hälsa och välfärd"@fi,
        "Finland. National Institute for Health and Welfare"@fi,
        "Finnish Institute for Health and Welfare"@fi,
        "Institutet för hälsa och välfärd (Finland)"@fi,
        "Nacional'nyj institut zdravoohraneniâ i social'nogo blagosostoâniâ"@fi,
        "National Institute for Health and Welfare (Finland)"@fi,
        "Natsionalnyi institut zdravoohranenija i socialnogo blagosostojanija"@fi,
