finaf:000032379 a rdac:C10005,
        skos:Concept ;
    dct:created "2007-02-28"^^xsd:date ;
    dct:modified "2025-01-23T18:54:19"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000032379" ;
    rdaa:P50016 finaf:000032380 ;
    rdaa:P50025 "Tuomiokirkkokoulu"@fi ;
    rdaa:P50035 "Turun katedraalikoulu eli Tuomiokirkkokoulu oli kirkon keskiajalla ylläpitämä koulu ja palveli lähinnä pappien koulutusta. Katedraalikoulu oli Suomen ensimmäinen koulu. Sen perustivat katoliset munkit 1200-luvulla, todennäköisesti vuonna 1276. Koulu muutettiin vuonna 1630 Turun kymnaasiksi, josta puolestaan tuli vuonna 1640 Turun akatemia. Akatemiaksi muuttamisen jälkeenkin kaupunkiin jäi silti yhä yliopistoon valmistava katedraalikoulu, josta alettiin vuonna 1641 käyttää triviaalikoulun nimeä. Vuonna 1830 koulu jaettiin ylempään alkeisoppilaitokseen ja lukioon, josta tuli uusi Turun kymnaasi, aina vuoteen 1872 saakka. Nykyisin koulun perinteitä jatkaa Katedralskolan i Åbo."@fi ;
    rdaa:P50237 mts:m4757 ;
    rdaa:P50350 yso:p94447 ;
    rdaa:P50407 "Turun katedraalikoulu"@fi ;
    rdau:P61101 "Laaksonen, Hannu. Alma mater Aboensis, 2006, (2006)"@fi ;
    skos:altLabel "Tuomiokirkkokoulu"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Turun katedraalikoulu"@fi .

