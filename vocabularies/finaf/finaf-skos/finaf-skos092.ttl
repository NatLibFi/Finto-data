    rdaa:P50237 "arkistolaitos"@fi ;
    rdaa:P50336 finaf:000032367,
        finaf:000034884 ;
    rdaa:P50393 "Kansallisarkisto ja maakunta-arkistot (7) muodostavat yhdessä arkistolaitoksen. Senaatin arkisto perustettiin v. 1816 ja avattiin yleisölle v. 1859. V. 1869 se sai nimekseen Valtionarkisto ja v. 1994 Kansallisarkisto. Koko maata kattava maakunta-arkistojen verkko luotiin 1920- ja 1930-luvuilla. Lähde: Kansallisarkisto : asiakkaan opas (1994)."@fi ;
    rdaa:P50407 "Arkistolaitos"@fi ;
    skos:altLabel "Finland. Arkivverket"@fi,
        "Opetus- ja kulttuuriministeriö. Arkistolaitos"@fi,
        "Suomi. Arkistolaitos"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Arkistolaitos"@fi .

