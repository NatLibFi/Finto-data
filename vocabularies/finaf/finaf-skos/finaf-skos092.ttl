    rdaa:P50025 "FRK (Finlands Röda Kors)"@fi,
        "Finlands Röda Kors"@fi,
        "Finnish Red Cross"@fi,
        "Punainen Risti (Suomi)"@fi,
        "Red Cross Finland"@fi,
        "Röda Korset (Finland)"@fi,
        "SPR (Suomen Punainen Risti)"@fi ;
    rdaa:P50035 "Suomessa Punaisen Ristin toiminta alkoi vuonna 1877, jolloin perustettiin Helsingissä \"Suomen yhdistys haavoitettujen ja sairaitten sotilaiden hoitoa varten\". - Toiminta keskittyi järjestöksi 12.11.1919. - Vuonna 1922 SPR hyväksyttiin jäseneksi Kansainväliseen Punaiseen Ristiin. - Jatkosodan aikana toimi uusi Suomen Huolto ry, jossa SPR oli vankoissa asemissa, mutta organisaatio poti sekavuutta. Vuonna 1942 nousi esiin ajatus, että SPR ja Mannerheim-liitto toimisivat viranomaistahoja täydentävänä kansanterveys- ja huoltojärjestönä. - Vuoden 1950 alussa SPR:n ja MLL:n yhteinen toimikunta ryhtyi selvittelemään järjestöjen suhdetta. Huhtikuussa MLL ilmoitti yhteistoiminnan siihenastisessa muodossa lakanneeksi ja järjestöt erosivat"@fi ;
    rdaa:P50236 "1919/.."^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m4657,
        mts:m4963 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Suomen Punainen Risti"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Suomen_Punainen_Risti'>Wikipedia</a>, katsottu 2.12.2020"@fi,
        "<a href='https://www.punainenristi.fi/'>Kotisivut</a>, katsottu 23.5.2018, tarkistettu 2.12.2020"@fi,
        "Viisi vuosikymmentä auttamisen tekoja : SPR:n Sauvo-Karunan osaston 50-vuotishistoria / Kari Hongisto. - Sauvo, 2001"@fi ;
    skos:altLabel "FRK (Finlands Röda Kors)"@fi,
        "Finlands Röda Kors"@fi,
        "Finnish Red Cross"@fi,
        "Punainen Risti (Suomi)"@fi,
        "Red Cross Finland"@fi,
        "Röda Korset (Finland)"@fi,
        "SPR (Suomen Punainen Risti)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Suomen Punainen Risti"@fi .

