rdac:C10013 a owl:Class ;
    rdfs:label "RDA entity"@en,
        "RDA-entiteetti"@fi ;
    rdakit:toolkitDefinition "An abstract class of key conceptual objects in the universe of human discourse that is a focus of interest to users of RDA metadata in a system for resource discovery."@en,
        "Inhimillisen diskurssin universumin keskeisten käsitteellisten objektien abstrakti luokka, joka on kirjaston tietojärjestelmissä olevan RDA-metatiedon käyttäjien kiinnostuksen kohde."@fi ;
    rdakit:toolkitLabel "RDA Entity"@en,
        "RDA-entiteetti"@fi ;
    reg:hasSubClass rdac:C10003,
        rdac:C10006,
        rdac:C10007,
        rdac:C10009,
        rdac:C10010,
        rdac:C10012 ;
    reg:lexicalAlias rdac:RDAEntiteetti.fi,
        rdac:RDAEntity.en ;
    reg:name "RDAEntity"@en,
        "RDAEntiteetti"@fi ;
    reg:status <http://metadataregistry.org/uri/RegStatus/1001> ;
    rdfs:isDefinedBy rdac: ;
    skos:definition "An abstract class of key conceptual objects in the universe of human discourse that is a focus of interest to users of RDA metadata in a system for resource discovery."@en,
        "Inhimillisen diskurssin universumin keskeisten käsitteellisten objektien abstrakti luokka, joka on kirjaston tietojärjestelmissä olevan RDA-metatiedon käyttäjien kiinnostuksen kohde."@fi ;
    skos:scopeNote "An RDA entity includes an agent, collective agent, corporate body, expression, family, item, manifestation, nomen, person, place, timespan, and work."@en,
        "RDA-entiteettiin sisältyvät aikajakso, ekspressio, henkilö, kappale, kollektiivinen toimija, manifestaatio, nomen, paikka, suku, teos, toimija, sekä yhteisö."@fi .

