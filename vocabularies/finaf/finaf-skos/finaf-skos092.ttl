    rdaa:P50012 finaf:000032835 ;
    rdaa:P50025 "Turku AMK"@fi,
        "Turku Polytechnic (1997-2005)"@fi,
        "Turku University of Applied Sciences"@fi,
        "Turun AMK"@fi,
