    rdaa:P50025 "Dallapé"@fi,
        "Dallapé-harmonikkaorkesteri"@fi ;
    rdaa:P50035 "”Harmonikkaorkesteri Dallapé” syntyi syksyllä 1925, kun Rajamäen pojat -nimisessä kisälliyhtyeessä Helsingissä vaikuttanut kolmikko Martti Jäppilä, Ville Alanko ja Mauno Johnsson sekä hieman myöhemmin mukaan tullut Erkki Majander perustivat tanssimusiikkia soittavan kokoonpanon. Dallapé levytti myös nimillä Rajamäen poikain orkesteri (1930), Masan Harmonikkaorkesteri (1938-1954) ja Sointu-orkesteri (1945-1946)."@fi ;
    rdaa:P50037 "1925" ;
    rdaa:P50237 mts:m400,
        "viihdeorkesteri"@fi ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Dallapé-orkesteri"@fi ;
    rdau:P61101 "<a href='http://pomus.net/001491'>Pomus.net</a>, katsottu 31.10.2017"@fi ;
    skos:altLabel "Dallapé"@fi,
        "Dallapé-harmonikkaorkesteri"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Dallapé-orkesteri"@fi .

