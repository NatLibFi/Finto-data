        "vaitoskirja"@fi ;
    reg:status <http://metadataregistry.org/uri/RegStatus/1001> ;
    rdfs:domain rdac:C10004 ;
    rdfs:isDefinedBy rdaa: ;
    rdfs:subPropertyOf rdaa:P50542 ;
    skos:definition "Relates a person to a thesis provided by the praeses in an academic disputation that is defended or opposed by a candidate for a degree."@en,
        "Liittää oppiarvoa tavoittelevan, puolustavan tai opponoivan kandidaatin väitöskirjaan, jonka preeses esittelee akateemisessa väitöstilaisuudessa."@fi .

rdaa:P50002 a rdf:Property ;
    rdfs:label "is appellee corporate body of"@en,
        "yhteisöön kohdistuva muutoshakemus"@fi ;
    rdakit:hasElementType "2" ;
    rdakit:instructionNumber "18.5" ;
    rdakit:toolkitDefinition "A legal work of a higher court that records a decision of a lower court that appeals against a corporate body."@en,
