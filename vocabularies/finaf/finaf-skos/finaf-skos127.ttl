finaf:000236823 a rdac:C10004,
        skos:Concept ;
    dct:created "2026-06-12"^^xsd:date ;
    dct:modified "2026-06-15T04:06:53"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000530435651>,
        "Asteri ID: 000236823" ;
    rdaa:P50097 yso:p94383 ;
    rdaa:P50100 yso:p3884,
        yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Stenbock, Måns, 1763-1822"@fi ;
    rdaa:P50104 mts:m2816,
        mts:m5089 ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen upseeri. Aloitti sotilasuransa jo lapsena. Vuonna 1781 hänestä tuli Itä-Göötanmaan ratsuväkirykmentin esikuntaluutnantti, vuotta myöhemmin kamariherra ja henkivartioston kapteeni. Vuonna 1783 hänet ylennettiin eversti-kamariherraksi ja vuonna 1793 everstiluutnantiksi. Seuraavana vuonna hän sai nimityksen Kuninkaallisen Majesteetin ritarikunnan yliupseeriksi ja Pohjantähden ritarikunnan komentajaksi. Vuonna 1796 hänet lähetettiin Tanskan hoviin ilmoittamaan kuningas Kustaa IV Adolfin liittymisestä kuninkaalliseen hoviin saman vuoden marraskuussa. Hänet nimitettiin Miekkaritarikunnan ritariksi vuonna 1800. Vuonna 1806 hänet nimitettiin everstiksi ja kenraaliadjutantiksi. Valtakunnanmarsalkka Axel von Fersenin salamurhan jälkeen vuonna 1810 hänet nimitettiin vt. valtakunnanmarsalkaksi, kunnes vakituinen marsalkka voitiin nimittää. Tämän vt. nimityksen jälkeen hänet nimitettiin kenraalimajuriksi vuonna 1816."@fi ;
    rdaa:P50118 yso:p234959 ;
    rdaa:P50119 "Rånäs, Ruotsi"@fi ;
    rdaa:P50120 "1822" ;
    rdaa:P50121 "1763" ;
    rdaa:P50291 "Stenbock" ;
    rdaa:P50292 "Magnus" ;
    rdaa:P50411 "Stenbock, Magnus, 1763-1822"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Magnus_Stenbock_(1763%E2%80%931822)'>Wikipedia</a>, katsottu 12.6.2026 (Magnus Stenbock)"@fi ;
