    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Gyllenstierna af Björksund och Helgö, Göran Nilsson, 1724-1799"@fi,
        "Gyllenstierna, Jöran, 1724-1799"@fi ;
    rdaa:P50104 mts:m2773,
        mts:m2890,
        mts:m3193 ;
    rdaa:P50109 yso:p105464 ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen. Lundissa ja Uppsalassa suoritettujen opintojensa jälkeen vuonna 1742 ilmoittautui auskultantiksi Svean hovioikeuteen, nimitettiin kamariherraksi samana vuonna. Vuonna 1750 hänestä tuli laamanni Närkeen, ja vuonna 1759 Södermanlantiin. Vuonna 1762 sai maaherran arvon, ja tuli valituksi vuoden 1765-1766 valtiopäiville. Myssypuolueen kannattajana menetti asemansa vuonna 1769. Keväällä 1772 kieltäytyi kutsusta takaisin neuvostoon. Vuonna 1781 Kustaa III suostutteli hänet ottamaan vastaan valtakunnanmarsalkan sauvan. Vuonna 1787 kuningas tarjosi hänelle prinssin arvonimeä, mutta hän luopui julkisesta elämästä vuonna 1788."@fi ;
    rdaa:P50118 yso:p110922 ;
    rdaa:P50120 "1799" ;
    rdaa:P50121 "1724" ;
    rdaa:P50291 "Gyllenstierna" ;
    rdaa:P50292 "Göran" ;
    rdaa:P50346 yso:p106813,
        yso:p167868 ;
    rdaa:P50411 "Gyllenstierna, Göran, 1724-1799"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/G%C3%B6ran_Gyllenstierna_(riksmarskalk)'>Wikipedia</a>, katsottu 8.6.2026 (Göran Gyllenstierna (riksmarskalk))"@fi ;
