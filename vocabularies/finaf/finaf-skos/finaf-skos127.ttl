    rdaa:P50103 "Bielke, Nicolaus Adamus, 1724-1792"@fi,
        "Bielke, Nils, 1724-1792"@fi ;
    rdaa:P50104 mts:m2773,
        mts:m2780,
        mts:m2816 ;
    rdaa:P50109 yso:p105464,
        "Nyköping, Ruotsi"@fi ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen valtiopäivämies, hattupuolueen kannattaja. Läheinen suhde kuningasperheen kanssa edisti etenemistä virkauralla. Vuonna 1761 hänet nimitettiin maaherraksi Nyköpingin lääniin, missä hän kehitti ansiokkaasti sekä teollisuutta että maataloutta. Vuonna 1774 hänen omistamansa kartanon mailta löydettiin kansainvaellusajan kulta-aarre (Tureholmsskatten), jonka hän suurimmaksi osaksi sulatutti ja lyötti tukaateiksi, joilla sai maksettua velkansa. Vuonna 1782 hän sai kaivoskorkeakoulun presidentin viran, jota hoiti tarmokkaasti aina vuoteen 1790 saakka. Vuodesta 1774 hän oli Ruotsin kuninkaallisen tiedeakatemian jäsen nro 206."@fi ;
    rdaa:P50118 yso:p234959 ;
    rdaa:P50119 yso:p105256 ;
    rdaa:P50120 "1792" ;
    rdaa:P50121 "1724" ;
