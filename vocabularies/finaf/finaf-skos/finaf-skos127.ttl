finaf:000236807 a rdac:C10004,
        skos:Concept ;
    dct:created "2026-06-11"^^xsd:date ;
    dct:modified "2026-06-11T10:17:42"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000055091350>,
        <http://viaf.org/viaf/79010701>,
        "Asteri ID: 000236807" ;
    rdaa:P50097 yso:p94383 ;
    rdaa:P50100 yso:p15037,
        yso:p3884,
        yso:p454 ;
    rdaa:P50102 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50103 "Essen, H. H. von, 1755-1824"@fi,
        "Essen, Hans Heinrich von, 1755-1824"@fi,
        "Essen, Hans Henrik von, 1755-1824"@fi ;
    rdaa:P50104 mts:m2726,
        mts:m2773 ;
    rdaa:P50109 yso:p234571 ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen. Aloitti sotilasuransa kadettina vuonna 1768, eteni sitten nopeasti: Vuonna 1778 ratsumestari, 1787 eversti ja vielä samana vuonna everstiluutnantti, 1795 kenraalimajuri, 1805 kenraaliluutnantti, 1807 ratsuväen kenraali ja 1811 kenttämarsalkka. Samalla menestyi myös hovissa: Vuonna 1777 hovitallimestari, 1788 ylitallimestari, 1796 valtakunnantallimestari. Vuonna 1788 sai haasteen kaksintaistelun kreivi A.L. Ribbingiltä, syynä Charlotta Eleonora De Geerin kosinta. Tämä aiheutti von Essenille lievän loukkantumisen ja suuren skandaalin, olihan hän ollut vuosikausia suhteessa Augusta von Fersenin kanssa. Oli Kustaa III:n suosikkeja ja seurasi kuningasta tämän ulkomaanmatkoille ja sotaretkille. Tiesi murhasuunnitelmista ja yritti turhaan saada kuningas luopumaan osallistumisesta oopperan naamiaisiin. Hänen käsivarsilleen haavoittunut kuningas vaipui, ja hän vei tämän pois ampumapaikalta. Vuosina 1795-1797 hän toimi valtionhoitajana Tukholmassa. Vuonna 1796 osallistui sijaishallitsija Kaarle-herttuan Pietarin-matkaan. Vuonna 1800 hänet nimitettiin Pommerin kenraalikuvernööriksi. Siellä hän edisti maaorjuuden lakkauttamista. Vuonna 1807 puolusti Stralsundin kaupunkia Ranskaa vastaan. 2,5 kuukauden kuluttua sai aikaan aselevon ranskalaisten kanssa, mutta kuningas Kustaa IV Aadolf sanoi sopimuksen irti. Vuonna 1809 sai kreivin arvon. Vuosina 1814-1816 toimi Norjan käskynhaltijana. Nimitettiin vuonna 1816 valtakunnanmarsalkaksi ja vuonna 1817 Skoonen komentajaksi."@fi ;
    rdaa:P50118 yso:p235673 ;
    rdaa:P50119 "Tidaholm, Ruotsi"@fi ;
    rdaa:P50120 "1824" ;
    rdaa:P50121 "1755" ;
    rdaa:P50291 "Essen" ;
    rdaa:P50292 "Hans Henric von" ;
    rdaa:P50346 yso:p106813 ;
    rdaa:P50411 "Essen, Hans Henric von, 1755-1824"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Hans_Henric_von_Essen_(1755%E2%80%931824)'>Wikipedia</a>, katsottu 11.6.2026 (Hans Henric von Essen)"@fi ;
