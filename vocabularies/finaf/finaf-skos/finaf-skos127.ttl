        <http://viaf.org/viaf/12274440>,
        "Asteri ID: 000236543" ;
    rdaa:P50097 yso:p94383 ;
    rdaa:P50100 yso:p4130,
        yso:p454 ;
    rdaa:P50103 "Adam Horn af Ekebyholm, 1717-1778"@fi,
        "Ekebyholm, Adam Horn af, 1717-1778"@fi,
        "Horn af Ekebyholm, Adam, 1717-1778"@fi,
        "Horn af Kanckas, Adam, 1717-1778"@fi,
        "Kanckas, Adam Horn af, 1717-1778"@fi ;
    rdaa:P50104 mts:m2749,
        mts:m2773 ;
    rdaa:P50110 mts:m816 ;
    rdaa:P50113 "Ruotsalainen aatelinen poliitikko ja virkamies. Aloitti sotilasuransa jo 14-vuotiaana vänrikkinä ja eteni nopeasti. Majuri Hattujen sodassa vuosina 1741-1743, Itä-Göötanmaan ratsuväkirykmentin eversti vuonna 1747. Osallistui Pommerin sotaan 1750-luvulla, jona aikana ylennettiin vuonna 1757 kenraalimajuriksi ja sitten kenraaliluutnantiksi. Toimi samaan aikaan valtiopäivillä (myssyjen ja sittemmin hovipuolueen kannattaja) ja yritti Pietarin-lähettilään tuloksetta suostutella Venäjän hallitusta tukemaan Ruotsin hovia kamppailussa vuonna 1750 vallassa ollutta myssypuoluetta vastaan. Vuosina 1751-1752 toimi salaisen valiokunnan jäsenenä. Myssyt valitsivat hänet vuonna 1765 kansleriksi, mutta hän luopui tästä luottamustoimesta. Oli mukana Kööpenhaminassa vuonna 1766 prokuraattorina Tanskan Sofia Magdalenan ja Ruotsin kruununprinssin vihkiäisissä. Hattupuolue nousi valtaan vuonna 1769, ja Horn muiden myssyjen tavoin erotettiin viroistaan. Kustaa III kutsui hänet jo 1771 takaisin. Vuonna 1772 hänet nimitettiin valtakunnantallimestariksi."@fi ;
    rdaa:P50118 yso:p1054643 ;
    rdaa:P50119 yso:p105464 ;
    rdaa:P50120 "1778" ;
    rdaa:P50121 "1717" ;
    rdaa:P50291 "Horn" ;
    rdaa:P50292 "Adam" ;
    rdaa:P50411 "Horn, Adam, 1717-1778"@fi ;
    rdau:P61101 "<a href='https://sv.wikipedia.org/wiki/Adam_Horn_af_Ekebyholm'>Wikipedia</a>, katsottu 6.5.2026 (Adam Horn af Ekebyholm)"@fi ;
    skos:altLabel "Adam Horn af Ekebyholm, 1717-1778"@fi,
        "Ekebyholm, Adam Horn af, 1717-1778"@fi,
        "Horn af Ekebyholm, Adam, 1717-1778"@fi,
        "Horn af Kanckas, Adam, 1717-1778"@fi,
        "Kanckas, Adam Horn af, 1717-1778"@fi ;
    skos:hiddenLabel "Adam Horn"@fi,
        "Adam Horn af Ekebyholm"@fi,
        "Adam Horn af Kanckas"@fi ;
