    rdaa:P50025 "SDR (1914-1920)"@fi,
        "Sosialidemokraattinen raittiusliitto (1914-1920)"@fi,
        "Suomen sosiaalidemokraattinen raittiusliitto (1914-1920)"@fi ;
    rdaa:P50035 "Suomen sosialidemokraattinen raittiusliitto perustettiin 1914. Vuonna 1920 siitä muodostettiin Suomen työväen raittiusliitto, joka lakkautettiin 1930. Vuonna 1924 osa Suomen työväen raittiusliitosta liittyi SDP:hen ja muodostettiin uudelleen Suomen sosialidemokraattinen raittiusliitto"@fi ;
    rdaa:P50236 "1914/1920"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m401 ;
