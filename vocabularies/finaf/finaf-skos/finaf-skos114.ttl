finaf:000029444 a rdac:C10005,
        skos:Concept ;
    dct:created "2010-11-18"^^xsd:date ;
    dct:modified "2021-06-19T15:00:45"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000029444" ;
    rdaa:P50012 finaf:000029443 ;
    rdaa:P50016 finaf:000029445 ;
    rdaa:P50237 mts:m898,
        "työväenteatteri"@fi ;
    rdaa:P50393 "Mikkelin työväen näyttämö aloitti toimintansa vuonna 1919 harrastajateatterina. Vuodesta 1929 vuoteen 1944 teatteri oli nimeltään Mikkelin työväen teatteri. Tuolloin teatteri toimi yhdistyspohjaisena. Vuonna 1930 teatterille palkattiin ensimmäiset päätoimiset henkilöt: teatterinjohtaja ja kaksi näyttelijää. Vuonna 1944 teatterista tuli Mikkelin teatteri. (Wikipedia, katsottu 18.11.2010)"@fi ;
    rdaa:P50407 "Mikkelin työväen teatteri"@fi ;
    rdau:P61101 "Pikkujättiläinen, 2010"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Mikkelin työväen teatteri"@fi .

