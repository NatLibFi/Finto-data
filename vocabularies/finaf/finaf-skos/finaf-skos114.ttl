finaf:000031952 a rdac:C10005,
        skos:Concept ;
    dct:created "1996-12-09"^^xsd:date ;
    dct:modified "2025-10-09T08:16:23"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000527244600>,
        "Asteri ID: 000031952" ;
    rdaa:P50008 finaf:000038390 ;
    rdaa:P50012 finaf:000031950 ;
    rdaa:P50013 finaf:000029243 ;
    rdaa:P50022 yso:p14700,
        yso:p8432 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin>,
        <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50025 "Helsingfors universitets studentbibliotek"@fi,
        "Helsingin yliopisto. Opiskelijakirjasto"@fi,
        "Helsingin yliopisto. Studentbiblioteket"@fi,
        "Helsingin yliopisto. Undergraduate Library"@fi,
        "Helsinki University Undergraduate Library"@fi,
        "Opiskelijakirjasto (Helsingin yliopisto)"@fi ;
    rdaa:P50035 "Opiskelijakirjasto oli alun perin Ylioppilaskunnan kirjasto. Se perustettiin Yleinen Ylioppilaskirjasto (ruots. Allmänna Studentbibliotek) -nimisenä jo vuonna 1858, kun yliopiston osakuntien vanhat kirjastot yhdistettiin. Vuonna 1892 kirjasto sai oman rakennuksen ja uudeksi nimekseen (vuoteen 1974 asti) Ylioppilaskunnan kirjasto (Studentkårens bibliotek). Vuonna 1974 ylioppilaskunta luovutti kirjaston valtiolle, ja vuodet 1974–1996 kirjasto kuului hallinnollisesti Helsingin yliopiston kirjastoon (nyk. Kansalliskirjasto). Vuonna 1997 Opiskelijakirjasto kuitenkin irrotettiin Helsingin yliopiston kirjastosta yliopiston konsistorin alaiseksi erillislaitokseksi."@fi ;
    rdaa:P50236 "1997/2009"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m4688 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Helsingin yliopiston opiskelijakirjasto"@fi ;
    rdau:P61101 "Wikipedia, katsottu 10.2.2012"@fi ;
    skos:altLabel "Helsingfors universitets studentbibliotek"@fi,
        "Helsingin yliopisto. Opiskelijakirjasto"@fi,
