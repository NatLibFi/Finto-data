finaf:000000911 a rdac:C10005,
        skos:Concept ;
    dct:created "1993-12-03"^^xsd:date ;
    dct:modified "2025-10-06T15:28:51"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000000911" ;
    rdaa:P50008 finaf:000000899 ;
    rdaa:P50012 finaf:000232300 ;
    rdaa:P50016 finaf:000009366 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "Helsingfors universitet. Historisk-filologiska sektionen"@fi,
        "Historiallis-kielitieteellinen osasto (Helsingin yliopisto)"@fi,
        "Historisk-filologiska sektionen vid Helsingfors universitet"@fi ;
    rdaa:P50035 "Humanistisen tiedekunnan juuret ovat vanhassa filosofisessa tiedekunnassa, joka oli yksi vuonna 1640 perustetun Turun Akatemian neljästä kantatiedekunnasta. Tiedekunta jaettiin 1852 kahteen osastoon, historiallis-kielitieteelliseen osastoon ja fyysis-matemaattiseen (myöhemmin matemaattis-luonnontieteelliseen) osastoon. 1992 vanha filosofinen tiedekunta lakkautettiin ja sen osastoista tuli itsenäisiä tiedekuntia, jolloin historiallis-kielitieteellinen osasto muuttui humanistiseksi tiedekunnaksi."@fi ;
    rdaa:P50236 "1919/1991"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m4751 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Helsingin yliopisto. Historiallis-kielitieteellinen osasto"@fi ;
    skos:altLabel "Helsingfors universitet. Historisk-filologiska sektionen"@fi,
        "Historiallis-kielitieteellinen osasto (Helsingin yliopisto)"@fi,
        "Historisk-filologiska sektionen vid Helsingfors universitet"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Helsingin yliopisto. Historiallis-kielitieteellinen osasto"@fi .

