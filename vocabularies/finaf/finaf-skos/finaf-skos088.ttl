finaf:000003361 a rdac:C10005,
        skos:Concept ;
    dct:created "2000-03-28"^^xsd:date ;
    dct:modified "2022-09-01T19:00:33"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000492927988>,
        "Asteri ID: 000003361" ;
    rdaa:P50012 finaf:000015049 ;
    rdaa:P50022 yso:p14392 ;
    rdaa:P50035 "Vuonna 1969 suomalaisyritykset Oy Vuoksenniska Ab ja Oy Fiskars Ab yhdistivät terästuotantonsa uuteen yhtiöön nimeltä Ovako. Wärtsilästä tuli Ovako Oy:n osaomistaja vuonna 1972. Vuonna 1986 perustettiin Ovako Steel -konserni sulauttamalla yhteen SKF Steel ja Ovako. Vuonna 1991 SKF otti Ovako Steelin kokonaan omistukseensa, ja Imatran toiminta jatkui Imatra Steelin nimellä. Ovako perustettiin (uudelleen?) 2005 sulauttamalla toisiinsa Fundia, Ovako Steel ja Imatra Steel."@fi ;
    rdaa:P50037 "1969" ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50350 yso:p94426 ;
    rdaa:P50407 "Ovako (yhtiö : 1969-1986)"@fi ;
    rdau:P61101 "Lähde: Laakasuo, Risto: Berndt Grönblom ja hänen yrityksensä. 1985"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Ovako (yhtiö : 1969-1986)"@fi .

