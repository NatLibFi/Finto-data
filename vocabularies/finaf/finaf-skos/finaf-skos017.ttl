    rdaa:P50291 "Tallqvist" ;
    rdaa:P50292 "Tore" ;
    rdaa:P50411 "Tallqvist, Tore, 1941-2022"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Tore_Tallqvist'>Wikipedia</a>, katsottu 21.12.2022 (Tore Gustav Tallqvist (25. joulukuuta 1941 Helsinki – 9. marraskuuta 2022 Helsinki) oli suomalainen arkkitehti. Hän toimi arkkitehtuurin historian professorina Tampereen teknillisessä korkeakoulussa 1988–2009. Tallqvist valmistui ylioppilaaksi Svenska normallyceumin klassiselta linjalta vuonna 1959 ja arkkitehdiksi Teknillisestä korkeakoulusta vuonna 1969. Tekniikan lisensiaatiksi hän valmistui vuonna 1983. Tallqvist opetti Teknillisessä korkeakoulussa 1972–1986)"@fi ;
    skos:hiddenLabel "Tore Tallqvist"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Tallqvist, Tore, 1941-2022"@fi .

