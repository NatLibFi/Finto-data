finaf:000038021 a rdac:C10005,
        skos:Concept ;
    dct:created "2012-12-05"^^xsd:date ;
    dct:modified "2026-03-19T14:54:21"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000038021" ;
    rdaa:P50016 finaf:000038012,
        finaf:000038013 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50025 "Vaasan hovioikeus (1775-1808)"@fi,
        "Vasa hovrätt (1775-1808)"@fi,
        "Wasa hovrätt (1775-1808)"@fi ;
    rdaa:P50035 "Vaasan hovioikeus on toiseksi vanhin Suomen kuudesta hovioikeudesta. Se on perustettu vuonna 1775 Ruotsin kuninkaan Kustaa III:n päätöksellä. Hovioikeus aloitti varsinaiset istunnot 21.8.1776. Aluksi sillä oli toimitilat Vanhassa Vaasassa, jonne ne valmistuivat 1786. Vuonna 1862 Vaasan hovioikeus muutti nykyisille sijoilleen Vaasan kaupunkiin, kun C. A. Setterbergin suunnittelema punatiilitalo Hovioikeudenpuistossa valmistui"@fi ;
    rdaa:P50236 "1775/1808"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50350 yso:p94466 ;
    rdaa:P50407 "Ruotsi. Hovioikeus (Vaasa)"@fi,
        "Sverige. Hovrätt (Vasa)"@sv ;
    rdau:P61101 "... Kongl. maj:t har ... gifwit ... tilkänna: at som enligt kongl. maj:ts ... förordning angående fyra riddare orden ... utom ordens capitlet ingen domstol ... äger magt at döma commendeur eller riddare sine orden och ridderliga förmåner förlustig .., 1806"@fi,
        "Wikipedia, katsottu 5.12.2012"@fi ;
    skos:altLabel "Vaasan hovioikeus (1775-1808)"@fi,
        "Vasa hovrätt (1775-1808)"@fi,
        "Wasa hovrätt (1775-1808)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Ruotsi. Hovioikeus (Vaasa)"@fi,
        "Sverige. Hovrätt (Vasa)"@sv .

