    rdaa:P50025 "Finlands senat"@fi,
        "Sejm Finlândii"@fi,
        "Senaten för Finland"@fi,
        "Suomi (suuriruhtinaskunta). Suomen senaatti"@fi ;
    rdaa:P50035 "Maaliskuussa 1917 vallankumouksen myötä senaatin nimestä pudotettiin pois etuliite keisarillinen. Itsenäistymisen jälkeen, vuoden 1918 lopulla, senaatin talousosastosta tuli valtioneuvosto ja oikeusosastosta korkein oikeus."@fi ;
    rdaa:P50236 "1917/1918"^^<http://id.loc.gov/datatypes/edtf> ;
