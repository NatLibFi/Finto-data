finaf:000036070 a rdac:C10005,
        skos:Concept ;
    dct:created "2009-10-22"^^xsd:date ;
    dct:modified "2021-06-19T15:03:17"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000036070" ;
    rdaa:P50012 finaf:000036072 ;
    rdaa:P50016 finaf:000036071 ;
    rdaa:P50025 "Finlands Vita Garde"@fi,
        "Suomen valkoinen kaarti"@fi,
        "Valkoinen kaarti"@fi ;
    rdaa:P50393 "Suomen kaarti 1803-1808 oli Venäjän vallan aikana ainoa suomalainen kaartin joukkoyksikkö. Myöhemmin itsenäisyyden aikana se otti aluksi nimekseen Suomen valkoinen kaarti. 1957 nimeksi vaihdettiin Kaartin pataljoona. Nykyisin tämä pataljoona on yhdistetty Kaartin jääkärirykmenttiin."@fi ;
    rdaa:P50407 "Suomi. Maavoimat. Suomen valkoinen kaarti"@fi ;
    rdau:P61101 "Ratsastus, 1810: t.p. (Ratsastus [Pienpainateaineisto] : 1810-1944.)"@fi,
        "Wikipedia (22.10.2009)"@fi ;
    skos:altLabel "Finlands Vita Garde"@fi,
        "Suomen valkoinen kaarti"@fi,
        "Valkoinen kaarti"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Suomi. Maavoimat. Suomen valkoinen kaarti"@fi .

finaf:000036071 a rdac:C10005,
        skos:Concept ;
    dct:created "1992-11-24"^^xsd:date ;
    dct:modified "2020-12-03T20:13:11"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000492950790>,
        "Asteri ID: 000036071" ;
    rdaa:P50012 finaf:000036070,
        finaf:000036072 ;
    rdaa:P50025 "KaartP"@fi,
        "Kaartin pataljoona"@fi ;
    rdaa:P50035 "Pataljoonan historia alkaa vuodesta 1944, jolloin perustettiin Helsingin komennuskomppania. Komppania nimettiin 5. joulukuuta 1948 Helsingin varuskuntapataljoonaksi ja edelleen 1. tammikuuta 1957 Kaartin pataljoonaksi. Toisen maailmansodan jälkeen Suomessa palattiin yksiköiden numeroinnista maakunnallisiin nimiin vuonna 1958, jolloin myös Helsinkiin saatiin taas Kaartin pataljoona."@fi ;
    rdaa:P50236 "1957/.."^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 "pataljoona"@fi,
        "sotilaallinen organisaatio"@fi ;
    rdaa:P50407 "Suomi. Maavoimat. Kaartin pataljoona"@fi ;
    rdau:P61101 "Ekman, Torsten. Finska gardet 1812-1905, (2006)"@fi,
        "Ekman, Torsten. Suomen kaarti 1812-1905, (2006)"@fi ;
    skos:altLabel "KaartP"@fi,
        "Kaartin pataljoona"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Suomi. Maavoimat. Kaartin pataljoona"@fi .

