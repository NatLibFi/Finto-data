    rdaa:P50012 finaf:000031705 ;
    rdaa:P50014 finaf:000031708 ;
    rdaa:P50022 yso:p6204 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "STyR (Suomen työväen raittiusliitto)"@fi ;
    rdaa:P50035 "Suomen sosialidemokraattinen raittiusliitto perustettiin 1914. Vuonna 1920 toiminnan jatkajaksi muodostattiin Suomen työväen raittiusliitto. Kommunistit ja sosiaalidemokraatit toimivat samassa liitossa vuoden 1924 edustajakokoukseen asti, jolloin Työväen Raittiusliitto jäi kommunistien haltuun. Sosiaalidemokraatit perustivat uuden liiton, jonka nimeksi tuli jälleen Suomen Sosialidemokraattinen Raittiusliitto. Kommunistinen liitto lakkautettiin vuonna 1930 samalla kun muutkin kommunistijärjestöt."@fi ;
    rdaa:P50236 "1920/1930"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m401 ;
    rdaa:P50407 "Suomen työväen raittiusliitto"@fi ;
    skos:altLabel "STyR (Suomen työväen raittiusliitto)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Suomen työväen raittiusliitto"@fi .

