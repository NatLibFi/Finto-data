finaf:000038158 a rdac:C10005,
        skos:Concept ;
    dct:created "2012-12-14"^^xsd:date ;
    dct:modified "2022-03-14T14:50:58"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000506367417>,
        "Asteri ID: 000038158" ;
    rdaa:P50016 finaf:000019752,
        finaf:000032522,
        finaf:000038157,
        finaf:000038159 ;
    rdaa:P50025 "Finska metallindustrins arbetsgifvareförbund"@fi ;
    rdaa:P50035 "Perustettiin nimellä Finska Metallindustrins Arbetsgivareförbund (suomeksi Suomen Metalliteollisuuden Harjoittajain Liitto) 17. lokakuuta 1903. Alun perin järjestö toimi puhtaasti työnantajajärjestönä, mutta Suomen itsenäisyyden alkuvuosista saakka järjestö on pyrkinyt myös laajempaan elinkeinopoliittiseen vaikuttamiseen, aluksi vuonna 1918 perustetun Suomen Metalliteollisuusyhdistyksen kautta. Työnantajajärjestö ja elinkeinopoliittinen järjestö yhdistettiin vuonna 1990 yhdeksi kokonaisuudeksi, jonka nimeksi tuli Suomen Metalli-, Kone- ja Sähköteknisen Teollisuuden Keskusliitto. Nimi muutettiin vuonna 1992 muotoon Metalliteollisuuden Keskusliitto ja edelleen vuonna 2003 muotoon Teknologiateollisuus"@fi ;
    rdaa:P50236 "1903/1918"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m401 ;
    rdaa:P50407 "Suomen metalliteollisuuden harjoittajain liitto"@fi ;
    rdau:P61101 "Protokoll fördt vid Finska metallindustrins arbetsgifvareförbund - Suomen metalliteollisuuden harjoittajain liitto's årsmöte, 1904-1904: t.p. (Suomen metalliteollisuuden harjoittajain liitto)"@fi,
        "Wikipedia, 14.12.2012"@fi ;
    skos:altLabel "Finska metallindustrins arbetsgifvareförbund"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Suomen metalliteollisuuden harjoittajain liitto"@fi .

