finaf:000035205 a rdac:C10005,
        skos:Concept ;
    dct:created "2003-10-02"^^xsd:date ;
    dct:modified "2022-03-28T16:33:28"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000506750651>,
        "Asteri ID: 000035205" ;
    rdaa:P50012 finaf:000035190 ;
    rdaa:P50013 finaf:000035189 ;
    rdaa:P50022 yso:p18824 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "Keskinäinen Henkivakuutusyhtiö Pohja"@fi ;
    rdaa:P50035 "Vuonna 1922 perustetun osakeyhtiö Henki-Pohjan yhtiömuoto muutettiin v. 1933 keskinäiseksi, ja nimeksi tuli Keskinäinen Henkivakuutusyhtiö Pohja. Vuonna 1947 Pohja, Keskinäinen vakuutusyhtiö Vara (ent. Paloapuyhdistys Tulenvara) ja Eläkekassa Elonvara yhdistettiin Pohja-yhtymäksi. 18.6.1982 tehdyn päätöksen mukaan Pohja-yhtymä ja Aurayhtiöt fuusioitiin. Fuusion tuloksena syntynyt Tapiola-yhtiöt aloitti toimintansa 1.1.1984"@fi ;
    rdaa:P50037 "1933" ;
    rdaa:P50038 "1947" ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50407 "Pohja, keskinäinen henkivakuutusyhtiö"@fi ;
    rdau:P61101 "Itkonen, Uolevi. Tapiola-fuusio / Uolevi Itkonen ; [kuvatekstit: Ulla Tujunen], 2002"@fi ;
    skos:altLabel "Keskinäinen Henkivakuutusyhtiö Pohja"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Pohja, keskinäinen henkivakuutusyhtiö"@fi .

