    rdaa:P50025 "Finland. Finlands rundradio"@fi,
        "Finlands rundradio"@fi,
        "Suomi. Suomen yleisradio"@fi ;
    rdaa:P50035 "Radiotoimintaa hoidettiin vuosina 1921-1926 erilaisten yhdistysten toimesta. Nuorten Voiman Liiton Radioyhdistys sai 24.8.1921 valtioneuvostolta toimiluvan. - O.Y. Suomen Yleisradio-A.B. Finlands Rundradio'n perustamispäätös tehtiin 15.12.1925. Yhtiön perustamiskokouksessa 29.5.1926 valittiin seitsenhenkinen hallintoneuvosto. Ohjelmalähetykset alkoivat 9.9.1926. Vuonna 1934 Ylen toiminta siirtyi Suomen valtiolle. Uuden yhtiön nimeksi tuli ensin Oy Suomen Yleisradio Ab ja vuodesta 1944 Oy Yleisradio Ab."@fi ;
    rdaa:P50236 "1926/1944"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m818 ;
    rdaa:P50407 "Suomen yleisradio"@fi ;
    rdau:P61101 "YLEm Insinöörit 50 vuotta / toim. Per Nyström, Raimo Nummi, Ismo Koponen. - Helsinki 2000"@fi ;
    skos:altLabel "Finland. Finlands rundradio"@fi,
        "Finlands rundradio"@fi,
        "Suomi. Suomen yleisradio"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Suomen yleisradio"@fi .

