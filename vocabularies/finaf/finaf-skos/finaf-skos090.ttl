    rdaa:P50006 <http://isni.org/isni/0000000492947209>,
        "Asteri ID: 000032063" ;
    rdaa:P50012 finaf:000018904,
        finaf:000032062 ;
    rdaa:P50393 "Jyväskylän kaupunginvaltuusto päätti perustaa kunnallisen sähkölaitoksen 23.4.1902. - Toiminnan kehittymisen myötä nimi on muutunut Jyväskylän kaupungin energialaitokseksi ja Jyväskylän Energiaksi. - Sähkölaitos muuttui Jyväskylän kaupungin omistamaksi osakeyhtiöksi vuoden 1977 alusta. - Tällä hetkellä (2002) Jyväskylän Energia Oy on konserni, johon kuuluu tytäryhtiö JE-Urakointi Oy ja joka on osakkaana verkottumisen kautta syntyneissä yhtiöissä, joista merkittävimmät ovat Jyväskylän energiatuotanto Oy ja Hyötytuuli Oy"@fi ;
    rdaa:P50407 "Jyväskylän Energia"@fi ;
    rdau:P61101 "Skippari, Mika. Sähkö kaikkien palvelijaksi : Jyväskylän kaupungin sähkölaitos - Jyväskylän Energia oy 1902 - 2002 / Mika Skippari, 2002"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Jyväskylän Energia"@fi .

