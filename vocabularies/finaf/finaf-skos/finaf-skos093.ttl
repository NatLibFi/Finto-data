    rdaa:P50006 <http://isni.org/isni/000000012190471X>,
        "Asteri ID: 000030311" ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50025 "TY (Turun yliopisto)"@fi,
        "Turun suomalainen yliopisto"@fi,
        "Universidad de Turku"@fi,
        "Universitas Aboensis"@fi,
        "Universitas Turkuensis"@fi,
        "University of Turku"@fi,
        "Università di Turku"@fi,
        "Universität Turku"@fi,
        "Åbo Universitet"@fi ;
    rdaa:P50035 "Turun suomalaisen yliopiston perustamiskokous pidetty 28.2.1920"@fi,
        "Turun yliopisto ei nimestään huolimatta ole Turun akatemian seuraaja, vaan Turun akatemia siirtyi Turusta Helsinkiin ja on nykyisin nimeltään Helsingin yliopisto. Yliopistollinen opetus tuli takaisin Turkuun vuonna 1917, kun kaupunkiin perustettiin ruotsinkielinen Åbo Akademi. Nykyinen Turun yliopisto perustettiin vuonna 1920 Turun Suomalaisen Yliopistoseuran toimesta suomenkieliseksi monialayliopistoksi ruotsinkielisen Åbo Akademin ja kaksikielisen Helsingin yliopiston rinnalle."@fi ;
    rdaa:P50037 "1920" ;
    rdaa:P50237 mts:m4680 ;
    rdaa:P50350 yso:p94447 ;
