    rdaa:P50022 yso:p25610 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/fin> ;
    rdaa:P50035 "Helsingin Kaupunginteatterilla on kaksi edeltäjää. Vuonna 1902 perustettu Helsingin Työväenteatteri ja vuonna 1933 perustettu Helsingin Kansanteatteri yhdistyivät Helsingin Kansanteatteri-Työväenteatteriksi 1948. Kansanteatteri-Työväenteatteri muuttui Helsingin Kaupunginteatteriksi vuonna 1965, jolloin Helsingin teatterisäätiö perustettiin ja tehtiin päätös teatteritalon rakentamisesta."@fi ;
    rdaa:P50232 finaf:000007459,
        finaf:000015864 ;
    rdaa:P50236 "1948/1965"^^<http://id.loc.gov/datatypes/edtf> ;
