    rdaa:P50025 "J. P. Lindh (kirjapaino, Örebro, 1783-1798)"@fi,
        "Joh. P. Lindh (kirjapaino, Örebro, 1783-1798)"@fi,
        "Johan Pehr Lindh (kirjapaino, Örebro, 1783-1798)"@fi,
        "Johan Peter Lindh (kirjapaino, Örebro, 1783-1798)"@fi,
        "Lindh, J. P. (kirjapaino, Örebro, 1783-1798)"@fi,
        "Lindh, Joh. P. (kirjapaino, Örebro, 1783-1798)"@fi,
        "Lindh, Johan Pehr (kirjapaino, Örebro, 1783-1798)"@fi ;
    rdaa:P50336 finaf:000174636 ;
    rdaa:P50393 "Johan Peter Lindh (1757-1820) osti Johan Georg Langelta (1722-1792) tämän vuonna 1781 ostaman Lars Wennbergin ja Johan Christopher Holmbergin painon vuonna 1791 ja siirtyi Tukholmaan. Vuonna 1806 Lindh osti Langen leskeltä Maria Susanna Lange os. Behleltä (1732-1813) Langen painon privilegioineen. Örebron painoa hoitivat vuoden 1791 jälkeen faktorit Erik Wikblad ensin ja sitten Nils Magnus Lindh, jolle kirjapaino siirtyi vuonna 1798."@fi ;
    rdaa:P50407 "Lindh, Johan Peter (kirjapaino, Örebro, 1783-1798)"@fi ;
    rdau:P61101 "Klemming, G. E. Svensk boktryckeri-historia 1483-1883, 1883"@fi ;
