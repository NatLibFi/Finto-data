finaf:000013125 a rdac:C10005,
        skos:Concept ;
    dct:created "1995-08-01"^^xsd:date ;
    dct:modified "2021-06-18T19:04:29"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000013125" ;
    rdaa:P50012 finaf:000003860,
        finaf:000018918 ;
    rdaa:P50016 finaf:000003133,
        finaf:000011928 ;
    rdaa:P50237 mts:m257 ;
    rdaa:P50393 "Suomen opettajien raittiusliitto perustettu 1906 ; 1964- Raittiuskasvatusliitto. Raittiuskasvatusliiton liittokokous pätti 26.4.1986 perustaa Nuorisokasvatussäätiön. 2.6.1987 Raittiuskasvatusliiton liittokokous hyväksyi uudet säännöt ja nimenmuutoksen Nuorisokasvatusliitoksi, joka otettiin käyttöön 1988. - Nuorisokasvatusliiton liittokokous päätti 15.5.1993 liiton lakkauttamisesta. Sen toiminta lakkautettiin vuoden 1993 lopussa ja liitto purkautui 1994 alkupuolella. Todettiin, että 12.6.1993 perustetaan uusi järjestö, josta ovat neuvotelleet Nuorisokasvatusliitto, Kansallinen terveyskasvatusliitto, Suomen terveyysliitto, Liikenneraittiustyön keskus ja Terveet elämäntavat ry. Em. liitot lakkauttavat toimintansa 1.1.1994. Raittiusjärjestöjen perinneyhdistyksistä toimineet järjestöt sulauttivat toimintansa vasta perustettuun Terveys ry:hyn."@fi ;
    rdaa:P50407 "Nuorisokasvatussäätiö"@fi ;
    rdau:P61101 "Helimäki, Kosti. Rohkeutta tarvitaan, röökiä ei ollenkaan, 2002"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Nuorisokasvatussäätiö"@fi .

