finaf:000000011 a rdac:C10005,
        skos:Concept ;
    dct:created "1990-04-07"^^xsd:date ;
    dct:modified "2020-12-03T20:00:09"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000492926889>,
        "Asteri ID: 000000011" ;
    rdaa:P50014 finaf:000017816 ;
    rdaa:P50025 "A. Ahlstrom Corporation"@fi,
        "Ahlström, A. (yhtiö)"@fi ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50301 finaf:000008209,
        finaf:000205042 ;
    rdaa:P50393 "Ahlström konsernin historia alkoi Merikarvialla 1851, missä Antti Ahlström vastasi Lankosken paperiruukista, varustamotoiminnasta ja laivanrakentamisesta. Hän ehti hankkia omistukseensa neljä rautaruukkia ja neljätoista sahaa. Yritys muutettiin osakeyhtiöksi 1908. Yhtiöön liitettiin Varkauden tehtaat, Karhula Oy ja enemmistö Iittalan lasitehtaasta. Korkeakosken tehdas erikoistui kartongin tuottamiseen, Kauttuan tehtaat sulfiittipaperin valmistukseen. Helsingistä ostettiin teolisuuspalatsi pääkonttoriksi. 1950-luvulla alkoi voimakas kansainvälistyminen, 1970-luvulla uudistettiin Kauttuan paperitehdas ja Varkauden tehdas lakkautettiin. Vuonna 1982 perheyhtiöllä oli lähes 60 eri liiketoiminnallista osa-aluetta. Vuonna 2001 yhtiö jakaantui kolmeen osaan. Nämä ovat: teollisuusyhtiö Ahlström Oyj, sijoitusyhtiö Ahlsröm Capital Oy ja A. Ahlström Osakeyhtiö (jolla osa metsistä, saha ja Noormarkun kiinteistöt)."@fi ;
    rdaa:P50407 "A. Ahlström (yhtiö)"@fi ;
    rdau:P61101 "Ahlstrom oyj 1.7.2001-"@fi,
        "Komsi, Pauli. Omistamisen taito : perheyritykset kansakunnan rakentajina / Pauli Komsi, Jan Lindström, Seppo Zetterberg, 2002"@fi ;
    skos:altLabel "A. Ahlstrom Corporation"@fi,
        "Ahlström, A. (yhtiö)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "A. Ahlström (yhtiö)"@fi .

