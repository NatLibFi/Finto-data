    rdaa:P50022 yso:p2969 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/eng> ;
    rdaa:P50035 "Yhtye perustettiin 1980-luvun alussa nimellä Paul Oxley's Radio. Nimi vaihdettiin myöhemmin muotoon Paul Oxley's Unit ja sen jälkeen vielä uudelleen nimeen Unit 6. Yhtyeen jäsenet olivat brittiläiset Paul Oxley (Malcolm Campbell) ja Brian Hammond, sekä suomalaiset Ulf Enberg, Kjell Ekholm ja Janne Romberg. Yhtye oli hyvin suosittu Suomessa aktiivikautenaan 1980-luvulla."@fi ;
    rdaa:P50237 mts:m1100 ;
    rdaa:P50334 finaf:000186547 ;
    rdaa:P50407 "Unit 6 (yhtye : 1983)"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Paul_Oxley%E2%80%99s_Unit'>Wikipedia, Paul Oxley's Unit</a>, katsottu 7.8.2017"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Unit 6 (yhtye : 1983)"@fi .

