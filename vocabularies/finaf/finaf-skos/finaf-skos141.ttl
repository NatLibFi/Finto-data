    rdaa:P50006 "Asteri ID: 000174655" ;
    rdaa:P50012 finaf:000174654 ;
    rdaa:P50016 finaf:000174561 ;
    rdaa:P50334 finaf:000140986 ;
    rdaa:P50393 "Aron Holm toimi Henric Keyser II:n perillisten kirjapainon faktorina, kunnes hän osti painon itselleen vuonna 1716. Hän oli jo ennen tätä painanut omissa nimissään. Holmin paino tuhoutui osittain tulipalossa vuonna 1723. Jacob Schneidler (1681-1758) osti suuremman osan painosta, pienempi osa myytiin Anders Graeslerille."@fi ;
    rdaa:P50407 "Holm, Aron (kirjapaino, Tukholma, 1716-1723)"@fi ;
    rdau:P61101 "Klemming, G. E. Svensk boktryckeri-historia 1483-1883, 1883"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Holm, Aron (kirjapaino, Tukholma, 1716-1723)"@fi .

