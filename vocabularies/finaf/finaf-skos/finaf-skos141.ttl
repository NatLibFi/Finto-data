    rdaa:P50025 "Johann Krafft (kirjapaino, Wittenberg, 1590-1614)"@fi,
        "Officina Cratoniana (kirjapaino, Wittenberg)"@fi,
        "Typis Cratonianis (kirjapaino, Wittenberg)"@fi ;
    rdaa:P50035 "Officina Cratoniana oli myös Johann Krafft vanhemman (noin 1510-1578) perillisten Wittenbergissä vuosina 1578-1599 toimineen kirjapainon nimi."@fi ;
    rdaa:P50334 finaf:000141847,
        finaf:000141848 ;
    rdaa:P50393 "Johann Krafft nuorempi (s. 1566) jatkoi isänsä Johann Krafft vanhemman (k. 1578) kirjapainon toimintaa vuosina 1590-1614. Painon faktoreina tai vuokraajina toimivat Johann Schmidt (Faber) vuosina 1602-1610? ja Johann Gormann (k. 1628) vuosina 1605-1614. Paino siirtyi Gormannin omistukseen vuonna 1615."@fi ;
    rdaa:P50407 "Krafft, Johann II (kirjapaino, Wittenberg, 1590-1614)"@fi ;
    rdau:P61101 "Benzing, Josef. Die Buchdrucker des 16. und 17. Jahrhunderts im deutschen Sprachgebiet, 1982."@fi ;
    skos:altLabel "Johann Krafft (kirjapaino, Wittenberg, 1590-1614)"@fi,
        "Officina Cratoniana (kirjapaino, Wittenberg)"@fi,
        "Typis Cratonianis (kirjapaino, Wittenberg)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Krafft, Johann II (kirjapaino, Wittenberg, 1590-1614)"@fi .

