finaf:000233347 a rdac:C10005,
        skos:Concept ;
    dct:created "2025-09-01"^^xsd:date ;
    dct:modified "2025-09-01T12:15:44"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000121564970>,
        <http://viaf.org/viaf/129751542>,
        "Asteri ID: 000233347" ;
    rdaa:P50022 yso:p17341,
        yso:p3833,
        yso:p9890 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/lat> ;
    rdaa:P50025 "Aedes Populi Romani"@fi,
        "Aedes S.P.Q.R."@fi,
        "Aedibus Populi Romani"@fi,
        "Case del Popolo Romano"@fi,
        "Tipografia del Popolo romano"@fi,
        "Typographia in aedibus Populi romani"@fi ;
    rdaa:P50035 "Paavi Pius IV:n vuonna 1561 perustama kirjapaino annettiin kaksi vuotta myöhemmin Rooman kaupungille. Sitä hallinnoi vuoteen 1570 Paolo Manunzio, sitten Fabrizio Galletti vuoteen 1573 asti. Samana vuonna Stamperia ja kirjakauppa (Domenico Basa, Giorgio Ferrari, Brianzo Brianzi, Girolamo Franzini, Marco Amadori, Sebastiano De Franceschi ja Antonio Lanza) solmivat sopimuksen Stamperia-painosten painamisesta ja myynnistä. Sopimus uusittiin vuonna 1578 pienemmän yrityksen (Basa, Ferrari, Franzini, Lanza ja De Franceschi) kanssa. Stamperian ja kirjakaupan välinen yritys purettiin vuonna 1584, ja vuonna 1585 tehtiin samanlainen sopimus Giorgio Ferrarin kanssa, mutta vuonna 1593 häntä vastaan ​​nostettiin syyte sopimuksen noudattamatta jättämisestä. Ferrari jatkoi kirjojen julkaisemista sanoilla \"in aedibus Populi Romani\" vuoteen 1598 asti."@fi ;
    rdaa:P50037 "1561" ;
