    rdaa:P50121 "1932" ;
    rdaa:P50291 "King" ;
    rdaa:P50292 "Charles M." ;
    rdaa:P50411 "King, Charles M., 1932-2021"@fi ;
    rdau:P61101 "<a href='https://www.findagrave.com/memorial/253161354/charles_m-king'>Find a grave</a>, katsottu 4.9.2025 (Charles M. King: Birth 2 Oct 1932 West Salem, Edwards County, Illinois, USA, Death Jan 2021 ... Florence, Lane County, Oregon, USA ... His life's work was in the chemical causes of cancer. ... He attended Edwards County grammar and high schools before continuing to the University of Illinois to study chemistry. ... He later served in the US Army as a member of the 56th Army Band at Camp Zama, Japan. After his return to the US he attended the University of Minnesota where he received a degree in Mortuary Science and earned his Doctorate in Biochemistry. He was a 53 year member of the American Association for Cancer Research.)"@fi ;
    skos:hiddenLabel "Charles M. King"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "King, Charles M., 1932-2021"@fi .

