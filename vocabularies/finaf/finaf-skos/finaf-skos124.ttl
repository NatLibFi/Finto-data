        mts:m3349 ;
    rdaa:P50109 yso:p107719 ;
    rdaa:P50115 "Charles David"@fi ;
    rdaa:P50119 yso:p105663 ;
    rdaa:P50121 "1969" ;
    rdaa:P50291 "King" ;
    rdaa:P50292 "Charles D." ;
    rdaa:P50411 "King, Charles D. (Charles David), 1969-"@fi ;
    rdau:P61101 "<a href='https://blackpast.org/african-american-history/charles-david-king-1969/'>Charles David King (1969- ) / contributed by: Sonya Morris // Black past 6.12.2021</a>, katsottu 8.9.2025 (Charles King is a producer, visionary, trailblazer, angel investor, founder and Chief Executive Officer of MACRO, a Hollywood development and production studio founded in 2015. Born in Harlem, New York in 1969 ... He graduated from Vanderbilt with a Bachelor of Arts in 1991. Five years later in 1996 he received a Juris Doctor degree from Howard University Law School. ... King has an extensive background that contributed to the development of his company, Macro. From June 1995 until December 1995 King was an in-house attorney at MTV Networks, then from 1995 to 1997 he held the same post at America Online (AOL)[.] In 1997 ... King was named Senior VP for Motion Pictures at the William Morris Agency ... a position he held until 2009. Two years later in January 2017 he became the Co-Founder and General Partner at M Ventures ... In 2018 King became a member of THINK450 ... In January 2019 King co-founded MaC Venture ... King founded MACRO in 2015.)"@fi,
        "<a href='https://www.imdb.com/name/nm2229798/?ref_=tt_rvi_t_2'>IMDb</a>, katsottu 3.9.2025 (Charles D. King, Producer, Executive, Director"@fi,
        "<a href='https://www.linkedin.com/in/charles-d-king-65179a54/'>LinkedIn</a>, katsottu 3.9.2025 (Charles D. King, Founder & Chief Executive Officer at MACRO)"@fi ;
    skos:altLabel "King, Charles D. (elokuvatuottaja)"@fi,
        "King, Charles David, 1969-"@fi ;
    skos:hiddenLabel "Charles D. King"@fi,
        "Charles David King"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "King, Charles D. (Charles David), 1969-"@fi .

