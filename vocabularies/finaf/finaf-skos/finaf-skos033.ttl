    rdaa:P50291 "Key" ;
    rdaa:P50292 "Ellen" ;
    rdaa:P50411 "Key, Ellen, 1849-1926"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Ellen_Key'>Wikipedia</a>, katsottu 6.3.2026 (Ellen Key: Ellen Karolina Sofia Key (11. joulukuuta 1849 Sundsholm, Ruotsi – 26. huhtikuuta 1926 Strand, Omberg, Ruotsi) oli ruotsalainen kirjailija, opettaja ja yhteiskunnallinen keskustelija naisasian piirissä. Keyn tunnetuin teos on Barnets århundrade (1900, suom. Tulevaisuuden kasvatus, 1907). Key oli kirjallisuuspsykologi ja ajattelija. Hän toimi vuodesta 1883 luennoitsijana Tukholman työväenopistossa ja piti lisäksi esitelmiä niin koti- kuin ulkomaillakin yhteiskunnallisista, siveysopillisista ja kirjallishistoriallisista kysymyksistä.)"@fi ;
    skos:altLabel "E. C. S., 1849-1926"@fi,
        "Key, Ellen Karolina Sofia, 1849-1926"@fi,
        "Кей, Еллен, 1849-1926"@fi,
        "Кей, Эллен, 1849-1926"@fi ;
    skos:hiddenLabel "Ellen Karolina Sofia Key"@fi,
        "Ellen Key"@fi,
        "Еллен Кей"@fi,
        "Эллен Кей"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Key, Ellen, 1849-1926"@fi .

