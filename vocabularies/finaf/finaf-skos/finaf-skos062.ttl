finaf:000139411 a rdac:C10004,
        skos:Concept ;
    dct:created "2010-03-18"^^xsd:date ;
    dct:modified "2021-03-08T16:27:06"^^xsd:dateTime ;
    rdaa:P50094 "Asteri ID: 000139411" ;
    rdaa:P50120 "1772" ;
    rdaa:P50121 "1711" ;
    rdaa:P50291 "Momma" ;
    rdaa:P50292 "Peter" ;
    rdaa:P50318 finaf:000174565,
        finaf:000174665 ;
    rdaa:P50395 "Peter Momma osti Johan Henric Wernerin (k. 1735) leskeltä Catharina Stierncronalta (1705-1787) kuninkaallisen kirjapainon vuonna 1738, jonka hän siirsi pojalleen Wilhelm Mommalle (elinvuodet mahdollisesti 1740-1772) joulukuun viimeisenä 1768. Momma sai testamentin kautta vuonna 1769 haltuunsa Lorentz Ludvig Grefingin (k. 1769) kirjapainon. Tämä kirjapaino esiintyi nimellä Förr detta Grefingska tryckeriet, kunnes se siirtyi Momman vävylle Henrik Fougtille (1720-1782) viimeistään vuonna 1772."@fi,
        "Vuonna 1746 Peter Momma osti Carl Johansson Röpken kirjapainon. Peter Mommalla oli kirjapaino myös Västeråsissa vuosina 1739-1741 ja Nyköpingissä vuosina 1753-1766."@fi ;
    rdaa:P50411 "Momma, Peter, 1711-1772"@fi ;
    rdau:P61101 "Klemming, G. E. Svensk boktryckeri-historia 1483-1883, 1883"@fi ;
    skos:hiddenLabel "Peter Momma"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Momma, Peter, 1711-1772"@fi .

