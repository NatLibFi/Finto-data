finaf:000096028 a rdac:C10004,
        skos:Concept ;
    dct:created "1998-11-10"^^xsd:date ;
    dct:modified "2023-04-20T12:27:25"^^xsd:dateTime ;
    rdaa:P50094 <http://isni.org/isni/0000000059610154>,
        "Asteri ID: 000096028" ;
    rdaa:P50095 "Suomen linnoitusprikaati"@fi ;
    rdaa:P50103 "Nordenberg, Carl Fredrik, 1702-1779"@fi,
        "Nordenskjöld, Charles Frederic, 1702-1779"@fi,
        "Nordensköld, Carl Fred., 1702-1779"@fi ;
    rdaa:P50104 mts:m2359 ;
    rdaa:P50113 "Voluntaari Tukholman linnoituskonttorissa 1716. Konduktööri linnoituskunnassa 1719, luutnantti Göteborgin linnoitusprikaatissa 1731. Insinöörikapteeni Tukholman linnoituskonttorissa 1741, majuri 1745, Malmön linnoitusprikaatissa 1749. Ylimajoitusmestariluutnantti Suomen linnoitusprikaatissa 1755. Everstiluutnantti Tukholman linnoitusprikaatissa 1756. Linnoituskunnan vt. johtaja ja sotakollegion jäsen 1757. Eversti Suomen linnoitusprikaatissa 1762-1763. Ruotsin tiedeakatemian jäsen 1739. Nordenberg vuoteen 1751, jolloin aateloitiin nimellä Nordenskiöld."@fi ;
    rdaa:P50118 yso:p94413 ;
    rdaa:P50119 yso:p94413 ;
    rdaa:P50120 "1779" ;
    rdaa:P50121 "1702" ;
    rdaa:P50291 "Nordenskiöld" ;
    rdaa:P50292 "Carl Fredrik" ;
    rdaa:P50411 "Nordenskiöld, Carl Fredrik, 1702-1779"@fi ;
