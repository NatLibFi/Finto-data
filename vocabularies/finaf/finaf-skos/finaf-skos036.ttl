    rdaa:P50291 "Braunerskiöld" ;
    rdaa:P50292 "Laurentius" ;
    rdaa:P50395 "Alunperin Braun, aateloitu 1719 nimellä Braunerskiöld."@fi,
        "Sotalaivaston lääkäri Karlskronassa 1690. Kalmarin lukion logiikan ja fysiikan lehtori 1692. Turun akatemian lääketieteen professori 1693. Akatemian rehtori 1696-1697, sijaisrehtori 1697-1698. Tarton (Pärnun) yliopiston lääketieteen professori 1699-1701 ja 1705-1710, sotalääkäri Kuurinmaalla 1703-1704. Sotalääkäri Skånessa 1710. Amiraliteetinlääkäri Karlskronassa 1719, ero 1728. Arkkiatri 1719."@fi ;
    rdaa:P50411 "Braunerskiöld, Laurentius, 1657-1729"@fi ;
    skos:altLabel "Braun, Lars, 1657-1729"@fi,
