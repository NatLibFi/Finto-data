    rdaa:P50103 "Bielke, Sten, 1624-1684"@fi,
        "Bielke, Steno, 1624-1684"@fi,
        "Sten Nilsinpoika Bielke, nuorempi, 1624-1684"@fi ;
    rdaa:P50113 "Kapteeni amiraliteetissa 1648, majuri 1652, amiraaliluutnantti ja amiraliteettineuvos 1653. Lähettiläs roomalaisen keisarin luona 1655, Saksin vaaliruhtinaan luona 1656-1657. Valtaneuvos 1657. Amiraali 1657. Ministeri rauhanneuvotteluissa Tanskan kanssa 1658 ja 1660. Kanslianeuvos 1660-1672, 1679-1680. Lähettiläs Puolassa 1660. Reduktiokollegion presidentti 1663-1671. Tarton yliopiston kansleri 1669. Ångermanlandin kihlakunnantuomari 1670-1680. Valtiovarainhoitaja 1672-1684, kamarikollegion presidentti 1672-1684, Etelä-Suomen laamanni 1673-1680, vuorikollegion presidentti 1679-1684, Västmanlandin ja Taalain laamanni 1680-1684, valtiokonttorin presidentti 1680-1684. Kuninkaallinen neuvos 1682."@fi ;
    rdaa:P50118 yso:p105464 ;
    rdaa:P50119 yso:p94447 ;
    rdaa:P50120 "1684" ;
    rdaa:P50121 "1624" ;
