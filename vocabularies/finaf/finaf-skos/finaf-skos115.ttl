finaf:000037245 a rdac:C10005,
        skos:Concept ;
    dct:created "1997-06-02"^^xsd:date ;
    dct:modified "2021-06-19T15:03:45"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000037245" ;
    rdaa:P50012 finaf:000027520 ;
    rdaa:P50016 finaf:000037246 ;
    rdaa:P50025 "Medieförbundet"@fi ;
    rdaa:P50035 "Viestintäalan ammattiliitto oli suomalainen vuosina 1894–2009 toiminut graafisessa teollisuudessa (pääasiassa kirjapainoalalla) työskentelevien ammattiliitto. Järjestö perustettiin 18.–20. elokuuta 1894 nimellä Suomen Kirjaltajaliitto. Rekisteröityminen vahvistettiin vuoden 1897 alussa. Vuodesta 1914 vuoteen 1997 järjestö toimi nimellä Suomen Kirjatyöntekijäin Liitto (SKL). Toukokuussa 2009 järjestön liittokokous päätti fuusioitua Kemianliiton kanssa Teollisuusalojen ammattiliittoon (TEAM), joka aloitti vuoden 2010 alussa."@fi ;
    rdaa:P50037 "1998" ;
    rdaa:P50038 "2009" ;
    rdaa:P50237 mts:m401 ;
    rdaa:P50407 "Viestintäalan ammattiliitto"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/Viestint%C3%A4alan_ammattiliitto'>Wikipedia</a>, katsottu 12.4.2019"@fi ;
    skos:altLabel "Medieförbundet"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Viestintäalan ammattiliitto"@fi .

