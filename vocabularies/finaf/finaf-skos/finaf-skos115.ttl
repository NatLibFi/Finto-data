    rdfs:label "is arranger agent of music of"@en,
        "sovittajana musiikissa"@fi ;
    rdakit:hasElementType "2" ;
    rdakit:instructionNumber "18.5" ;
    rdakit:seeAlso rdaa:P50187 ;
    rdakit:toolkitDefinition "An expression that includes a contribution by an agent of rewriting a musical composition for a medium of performance different from that for which the work was originally intended."@en,
