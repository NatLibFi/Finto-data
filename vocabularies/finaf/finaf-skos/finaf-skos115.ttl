finaf:000003385 a rdac:C10005,
        skos:Concept ;
    dct:created "1993-03-11"^^xsd:date ;
    dct:modified "2020-11-04T20:05:59"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000474388984>,
        "Asteri ID: 000003385" ;
    rdaa:P50025 "Paloheimo-ryhmä"@fi,
        "Paloheimo-yhtymä"@fi ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50336 finaf:000000649,
        finaf:000004063,
        finaf:000018460 ;
    rdaa:P50393 "Paloheimo konsernin historia ulottuu vuoteen 1889, jolloin H. G. Brander osti Santamäen kartanon Lopelta. 1890 maatalouden rinnalle muodostui teollista tuotantoa tiilien valmistuksen ja sahan myötä. Riihimäen asemaravintola nykyinen Paloheimo Oy:n Asemaravintola tuli osaksi toimintaa. Veljekset Paloheimo perustivat Kajaanin Puutarha osakeyhtiön ja olivat osakkaana Riihimäen lasitehtaassa ja Rauma Wood Ltd:ssä. Hjalmar Gabriel Paloheimon perikunta perusti H. G. Paloheimo osakeyhtiön. Yhtiö aloitti tiilen ja talojen valmistuksen.1990-luvulla tiiliteollisuus myytiin Partek Oy:lle ja luovuttiin kokonaan lasiteollisuudesta. 1954 aloitettiin Lundia-kalusteiden valmistus ja 1980-luvulla Saastamoinen yhtymä Oy tuli osaksi konsernia, mutta lastulevy-, vaneri- ja puukipsilevytehtaat ja Kuopion saha myytiin 1990-luvun puolivälissä.Uutena yksikkönä konserniin liitettiin ranskalainen Lemoine-parkettitehdas. Parkettiliiketoiminnasta luovuttiin v. 2001. Imatran Voima Oy:n kanssa perustettiin Elnova-ryhmä. V. 2002 Paloheimo muodostuu kolmesta liiketoiminnasta: Fenestra Oy:n ikkunateollisuudesta, Lundia Oy:n kalustejärjestelmästä ja Wood Oy:n sahateollisuudesta. Osakkuusyhtiöiden kautta konserni on mukana energiatoimialalla."@fi ;
    rdaa:P50407 "Paloheimo (yhtiö)"@fi ;
    rdau:P61101 "Komsi, Pauli. Omistamisen taito : perheyritykset kansakunnan rakentajina / Pauli Komsi, Jan Lindström, Seppo Zetterberg, 2002"@fi ;
    skos:altLabel "Paloheimo-ryhmä"@fi,
        "Paloheimo-yhtymä"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Paloheimo (yhtiö)"@fi .

