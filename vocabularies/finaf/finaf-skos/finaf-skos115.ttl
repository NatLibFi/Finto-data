    rdaa:P50006 "Asteri ID: 000037790" ;
    rdaa:P50016 finaf:000037789 ;
    rdaa:P50035 "Neste Oy, tai Neste-konserni, perustettiin vuonna 1948, jolloin sen tarkoituksena oli turvata Suomen öljynhuoltoa. Neste fuusioitiin Imatran Voiman kanssa Fortumiksi vuonna 1998, mutta yhtiöt erotettiin uudelleen vuonna 2005. Neste Oil Oyj syntyi 1. toukokuuta 2004 Fortum Oyj:n jakautuessa sähkö- ja lämpö- sekä öljy-yhtiöksi. Yhtiö oli aluksi Fortum Oyj:n tytäryhtiö, mutta irtaantui Fortumista keväällä 2005"@fi ;
    rdaa:P50236 "1948/1998"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 mts:m941 ;
    rdaa:P50407 "Neste (yhtiö)"@fi ;
    rdau:P61101 "<a href='http://www.neste.com'>Kotisivut</a>, katsottu 21.10.2020"@fi,
        "Issledovaniâ dal'nejših razrabotok infrastruktury Neneckogo Avtonomnogo Okruga / [Kværner Masa-Yards, Neste, YIT Corporation], 1998"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Neste (yhtiö)"@fi .

