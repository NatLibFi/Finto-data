    rdaa:P50025 "AKKL (Ammatillisten aikuiskoulutuskeskusten liitto)"@fi,
        "Förbundet för vuxenutbildningscentrer"@fi ;
    rdaa:P50035 "Aikuiskoulutuksen järjestäjien yhdistys. Perustettu vuonna 1972 nimellä Ammatillisten kurssikeskusten liitto, vuodesta 1990 Ammatillisten aikuiskoulutuskeskusten Liitto, vuodesta 2009 Ammatillisen Aikuiskoulutuksen Liitto. Ammatillisen Aikuiskoulutuksen Liitto ja Koulutuksen järjestäjien yhdistys KJY lakkauttivat toimintansa ja perustivat Ammattiosaamisen kehittämisyhdistys AMKEn, joka aloitti toimintansa vuoden 2011 alusta."@fi ;
    rdaa:P50236 "1990/2008"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50237 "yhdistys"@fi ;
    rdaa:P50407 "Ammatillisten aikuiskoulutuskeskusten liitto"@fi ;
    rdau:P61101 "Tukeva ote koulutukseen, 2006 [po. 2007]"@fi,
