finaf:000006477 a rdac:C10005,
        skos:Concept ;
    dct:created "1990-04-07"^^xsd:date ;
    dct:modified "2025-05-26T04:35:39"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/000000040458471X>,
        "Asteri ID: 000006477",
        "Y-tunnus: 0599340-0" ;
    rdaa:P50022 yso:p17340 ;
    rdaa:P50025 "Söderström, Werner (yhtiö)"@fi,
        "WS (kustantamo)"@fi,
        "WSOY"@fi,
        "WSOY-yhtymä"@fi,
        "Werner Söderström"@fi,
        "Werner Söderström oy"@fi ;
    rdaa:P50035 "Perustettu 1878 Porvooseen, joista alkuvuodet (1878-1881) kustansi yksityishenkilönä. Osakeyhtiömuodon kustannusliike ja painotalo sai 1904. Toiminta jakautui siten, että toimitusosastot ja pääkonttori olivat Helsingissä ja tuotantolaitokset Porvoossa, myöhemmin myös Juvalla. V. 1934 WSOY perusti Otavan kanssa Yhtyneet Kuvalehdet Oy:n. V. 1969 WSOY, Otava ja Tammi perustivat Suuren Suomalaisen Kirjakerhon. WSOY-yhtymästä muodostui viestinnän monitoimiyhtymä. V. 1998 WSOY, Sanoma Oy, Helsinki Media Company ja Devarda Oy fuusioituivat."@fi ;
    rdaa:P50237 mts:m4963,
        mts:m941 ;
    rdaa:P50301 finaf:000038407 ;
    rdaa:P50350 yso:p94137 ;
    rdaa:P50407 "Werner Söderström osakeyhtiö"@fi ;
    rdau:P61101 "<a href='https://fi.wikipedia.org/wiki/WSOY'>Wikipedia</a>, katsottu 26.10.2020"@fi,
        "<a href='https://www.wsoy.fi/'>Kotisivut</a>, katsottu 26.10.2020"@fi,
        "Hurmio tai turmio / Hannu Tarmio. - Helsinki, 1998"@fi ;
    skos:altLabel "Söderström, Werner (yhtiö)"@fi,
        "WS (kustantamo)"@fi,
        "WSOY"@fi,
        "WSOY-yhtymä"@fi,
        "Werner Söderström"@fi,
        "Werner Söderström oy"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Werner Söderström osakeyhtiö"@fi .

