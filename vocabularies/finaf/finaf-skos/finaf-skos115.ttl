finaf:000010764 a rdac:C10005,
        skos:Concept ;
    dct:created "1993-10-11"^^xsd:date ;
    dct:modified "2020-12-03T20:03:40"^^xsd:dateTime ;
    rdaa:P50006 <http://isni.org/isni/0000000492929748>,
        "Asteri ID: 000010764" ;
    rdaa:P50012 finaf:000000870,
        finaf:000011104,
        finaf:000015905 ;
    rdaa:P50025 "Teknillinen koulu (Helsinki)"@fi ;
    rdaa:P50237 "koulu"@fi ;
    rdaa:P50393 "Koneenkäyttäjä-, värkmestari- ja rakennusmestarikoulu aloitti toimintansa Taideteollisuusyhdistyksen omistamana yksityisenä laitoksena 1.11.1881. Koulu otettiin valtion haltuun 1.7.1886 ja nimi muutettiin Helsingin teollisuuskouluksi. - 1.1.1942 nimenmuutos Helsingin teknilliseksi oppilaitokseksi. Helsingin teknillinen opisto aloitti toimintansa 1945. Helsingin teknillisen koulun oppilasyhdistys rekisteröitiin v. 1946"@fi ;
    rdaa:P50407 "Helsingin teknillinen koulu"@fi ;
    rdau:P61101 "Hintikka, Pekka. Mennyttä aikaa muistelen... : 1881-HTOL-1998, (2002)"@fi ;
