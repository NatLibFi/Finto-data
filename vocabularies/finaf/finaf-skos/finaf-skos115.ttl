finaf:000038011 a rdac:C10005,
        skos:Concept ;
    dct:created "2012-12-05"^^xsd:date ;
    dct:modified "2021-06-19T15:04:03"^^xsd:dateTime ;
    rdaa:P50006 "Asteri ID: 000038011" ;
    rdaa:P50012 finaf:000038010 ;
    rdaa:P50016 finaf:000038092 ;
    rdaa:P50023 <http://lexvo.org/id/iso639-3/swe> ;
    rdaa:P50025 "Finland (suuriruhtinaskunta). Hovrätt (Turku)"@fi,
        "Turu õuekohus (1809-1917)"@fi,
        "Turun hovioikeus (1809-1917)"@fi,
        "Åbo Hovrätt (1809-1917)"@fi ;
    rdaa:P50035 "Turun hovioikeus on Suomen vanhin hovioikeus. Turun hovioikeuden perusti 15. kesäkuuta 1623 antamallaan kuninkaallisella valtakirjalla Ruotsin kuningas Kustaa II Adolf. Ensimmäiseksi hovioikeuden presidentiksi ja samalla Suomen maaherraksi nimitettiin Nils Tuurenpoika Bielke. Hovioikeus toimi ensimmäiset vuotensa Turun linnassa ja Billsteenin talossa, josta se muutti Suurtorin laidalle niin sanottuun Kankaisten taloon 1671. Turun palon tuhottua Kankaisten talon hovioikeus muutti Turun akatemialle rakennettuun Akatemiataloon 1830, jossa se toimii edelleen"@fi ;
    rdaa:P50236 "1809/1917"^^<http://id.loc.gov/datatypes/edtf> ;
    rdaa:P50350 yso:p94447 ;
    rdaa:P50407 "Suomi (suuriruhtinaskunta). Hovioikeus (Turku)"@fi ;
    rdau:P61101 "Wikipedia, katsottu 5.12.2012"@fi ;
    skos:altLabel "Finland (suuriruhtinaskunta). Hovrätt (Turku)"@fi,
        "Turu õuekohus (1809-1917)"@fi,
        "Turun hovioikeus (1809-1917)"@fi,
        "Åbo Hovrätt (1809-1917)"@fi ;
    skos:inScheme finaf: ;
    skos:prefLabel "Suomi (suuriruhtinaskunta). Hovioikeus (Turku)"@fi .

